---
const base = '/ThesisArcPro';

// Support agent photos from Supabase Storage (public bucket)
const agents = [
  'https://rehvwvujuamehoanfomj.supabase.co/storage/v1/object/public/agents/agent1.jpg',
  'https://rehvwvujuamehoanfomj.supabase.co/storage/v1/object/public/agents/agent2.jpg',
  'https://rehvwvujuamehoanfomj.supabase.co/storage/v1/object/public/agents/agent3.jpg',
];
---

<!-- Floating Chat Widget -->
<div id="chatWidget" class="cw-wrap">
  <!-- Launcher (pill) -->
  <button class="cw-launcher" id="cwBubble" aria-label="Chat with support">
    <span class="cw-launcher-closed">
      <span class="cw-launcher-ava">
        <img src={agents[0]} alt="" />
        <span class="cw-launcher-dot"></span>
      </span>
      <span class="cw-launcher-label">Chat with support</span>
    </span>
    <span class="cw-launcher-open">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
      Close
    </span>
  </button>

  <!-- Panel -->
  <div class="cw-panel" id="cwPanel">
    <!-- Home screen -->
    <div class="cw-screen active" id="cwHome">
      <div class="cw-header">
        <div class="cw-header-top">
          <div class="cw-avatars" id="cwAvatars">
            {agents.map((a) => <img src={a} alt="agent" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 40 40%22><circle cx=%2220%22 cy=%2220%22 r=%2220%22 fill=%22%23cbd5e1%22/><circle cx=%2220%22 cy=%2216%22 r=%227%22 fill=%22%23fff%22/><path d=%22M8 36c0-7 6-11 12-11s12 4 12 11%22 fill=%22%23fff%22/></svg>'" />)}
          </div>
        </div>
        <div class="cw-greeting">
          <p class="cw-greeting-sub">Hello there!</p>
          <h2 class="cw-greeting-main">How can we help?</h2>
        </div>
      </div>
      <div class="cw-body">
        <button class="cw-action-card" id="cwStartSupport">
          <span class="cw-action-text">
            <strong>Send us a message</strong>
            <small>We typically reply in under a minute</small>
          </span>
          <span class="cw-action-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </button>
        <div class="cw-home-convos" id="cwConvoList"></div>
      </div>
      <nav class="cw-nav">
        <button class="cw-nav-btn active" data-cwscreen="home">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h5v-6h4v6h5V10"/></svg>
          <span>Home</span>
        </button>
        <button class="cw-nav-btn" data-cwscreen="messages">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>Messages</span>
        </button>
        <button class="cw-nav-btn" data-cwscreen="help">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
          <span>Help</span>
        </button>
      </nav>
    </div>

    <!-- Messages list screen -->
    <div class="cw-screen" id="cwMessages">
      <div class="cw-subhead">
        <button class="cw-back-btn" id="cwBackFromMessages">‹</button>
        <h3>Messages</h3>
      </div>
      <div class="cw-convo-list" id="cwAllConvos">
        <div class="cw-convo-loading">Loading…</div>
      </div>
      <nav class="cw-nav">
        <button class="cw-nav-btn" data-cwscreen="home">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h5v-6h4v6h5V10"/></svg>
          <span>Home</span>
        </button>
        <button class="cw-nav-btn active" data-cwscreen="messages">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>Messages</span>
        </button>
        <button class="cw-nav-btn" data-cwscreen="help">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
          <span>Help</span>
        </button>
      </nav>
    </div>

    <!-- Help screen -->
    <div class="cw-screen" id="cwHelp">
      <div class="cw-subhead">
        <button class="cw-back-btn" id="cwBackFromHelp">‹</button>
        <h3>Help</h3>
      </div>
      <div class="cw-help-body">
        <p class="cw-help-lead">Need a hand? Start a chat and our team will get back to you fast.</p>
        <button class="cw-action-card" id="cwHelpStart">
          <span class="cw-action-text"><strong>Contact support</strong><small>Average reply: under a minute</small></span>
          <span class="cw-action-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </button>
        <a class="cw-help-link" href={`${base}/faq/`}>📚 Browse FAQ</a>
      </div>
      <nav class="cw-nav">
        <button class="cw-nav-btn" data-cwscreen="home">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h5v-6h4v6h5V10"/></svg>
          <span>Home</span>
        </button>
        <button class="cw-nav-btn" data-cwscreen="messages">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>Messages</span>
        </button>
        <button class="cw-nav-btn active" data-cwscreen="help">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12" y2="17"/></svg>
          <span>Help</span>
        </button>
      </nav>
    </div>

    <!-- Chat thread screen -->
    <div class="cw-screen" id="cwThread">
      <div class="cw-thread-header">
        <button class="cw-back-btn" id="cwBackFromThread">‹</button>
        <div class="cw-thread-title" id="cwThreadTitle">Support</div>
      </div>
      <div class="cw-thread-msgs" id="cwThreadMsgs"></div>
      <div class="cw-thread-input">
        <input type="text" class="cw-input" id="cwInput" placeholder="Type a message…" />
        <button class="cw-send" id="cwSend" aria-label="Send">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .cw-wrap { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 50000; font-family: 'Poppins','Inter','Segoe UI',sans-serif; }

  /* ── LAUNCHER PILL ── */
  .cw-launcher {
    display: inline-flex; align-items: center; gap: 0.55rem;
    height: 48px; padding: 0 1rem 0 0.5rem; border: none; cursor: pointer;
    background: #fff; color: #0f172a; border-radius: 999px;
    box-shadow: 0 6px 22px rgba(15,23,42,0.18); transition: all 0.25s ease;
    font-family: inherit; font-size: 0.9rem; font-weight: 600;
  }
  .cw-launcher:hover { box-shadow: 0 8px 28px rgba(15,23,42,0.24); transform: translateY(-1px); }
  .cw-launcher-closed { display: inline-flex; align-items: center; gap: 0.55rem; }
  .cw-launcher-ava { position: relative; width: 38px; height: 38px; flex-shrink: 0; }
  .cw-launcher-ava img { width: 100%; height: 100%; border-radius: 50%; object-fit: cover; background: #e2e8f0; }
  .cw-launcher-dot { position: absolute; bottom: 1px; right: 1px; width: 11px; height: 11px; background: #22c55e; border: 2px solid #fff; border-radius: 50%; }
  .cw-launcher-open { display: none; align-items: center; gap: 0.4rem; }

  .cw-launcher.open { background: #ffcc00; color: #1a1a1a; padding: 0 1.3rem; }
  .cw-launcher.open .cw-launcher-closed { display: none; }
  .cw-launcher.open .cw-launcher-open { display: inline-flex; }

  /* ── PANEL ── */
  .cw-panel {
    position: absolute; bottom: 64px; right: 0;
    width: 380px; height: 560px; background: #fff; border-radius: 18px;
    box-shadow: 0 12px 48px rgba(15,23,42,0.22);
    display: none; flex-direction: column; overflow: hidden;
    transform: translateY(12px) scale(0.98); opacity: 0; transition: all 0.22s ease;
  }
  .cw-panel.open { display: flex; transform: translateY(0) scale(1); opacity: 1; }

  .cw-screen { display: none; flex-direction: column; flex: 1; overflow: hidden; }
  .cw-screen.active { display: flex; }

  /* ── HEADER ── */
  .cw-header { background: linear-gradient(160deg, #2563eb 0%, #1233a0 100%); padding: 1.3rem 1.4rem 1.6rem; color: #fff; }
  .cw-header-top { margin-bottom: 1.6rem; }
  .cw-avatars { display: flex; }
  .cw-avatars img { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.85); margin-left: -10px; background: #cbd5e1; }
  .cw-avatars img:first-child { margin-left: 0; }
  .cw-greeting-sub { font-size: 1.4rem; font-weight: 400; color: rgba(255,255,255,0.55); line-height: 1.2; }
  .cw-greeting-main { font-size: 1.5rem; font-weight: 700; line-height: 1.25; }

  /* ── BODY ── */
  .cw-body { flex: 1; overflow-y: auto; padding: 1.1rem 1.2rem; background: #f8fafc; }
  .cw-action-card {
    width: 100%; display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.1rem; background: #fff; border: 1px solid #e8edf3;
    border-radius: 14px; cursor: pointer; transition: 0.18s; text-align: left;
    box-shadow: 0 2px 10px rgba(15,23,42,0.05);
  }
  .cw-action-card:hover { box-shadow: 0 4px 16px rgba(37,99,235,0.14); transform: translateY(-1px); }
  .cw-action-text { flex: 1; }
  .cw-action-text strong { display: block; font-size: 0.95rem; color: #0f172a; font-weight: 700; }
  .cw-action-text small { font-size: 0.78rem; color: #64748b; }
  .cw-action-arrow { color: #0f172a; display: flex; }

  .cw-home-convos { margin-top: 1rem; }

  /* ── NAV ── */
  .cw-nav { display: flex; border-top: 1px solid #eef2f6; background: #fff; }
  .cw-nav-btn {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.65rem 0; background: none; border: none; cursor: pointer;
    font-size: 0.72rem; font-weight: 600; color: #94a3b8; transition: 0.18s; font-family: inherit;
  }
  .cw-nav-btn svg { width: 22px; height: 22px; }
  .cw-nav-btn.active { color: #0f172a; }
  .cw-nav-btn:hover { color: #0f172a; }

  /* ── SUBHEAD (messages / help) ── */
  .cw-subhead { display: flex; align-items: center; gap: 0.4rem; padding: 0.9rem 1rem; border-bottom: 1px solid #eef2f6; }
  .cw-subhead h3 { flex: 1; font-size: 1.05rem; font-weight: 700; color: #0f172a; }
  .cw-back-btn { background: none; border: none; font-size: 1.5rem; color: #64748b; cursor: pointer; padding: 0 0.3rem; line-height: 1; }
  .cw-back-btn:hover { color: #0f172a; }

  .cw-convo-list { flex: 1; overflow-y: auto; }
  .cw-convo-loading { padding: 2rem; text-align: center; color: #94a3b8; font-size: 0.85rem; }
  .cw-convo-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.2rem; cursor: pointer; transition: 0.15s; border-bottom: 1px solid #f1f5f9; }
  .cw-convo-item:hover { background: #f8fafc; }
  .cw-convo-icon { width: 38px; height: 38px; border-radius: 50%; background: #eef6ff; display: flex; align-items: center; justify-content: center; font-size: 0.95rem; flex-shrink: 0; }
  .cw-convo-info { flex: 1; min-width: 0; }
  .cw-convo-name { font-size: 0.88rem; font-weight: 600; color: #0f172a; }
  .cw-convo-time { font-size: 0.68rem; color: #94a3b8; flex-shrink: 0; }

  /* ── HELP ── */
  .cw-help-body { flex: 1; overflow-y: auto; padding: 1.2rem; background: #f8fafc; }
  .cw-help-lead { font-size: 0.88rem; color: #475569; line-height: 1.6; margin-bottom: 1rem; }
  .cw-help-link { display: block; margin-top: 0.8rem; padding: 0.85rem 1rem; background: #fff; border: 1px solid #e8edf3; border-radius: 12px; font-size: 0.88rem; font-weight: 600; color: #0f172a; text-decoration: none; }
  .cw-help-link:hover { border-color: #2563eb; }

  /* ── THREAD ── */
  .cw-thread-header { display: flex; align-items: center; gap: 0.4rem; padding: 0.9rem 1rem; border-bottom: 1px solid #eef2f6; background: #fff; }
  .cw-thread-title { flex: 1; font-size: 0.98rem; font-weight: 700; color: #0f172a; }
  .cw-thread-msgs { flex: 1; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 0.5rem; background: #f8fafc; }
  .cw-msg { display: flex; flex-direction: column; max-width: 80%; }
  .cw-msg.mine { align-self: flex-end; }
  .cw-msg.theirs { align-self: flex-start; }
  .cw-msg-name { font-size: 0.65rem; font-weight: 600; color: #94a3b8; margin-bottom: 0.15rem; }
  .cw-msg-bubble { padding: 0.55rem 0.85rem; border-radius: 14px; font-size: 0.85rem; line-height: 1.5; word-wrap: break-word; }
  .cw-msg.mine .cw-msg-bubble { background: #2563eb; color: #fff; border-bottom-right-radius: 4px; }
  .cw-msg.theirs .cw-msg-bubble { background: #fff; color: #0f172a; border: 1px solid #eef2f6; border-bottom-left-radius: 4px; }
  .cw-msg-time { font-size: 0.6rem; color: #94a3b8; margin-top: 0.15rem; }
  .cw-msg.mine .cw-msg-time { text-align: right; }

  .cw-thread-input { display: flex; gap: 0.4rem; padding: 0.7rem 0.9rem; border-top: 1px solid #eef2f6; background: #fff; }
  .cw-input { flex: 1; background: #f1f5f9; border: 1px solid transparent; border-radius: 22px; padding: 0.55rem 1rem; font-size: 0.85rem; color: #0f172a; outline: none; font-family: inherit; }
  .cw-input:focus { border-color: #2563eb; background: #fff; }
  .cw-input::placeholder { color: #94a3b8; }
  .cw-send { width: 40px; height: 40px; border-radius: 50%; border: none; background: #2563eb; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; flex-shrink: 0; }
  .cw-send:hover { background: #1d4ed8; }
  .cw-send:disabled { opacity: 0.5; cursor: not-allowed; }

  .cw-login-prompt { padding: 2rem 1.5rem; text-align: center; }
  .cw-login-prompt p { font-size: 0.9rem; color: #64748b; margin-bottom: 1rem; }
  .cw-login-btn { background: #2563eb; color: #fff; border: none; border-radius: 10px; padding: 0.65rem 1.5rem; font-size: 0.88rem; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
  .cw-login-btn:hover { background: #1d4ed8; }

  @media (max-width: 480px) {
    .cw-panel { width: calc(100vw - 2rem); right: -0.5rem; bottom: 60px; height: 75vh; }
  }

  /* ── UNREAD BADGE ── */
  .cw-badge {
    position: absolute; top: -6px; right: -6px;
    background: #4455ef; color: #fff;
    font-size: 0.65rem; font-weight: 700;
    min-width: 20px; height: 20px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    padding: 0 4px; border: 2px solid #fff;
    pointer-events: none;
  }
  .cw-launcher { position: relative; }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
  const base = '/ThesisArcPro';

  let cwSession: any = null;
  let cwUserId = '';
  let cwUserName = '';
  let cwUserRole = '';
  let cwConversations: any[] = [];
  let cwActiveConvoId: string | null = null;
  let cwSub: any = null;

  const bubble = document.getElementById('cwBubble')!;
  const panel = document.getElementById('cwPanel')!;
  const homeScreen = document.getElementById('cwHome')!;
  const messagesScreen = document.getElementById('cwMessages')!;
  const helpScreen = document.getElementById('cwHelp')!;
  const threadScreen = document.getElementById('cwThread')!;

  function cwEsc(v: any) { return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  let cwUnreadCount = 0;
  let cwGlobalSub: any = null;

  function cwPlayPing() {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, ctx.currentTime);
      osc.frequency.setValueAtTime(660, ctx.currentTime + 0.12);
      gain.gain.setValueAtTime(0.18, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.35);
      osc.start(); osc.stop(ctx.currentTime + 0.35);
    } catch (e) {}
  }

  function cwSetBadge(count: number) {
    cwUnreadCount = count;
    let badge = document.getElementById('cwBadge');
    if (count > 0) {
      if (!badge) {
        badge = document.createElement('span');
        badge.id = 'cwBadge';
        badge.className = 'cw-badge';
        bubble.appendChild(badge);
      }
      badge.textContent = count > 9 ? '9+' : String(count);
    } else {
      badge?.remove();
    }
  }

  async function cwStartGlobalSub() {
    if (cwGlobalSub) return;
    // Subscribe to ALL messages table inserts — filter by sender_id != me on client side
    cwGlobalSub = supabase
      .channel('cw-global-notify')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' },
        (payload: any) => {
          const msg = payload.new;
          if (msg.sender_id === cwUserId) return; // ignore own messages
          // Only notify if the conversation belongs to us
          const isOurs = cwConversations.some((c: any) => c.id === msg.conversation_id);
          if (!isOurs) return;
          // Only ping/badge if panel is closed OR this isn't the active thread
          const panelOpen = panel.classList.contains('open');
          const isActiveThread = panelOpen && msg.conversation_id === cwActiveConvoId;
          if (!isActiveThread) {
            cwPlayPing();
            cwSetBadge(cwUnreadCount + 1);
          }
        }
      )
      .subscribe();
  }

  // Toggle launcher
  bubble.addEventListener('click', async () => {
    if (panel.classList.contains('open')) { closePanel(); return; }
    bubble.classList.add('open');
    panel.classList.add('open');
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { showLoginPrompt(); return; }
    cwSession = session;
    cwUserId = session.user.id;
    await detectRole();
    showScreen('home');
    await loadCwConversations();
    cwStartGlobalSub();
    cwSetBadge(0); // clear badge when user opens the panel
  });

  function closePanel() {
    panel.classList.remove('open');
    bubble.classList.remove('open');
    if (cwSub) { cwSub.unsubscribe(); cwSub = null; }
  }

  function showScreen(name: string) {
    [homeScreen, messagesScreen, helpScreen, threadScreen].forEach(s => s.classList.remove('active'));
    if (name === 'home') homeScreen.classList.add('active');
    else if (name === 'messages') messagesScreen.classList.add('active');
    else if (name === 'help') helpScreen.classList.add('active');
    else if (name === 'thread') threadScreen.classList.add('active');
  }

  // Nav buttons
  document.querySelectorAll('.cw-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const screen = (btn as HTMLElement).dataset.cwscreen;
      if (screen === 'messages') { showScreen('messages'); loadCwConversations(); }
      else if (screen === 'help') showScreen('help');
      else showScreen('home');
    });
  });

  document.getElementById('cwBackFromMessages')?.addEventListener('click', () => showScreen('home'));
  document.getElementById('cwBackFromHelp')?.addEventListener('click', () => showScreen('home'));
  document.getElementById('cwBackFromThread')?.addEventListener('click', () => { showScreen('messages'); cwActiveConvoId = null; if (cwSub) { cwSub.unsubscribe(); cwSub = null; } });

  function showLoginPrompt() {
    homeScreen.classList.add('active');
    const body = homeScreen.querySelector('.cw-body');
    if (body) body.innerHTML = `<div class="cw-login-prompt"><p>Log in to send us a message</p><a href="${base}/login/" class="cw-login-btn">Log In</a></div>`;
  }

  async function detectRole() {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/writers?auth_user_id=eq.${cwUserId}&select=id,full_name`, { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` } });
      const data = await res.json();
      if (data.length) { cwUserRole = 'writer'; cwUserName = data[0].full_name; return; }
    } catch (e) {}
    if (cwSession.user.email === 'thesisarcpro069@gmail.com') { cwUserRole = 'admin'; cwUserName = 'Admin'; return; }
    cwUserRole = 'client';
    cwUserName = cwSession.user.email?.split('@')[0] || 'Client';
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/profiles?email=eq.${encodeURIComponent(cwSession.user.email || '')}&select=full_name`, { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` } });
      const data = await res.json();
      if (data[0]?.full_name) cwUserName = data[0].full_name;
    } catch (e) {}
  }

  async function loadCwConversations() {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants?user_id=eq.${cwUserId}&select=conversation_id,conversations(id,type,title,updated_at)`, { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` } });
      const data = await res.json();
      cwConversations = data.map((d: any) => d.conversations).filter(Boolean).sort((a: any, b: any) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
      renderCwConvoList();
      renderCwHomeConvos();
    } catch (err) { console.error(err); }
  }

  function renderCwHomeConvos() {
    const el = document.getElementById('cwConvoList')!;
    if (!cwConversations.length) { el.innerHTML = ''; return; }
    const recent = cwConversations.slice(0, 3);
    el.innerHTML = `<p style="font-size:0.72rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;margin:0 0 0.4rem;">Recent</p>` +
      recent.map((c: any) => {
        const icon = c.type === 'support' ? '🛟' : '📋';
        return `<div class="cw-convo-item" data-cwcid="${c.id}" style="border-radius:12px;border-bottom:none;background:#fff;margin-bottom:0.4rem;border:1px solid #eef2f6;">
          <div class="cw-convo-icon">${icon}</div>
          <div class="cw-convo-info"><div class="cw-convo-name">${cwEsc(c.title || 'Chat')}</div></div>
        </div>`;
      }).join('');
    el.querySelectorAll('[data-cwcid]').forEach(item => item.addEventListener('click', () => openCwThread((item as HTMLElement).dataset.cwcid!)));
  }

  function renderCwConvoList() {
    const el = document.getElementById('cwAllConvos')!;
    if (!cwConversations.length) { el.innerHTML = '<div class="cw-convo-loading">No conversations yet</div>'; return; }
    el.innerHTML = cwConversations.map((c: any) => {
      const icon = c.type === 'support' ? '🛟' : '📋';
      const time = c.updated_at ? new Date(c.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
      return `<div class="cw-convo-item" data-cwcid="${c.id}"><div class="cw-convo-icon">${icon}</div><div class="cw-convo-info"><div class="cw-convo-name">${cwEsc(c.title || 'Chat')}</div></div><div class="cw-convo-time">${time}</div></div>`;
    }).join('');
    el.querySelectorAll('.cw-convo-item').forEach(item => item.addEventListener('click', () => openCwThread((item as HTMLElement).dataset.cwcid!)));
  }

  async function startSupport() {
    if (!cwSession) return;
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/conversations`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}`, 'Prefer': 'return=representation' },
        body: JSON.stringify({ type: 'support', title: `Support — ${cwUserName}` })
      });
      const conv = (await res.json())[0];
      if (!conv) throw new Error('Failed');
      await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` },
        body: JSON.stringify({ conversation_id: conv.id, user_id: cwUserId, role: cwUserRole, display_name: cwUserName })
      });
      await loadCwConversations();
      openCwThread(conv.id);
    } catch (err) { console.error(err); alert('Could not start chat. Please try again.'); }
  }
  document.getElementById('cwStartSupport')?.addEventListener('click', startSupport);
  document.getElementById('cwHelpStart')?.addEventListener('click', startSupport);

  async function openCwThread(conversationId: string) {
    cwActiveConvoId = conversationId;
    const conv = cwConversations.find(c => c.id === conversationId);
    document.getElementById('cwThreadTitle')!.textContent = conv?.title || 'Chat';
    showScreen('thread');
    const container = document.getElementById('cwThreadMsgs')!;
    container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;font-size:0.85rem;">Loading…</div>';
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/messages?conversation_id=eq.${conversationId}&order=created_at.asc`, { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` } });
      renderCwMessages(await res.json());
    } catch (err) { console.error(err); container.innerHTML = '<div style="text-align:center;color:#94a3b8;">Could not load messages</div>'; }
    if (cwSub) { cwSub.unsubscribe(); cwSub = null; }
    cwSub = supabase.channel(`cw-${conversationId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages', filter: `conversation_id=eq.${conversationId}` }, (payload: any) => {
        const msg = payload.new;
        const c = document.getElementById('cwThreadMsgs')!;
        const ph = c.querySelector('div[style*="text-align:center"]');
        if (ph) c.innerHTML = '';
        const isMine = msg.sender_id === cwUserId;
        if (!isMine) cwPlayPing();
        const time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
        c.insertAdjacentHTML('beforeend', `<div class="cw-msg ${isMine ? 'mine' : 'theirs'}">${!isMine ? `<div class="cw-msg-name">${cwEsc(msg.sender_name || 'Support')}</div>` : ''}<div class="cw-msg-bubble">${cwEsc(msg.content)}</div><div class="cw-msg-time">${time}</div></div>`);
        c.scrollTop = c.scrollHeight;
      }).subscribe();
  }

  function renderCwMessages(messages: any[]) {
    const container = document.getElementById('cwThreadMsgs')!;
    if (!messages.length) { container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;font-size:0.85rem;">No messages yet. Say hello!</div>'; return; }
    container.innerHTML = messages.map((m: any) => {
      const isMine = m.sender_id === cwUserId;
      const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
      return `<div class="cw-msg ${isMine ? 'mine' : 'theirs'}">${!isMine ? `<div class="cw-msg-name">${cwEsc(m.sender_name || 'Support')}</div>` : ''}<div class="cw-msg-bubble">${cwEsc(m.content)}</div><div class="cw-msg-time">${time}</div></div>`;
    }).join('');
    container.scrollTop = container.scrollHeight;
  }

  document.getElementById('cwSend')?.addEventListener('click', cwSendMessage);
  document.getElementById('cwInput')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); cwSendMessage(); } });

  async function cwSendMessage() {
    const input = document.getElementById('cwInput') as HTMLInputElement;
    const content = input.value.trim();
    if (!content || !cwActiveConvoId || !cwSession) return;
    const btn = document.getElementById('cwSend') as HTMLButtonElement;
    btn.disabled = true; input.value = '';
    try {
      await fetch(`${SUPABASE_URL}/rest/v1/messages`, { method: 'POST', headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}` }, body: JSON.stringify({ conversation_id: cwActiveConvoId, sender_id: cwUserId, sender_name: cwUserName, sender_role: cwUserRole, content }) });
      await fetch(`${SUPABASE_URL}/rest/v1/conversations?id=eq.${cwActiveConvoId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${cwSession.access_token}`, 'Prefer': 'return=minimal' }, body: JSON.stringify({ updated_at: new Date().toISOString() }) });
    } catch (err) { console.error(err); }
    btn.disabled = false; input.focus();
  }
</script>