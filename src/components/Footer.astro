---

<footer class="footer">
  <div class="container footer__inner">

    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <span class="logo-thesis">Thesis</span><span class="logo-arc">Arc</span><span class="logo-pro">Pro</span>
      </a>
      <p>Premium academic research & writing support for graduate students and researchers worldwide.</p>
    </div>

    <div class="footer__links">
      <h4>Quick Links</h4>
      <a href="/services">Services</a>
      <a href="/how-it-works">How It Works</a>
      <a href="/about">About Us</a>
      <a href="/academic-integrity">Academic Integrity</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer__links">
      <h4>Services</h4>
      <a href="/services">Dissertation Support</a>
      <a href="/services">Research Consulting</a>
      <a href="/services">Editing & Proofreading</a>
      <a href="/services">PhD Coaching</a>
    </div>

    <div class="footer__contact">
      <h4>Get In Touch</h4>
      <p>Ready to elevate your research?</p>
      <a href="/contact" class="btn-primary">Book Free Consultation</a>
    </div>

  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>&copy; 2026 ThesisArcPro. All rights reserved.</p>
      <div class="footer__legal">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
.footer {
  background-color: var(--navy);
  color: var(--white);
  padding-top: 4rem;
}

.footer__inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 3rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid var(--border);
}

.footer__logo {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 700;
  display: inline-block;
  margin-bottom: 1rem;
}

.logo-thesis { color: var(--white); }
.logo-arc    { color: var(--gold);  }
.logo-pro    { color: var(--white); }

.footer__brand p {
  color: rgba(255,255,255,0.6);
  font-size: 0.9rem;
  line-height: 1.7;
  max-width: 260px;
}

.footer__links h4,
.footer__contact h4 {
  color: var(--gold);
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  margin-bottom: 1.2rem;
}

.footer__links {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.footer__links a {
  color: rgba(255,255,255,0.65);
  font-size: 0.9rem;
  transition: color 0.3s ease;
}

.footer__links a:hover {
  color: var(--gold);
}

.footer__contact p {
  color: rgba(255,255,255,0.6);
  font-size: 0.9rem;
  margin-bottom: 1.2rem;
}

.footer__contact .btn-primary {
  font-size: 0.85rem;
  padding: 0.7rem 1.4rem;
}

.footer__bottom {
  padding: 1.5rem 0;
}

.footer__bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.footer__bottom p {
  color: rgba(255,255,255,0.4);
  font-size: 0.85rem;
}

.footer__legal {
  display: flex;
  gap: 1.5rem;
}

.footer__legal a {
  color: rgba(255,255,255,0.4);
  font-size: 0.85rem;
  transition: color 0.3s ease;
}

.footer__legal a:hover {
  color: var(--gold);
}

@media (max-width: 768px) {
  .footer__inner {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .footer__bottom-inner {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }
}

@media (max-width: 480px) {
  .footer__inner {
    grid-template-columns: 1fr;
  }
}
</style>