---
const base = '';
---
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <h1>Expert Academic Writing<br/>& Research Support</h1>
      <p class="hero__sub">From high school essays to PhD dissertations — we provide expert guidance, writing support, and professional editing at every academic level.</p>
      <a href="#" class="hero__btn auth-gate">Place your order</a>
    </div>
    <div class="hero__visual">
      <img
        src="/images/hero.svg"
        alt="Students receiving expert academic writing and research support"
        width="500"
        height="400"
        loading="eager"
      />
    </div>
  </div>

  <!-- Navy trust strip (full-width bar) -->
  <div class="hero__trust-bar">
    <div class="container hero__trust-inner">
      <div class="trust-stat">
        <span class="trust-num">2,000+</span>
        <span class="trust-lbl">Students Helped</span>
      </div>
      <div class="trust-div"></div>
      <div class="trust-stat">
        <span class="trust-num">98%</span>
        <span class="trust-lbl">Satisfaction Rate</span>
      </div>
      <div class="trust-div"></div>
      <div class="trust-stat">
        <span class="trust-num">Deadlines from</span>
        <span class="trust-lbl">3 hours</span>
      </div>
    </div>
  </div>

  <!-- Tagline below strip -->
  <p class="hero__tagline">
    <span class="tagline-icon">🛡️</span>
    No AI, no shortcuts — just real writers delivering plagiarism-free essays
  </p>
</section>

<style>
/* ── Hero section ── */
.hero {
  background: var(--bg-body, #ffffff);
  padding-top: 7rem;
}

.hero__inner {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 3rem;
  align-items: center;
  padding-bottom: 3rem;
}

/* ── Left content ── */
.hero__content {
  max-width: 520px;
}

.hero h1 {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: clamp(2rem, 4.5vw, 2.6rem);
  font-weight: 800;
  color: var(--color-main, #303b4f);
  line-height: 1.2;
  margin-bottom: 1.2rem;
}

.hero__sub {
  color: var(--color-main-light, #6d7483);
  font-size: 0.98rem;
  line-height: 1.7;
  margin-bottom: 2rem;
}

.hero__btn {
  display: inline-block;
  background: var(--color-main, #303b4f);
  color: #ffffff;
  padding: 0.8rem 2.2rem;
  border-radius: 25px;
  font-size: 0.92rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
}
.hero__btn:hover {
  background: #1a2332;
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(48,59,79,0.3);
}

/* ── Right image ── */
.hero__visual {
  display: flex;
  justify-content: center;
  align-items: center;
}
.hero__visual img {
  width: 100%;
  max-width: 440px;
  height: auto;
}

/* ── Navy trust bar (full-width) ── */
.hero__trust-bar {
  background: var(--navy, #1B2A4A);
  padding: 1.2rem 0;
}

.hero__trust-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}

.trust-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
}
.trust-num {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: 1.3rem;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.2;
}
.trust-lbl {
  font-size: 0.78rem;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.3px;
}

.trust-div {
  width: 1px;
  height: 36px;
  background: rgba(255,255,255,0.2);
}

/* ── Tagline below bar ── */
.hero__tagline {
  text-align: center;
  padding: 1rem 0 0;
  font-size: 0.85rem;
  color: var(--color-main-light, #6d7483);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  background: var(--bg-body, #ffffff);
}
.tagline-icon {
  font-size: 1rem;
}

/* ── Mobile ── */
@media (max-width: 768px) {
  .hero { padding-top: 5.5rem; }
  .hero__inner {
    grid-template-columns: 1fr;
    gap: 2rem;
    text-align: center;
  }
  .hero__content { max-width: 100%; }
  .hero__visual { order: -1; }
  .hero__visual img { max-width: 280px; }
  .hero__trust-inner { gap: 1.5rem; }
  .trust-div { display: none; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const { data: { session } } = await supabase.auth.getSession();
  const authGateLinks = document.querySelectorAll('.auth-gate');

  authGateLinks.forEach(link => {
    if (session) {
      link.setAttribute('href', '/contact/');
    } else {
      link.setAttribute('href', '/contact/');
    }
  });
</script>
