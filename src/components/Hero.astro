---
const base = '/ThesisArcPro';
---
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__eyebrow">Trusted by Students Worldwide</p>
      <h1>Expert Academic Writing & Research Support</h1>
      <p class="hero__sub">From high school essays to PhD dissertations — we provide expert guidance, writing support, and professional editing at every academic level.</p>
      <div class="hero__buttons">
        <a href="#" class="btn-primary auth-gate">Book a Free Consultation</a>
        <a href="#" class="btn-hero-secondary auth-gate">Get a Free Quote</a>
      </div>
      <div class="hero__trust">
        <div class="trust-item">
          <span class="trust-number">2,000+</span>
          <span class="trust-label">Students Helped</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">98%</span>
          <span class="trust-label">Satisfaction Rate</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <span class="trust-number">50+</span>
          <span class="trust-label">Expert Writers</span>
        </div>
      </div>
    </div>
    <div class="hero__visual">
      <img
        src="/ThesisArcPro/images/hero.svg"
        alt="Students receiving expert academic writing and dissertation support"
        width="500"
        height="400"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
.hero { background-color: #EEF2FB; padding: 10rem 0 6rem; position: relative; overflow: hidden; }
.hero::before { content: ''; position: absolute; top: -50%; right: -20%; width: 600px; height: 600px; background: radial-gradient(circle, rgba(197,160,89,0.10) 0%, transparent 70%); pointer-events: none; }
.hero__inner { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; position: relative; z-index: 1; }
.hero__eyebrow { color: var(--gold); font-size: 0.85rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1.2rem; }
.hero h1 { color: #1B2A4A; margin-bottom: 1.5rem; }
.hero__sub { color: #4A5568; font-size: 1.1rem; line-height: 1.8; margin-bottom: 2.5rem; max-width: 520px; }
.hero__buttons { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 3rem; }

/* Fixed secondary button — was invisible white-on-light; now blue supporting accent */
.btn-hero-secondary {
  display: inline-block; background-color: transparent; color: #2563EB;
  padding: 0.85rem 2rem; border-radius: 4px; font-family: var(--font-body);
  font-weight: 600; font-size: 0.95rem; letter-spacing: 0.5px;
  border: 2px solid #2563EB; cursor: pointer; transition: all 0.25s ease;
}
.btn-hero-secondary:hover { background-color: #2563EB; color: #ffffff; transform: translateY(-2px); }

.hero__trust { display: flex; align-items: center; gap: 1.5rem; }
.trust-item { display: flex; flex-direction: column; gap: 0.2rem; }
.trust-number { color: #1B2A4A; font-family: var(--font-heading); font-size: 1.8rem; font-weight: 700; line-height: 1; }
.trust-label { color: #718096; font-size: 0.8rem; letter-spacing: 0.5px; }
.trust-divider { width: 1px; height: 40px; background-color: #cbd5e1; }
.hero__visual { display: flex; justify-content: center; align-items: center; position: relative; z-index: 1; }
.hero__visual img { width: 100%; max-width: 480px; height: auto; filter: drop-shadow(0 16px 32px rgba(27,42,74,0.12)); }
@media (max-width: 768px) {
  .hero { padding: 8rem 0 4rem; }
  .hero__inner { grid-template-columns: 1fr; gap: 3rem; }
  .hero__visual { display: none; }
  .hero__trust { gap: 1rem; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const { data: { session } } = await supabase.auth.getSession();
  const authGateLinks = document.querySelectorAll('.auth-gate');

  authGateLinks.forEach(link => {
    if (session) {
      link.setAttribute('href', '/ThesisArcPro/contact/');
    } else {
      link.setAttribute('href', '/ThesisArcPro/login/');
    }
  });
</script>