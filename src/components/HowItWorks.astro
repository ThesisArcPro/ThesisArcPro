---
const base = '/ThesisArcPro';
---

<section class="hiw">
  <div class="container">

    <p class="hiw__eyebrow">Simple Process</p>
    <h2 class="section-title">How ThesisArcPro Works</h2>
    <hr class="gold-line" />
    <p class="section-subtitle">Getting expert academic support has never been easier. Follow these simple steps and get your work done professionally.</p>

    <div class="hiw__illustration">
      <img src="/ThesisArcPro/images/process.svg" alt="Simple 3 step process to get expert academic writing and research support" width="600" height="350" loading="lazy" />
    </div>

    <div class="hiw__steps">
      <div class="hiw__step">
        <div class="step__number">01</div>
        <div class="step__icon">📋</div>
        <h3>Submit Your Details</h3>
        <p>Fill out our simple order form with your assignment details — subject, deadline, academic level, and any specific requirements.</p>
      </div>
      <div class="hiw__connector">
        <div class="connector__line"></div>
        <div class="connector__arrow">→</div>
      </div>
      <div class="hiw__step">
        <div class="step__number">02</div>
        <div class="step__icon">🔍</div>
        <h3>Match With an Expert</h3>
        <p>We match you with the best qualified writer or researcher for your specific subject, academic level, and requirements.</p>
      </div>
      <div class="hiw__connector">
        <div class="connector__line"></div>
        <div class="connector__arrow">→</div>
      </div>
      <div class="hiw__step">
        <div class="step__number">03</div>
        <div class="step__icon">✅</div>
        <h3>Receive Quality Work</h3>
        <p>Get your completed, plagiarism-free work delivered before your deadline — ready to submit with confidence.</p>
      </div>
    </div>

    <div class="hiw__features">
      <div class="hiw__feature"><span class="feature__icon">⚡</span><span>Fast Turnaround</span></div>
      <div class="hiw__feature"><span class="feature__icon">🔒</span><span>100% Confidential</span></div>
      <div class="hiw__feature"><span class="feature__icon">✅</span><span>Plagiarism Free</span></div>
      <div class="hiw__feature"><span class="feature__icon">💬</span><span>24/7 Support</span></div>
      <div class="hiw__feature"><span class="feature__icon">🔄</span><span>Free Revisions</span></div>
    </div>

    <div class="hiw__cta">
      <a href="#" class="btn-primary auth-gate-hiw">Get Started Now</a>
    </div>

  </div>
</section>

<style>
.hiw { padding: var(--section-padding); background-color: var(--white); }
.hiw__eyebrow { text-align: center; color: var(--gold); font-size: 0.85rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; }
.hiw__illustration { display: flex; justify-content: center; margin-bottom: 3rem; }
.hiw__illustration img { width: 100%; max-width: 550px; height: auto; }
.hiw__steps { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 4rem; flex-wrap: wrap; }
.hiw__step { background-color: var(--off-white); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 2.5rem 2rem; text-align: center; flex: 1; min-width: 220px; max-width: 280px; position: relative; transition: all 0.3s ease; }
.hiw__step:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(27,42,74,0.12); border-color: var(--gold); }
.step__number { position: absolute; top: -16px; left: 50%; transform: translateX(-50%); background-color: var(--navy); color: var(--gold); font-family: var(--font-heading); font-size: 0.85rem; font-weight: 700; letter-spacing: 1px; padding: 0.3rem 1rem; border-radius: 20px; }
.step__icon { font-size: 2.5rem; margin-bottom: 1rem; margin-top: 0.5rem; }
.hiw__step h3 { color: var(--navy); font-size: 1.1rem; margin-bottom: 0.8rem; }
.hiw__step p { color: var(--text-mid); font-size: 0.9rem; line-height: 1.7; }
.hiw__connector { display: flex; flex-direction: column; align-items: center; gap: 0.3rem; padding: 0 1rem; color: var(--gold); }
.connector__line { width: 40px; height: 2px; background: linear-gradient(90deg, var(--gold) 0%, var(--gold-light) 100%); }
.connector__arrow { color: var(--gold); font-size: 1.2rem; }
.hiw__features { display: flex; justify-content: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 3rem; padding: 2rem; background-color: var(--navy); border-radius: 12px; }
.hiw__feature { display: flex; align-items: center; gap: 0.6rem; color: rgba(255,255,255,0.85); font-size: 0.9rem; font-weight: 500; }
.feature__icon { color: var(--gold); font-size: 1.1rem; }
.hiw__cta { text-align: center; }
@media (max-width: 768px) {
  .hiw__steps { flex-direction: column; align-items: center; }
  .hiw__connector { flex-direction: row; transform: rotate(90deg); padding: 0.5rem 0; }
  .hiw__step { max-width: 100%; width: 100%; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';
  const { data: { session } } = await supabase.auth.getSession();
  const btns = document.querySelectorAll('.auth-gate-hiw');
  btns.forEach(btn => {
    btn.setAttribute('href', session ? '/ThesisArcPro/contact/' : '/ThesisArcPro/login/');
  });
</script>