---
const base = '/ThesisArcPro';
---
<section class="hiw">
  <div class="container">
    <h2 class="hiw__title">How ThesisArcPro Works</h2>
    <p class="hiw__sub">Getting expert academic support has never been easier. Follow these simple steps and get your work done professionally.</p>

    <div class="hiw__inner">

      <!-- Left: 4 steps -->
      <div class="hiw__steps">

        <div class="hiw__step">
          <h3>1. Create your order (it's free)</h3>
          <p>Fill out our order form to be matched with the best writers</p>
          <a href="#" class="hiw__step-btn auth-gate">Place your order</a>
        </div>

        <div class="hiw__step">
          <h3>2. Choose a writer</h3>
          <p>Choose expert profiles, read reviews, and chat before you choose</p>
        </div>

        <div class="hiw__step">
          <h3>3. Make a payment</h3>
          <p>The deposit will stay on your balance until the order is ready</p>
        </div>

        <div class="hiw__step">
          <h3>4. Get your paper</h3>
          <p>our money stays in your account until you approve the result</p>
        </div>

      </div>

      <!-- Right: Promise card -->
      <div class="hiw__promise">
        <h3>Our Promise To You</h3>
        <ul>
          <li>✔ Original work every time</li>
          <li>✔ Expert qualified writers</li>
          <li>✔ On time delivery guaranteed</li>
          <li>✔ Free unlimited revisions</li>
          <li>✔ 24/7 customer support</li>
          <li>✔ Money back guarantee</li>
        </ul>
        <a href="#" class="hiw__promise-btn auth-gate">Order now</a>
      </div>

    </div>
  </div>
</section>

<style>
.hiw {
  background: var(--bg-body, #ffffff);
  padding: 3.5rem 0;
  border-top: 1px solid #eef2f7;
}
.hiw__title {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: clamp(1.3rem, 3vw, 1.6rem);
  font-weight: 700;
  color: var(--color-main, #303b4f);
  text-align: center;
  margin-bottom: 0.5rem;
}
.hiw__sub {
  text-align: center;
  color: var(--color-main-light, #6d7483);
  font-size: 0.9rem;
  max-width: 580px;
  margin: 0 auto 2.5rem;
  line-height: 1.6;
}

.hiw__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

/* ── Steps (left) ── */
.hiw__steps {
  display: flex;
  flex-direction: column;
  gap: 1.8rem;
}
.hiw__step h3 {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-main, #303b4f);
  margin-bottom: 0.3rem;
}
.hiw__step p {
  font-size: 0.88rem;
  color: var(--color-main-light, #6d7483);
  line-height: 1.6;
}
.hiw__step-btn {
  display: inline-block;
  background: var(--color-main, #303b4f);
  color: #ffffff;
  padding: 0.55rem 1.5rem;
  border-radius: 25px;
  font-size: 0.82rem;
  font-weight: 600;
  text-decoration: none;
  margin-top: 0.6rem;
  transition: all 0.2s;
}
.hiw__step-btn:hover {
  background: #1a2332;
  transform: translateY(-2px);
}

/* ── Promise card (right) ── */
.hiw__promise {
  background: var(--color-secondary, #046fcd);
  border-radius: 20px;
  padding: 2rem 2rem 1.8rem;
  color: #ffffff;
}
.hiw__promise h3 {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 1.2rem;
  text-align: center;
}
.hiw__promise ul {
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
}
.hiw__promise li {
  font-size: 0.92rem;
  font-weight: 600;
  color: #ffffff;
}
.hiw__promise-btn {
  display: block;
  background: #ffffff;
  color: var(--color-main, #303b4f);
  padding: 0.65rem 1.5rem;
  border-radius: 25px;
  font-size: 0.88rem;
  font-weight: 700;
  text-decoration: none;
  text-align: center;
  transition: all 0.2s;
  max-width: 180px;
  margin: 0 auto;
}
.hiw__promise-btn:hover {
  background: #f1f5f9;
  transform: translateY(-2px);
}

@media (max-width: 700px) {
  .hiw__inner { grid-template-columns: 1fr; gap: 2rem; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const { data: { session } } = await supabase.auth.getSession();
  document.querySelectorAll('.auth-gate').forEach(link => {
    if (session) {
      link.setAttribute('href', '/ThesisArcPro/contact/');
    } else {
      link.setAttribute('href', '/ThesisArcPro/login/');
    }
  });
</script>