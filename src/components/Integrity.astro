<style>
.integrity {
  padding: var(--section-padding);
  background-color: var(--navy);
  position: relative;
  overflow: hidden;
}

.integrity::before {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(197,160,89,0.06) 0%, transparent 70%);
  pointer-events: none;
}

.integrity__inner {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 5rem;
  align-items: center;
}

.integrity__eyebrow {
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.integrity h2 {
  color: var(--white);
  margin-bottom: 0.5rem;
}

.integrity__content > p {
  color: rgba(255,255,255,0.7);
  font-size: 0.95rem;
  line-height: 1.8;
  margin-bottom: 1rem;
}

.integrity__points {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin: 2rem 0;
}

.integrity__point {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.point__icon {
  font-size: 1.3rem;
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 0.2rem;
}

.point__text h4 {
  color: var(--white);
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
}

.point__text p {
  color: rgba(255,255,255,0.6);
  font-size: 0.85rem;
  line-height: 1.6;
}

.integrity__badge {
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.5rem;
}

.badge__icon {
  color: var(--gold);
  font-size: 2rem;
  margin-bottom: 1rem;
}

.integrity__badge h3 {
  color: var(--white);
  font-size: 1.3rem;
  margin-bottom: 1.5rem;
}

.integrity__badge ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.integrity__badge ul li {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  color: rgba(255,255,255,0.85);
  font-size: 0.95rem;
}

.check {
  color: var(--gold);
  font-weight: 700;
  font-size: 1rem;
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .integrity__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .integrity__points {
    grid-template-columns: 1fr;
  }
}
</style>