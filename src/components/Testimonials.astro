          <div class="author__avatar">DM</div>
          <div class="author__info">
            <span class="author__name">David M.</span>
            <span class="author__title">College Student, USIU Africa</span>
          </div>
        </div>
      </div>

    </div>

    <div class="testimonials__summary">
      <div class="summary__item">
        <span class="summary__number">4.9/5</span>
        <span class="summary__label">Average Rating</span>
      </div>
      <div class="summary__divider"></div>
      <div class="summary__item">
        <span class="summary__number">2,000+</span>
        <span class="summary__label">Happy Students</span>
      </div>
      <div class="summary__divider"></div>
      <div class="summary__item">
        <span class="summary__number">98%</span>
        <span class="summary__label">Would Recommend</span>
      </div>
    </div>

  </div>
</section>

<style>
.testimonials {
  padding: var(--section-padding);
  background-color: var(--off-white);
}

.testimonials__eyebrow {
  text-align: center;
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.testimonials__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.testimonial-card {
  background-color: var(--white);
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 12px;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
  transition: all 0.3s ease;
}

.testimonial-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(27,42,74,0.1);
  border-color: var(--gold);
}

.testimonial-card--featured {
  border-color: var(--gold);
  background: linear-gradient(135deg, var(--navy) 0%, #243558 100%);
}

.testimonial-card--featured .testimonial-card__stars {
  color: var(--gold);
}

.testimonial-card--featured .testimonial-card__text {
  color: rgba(255,255,255,0.85);
}

.testimonial-card--featured .author__name {
  color: var(--white);
}

.testimonial-card--featured .author__title {
  color: rgba(255,255,255,0.6);
}

.testimonial-card--featured .author__avatar {
  background-color: var(--gold);
  color: var(--navy);
}

.testimonial-card__stars {
  color: var(--gold);
  font-size: 1rem;
  letter-spacing: 2px;
}

.testimonial-card__text {
  color: var(--text-mid);
  font-size: 0.92rem;
  line-height: 1.8;
  flex: 1;
  font-style: italic;
}

.testimonial-card__author {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}

.author__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background-color: var(--navy);
  color: var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 700;
  flex-shrink: 0;
}

.author__info {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.author__name {
  color: var(--navy);
  font-weight: 600;
  font-size: 0.9rem;
}

.author__title {
  color: var(--text-light);
  font-size: 0.8rem;
}

.testimonials__summary {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 3rem;
  background-color: var(--navy);
  border-radius: 12px;
  padding: 2.5rem;
}

.summary__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.3rem;
}

.summary__number {
  color: var(--gold);
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
}

.summary__label {
  color: rgba(255,255,255,0.6);
  font-size: 0.85rem;
  letter-spacing: 0.5px;
}

.summary__divider {
  width: 1px;
  height: 50px;
  background-color: var(--border);
}

@media (max-width: 900px) {
  .testimonials__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 580px) {
  .testimonials__grid {
    grid-template-columns: 1fr;
  }
  .testimonials__summary {
    flex-direction: column;
    gap: 1.5rem;
  }
  .summary__divider {
    width: 60px;
    height: 1px;
  }
}
</style>