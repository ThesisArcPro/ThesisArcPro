---
const base = '/ThesisArcPro';
---
<section class="ws">
  <div class="ws__sep"></div>
  <div class="container">
    <h2 class="ws__title">Top essay writers ready to help you</h2>
    <p class="ws__sub">Hire qualified essay writer in your field and get 100% human-written papers</p>

    <div class="ws__grid" id="writersGrid">
      <div class="ws__loading">Loading writers...</div>
    </div>

    <div class="ws__actions">
      <a href={`${base}/writers`} class="ws__btn">Browse all writers</a>
      <p class="ws__note">⚠️ Qualified pros, ready to help</p>
    </div>
  </div>
</section>

<style is:global>
.ws {
  background: #f0f2fb;
  padding: 2rem 0 3.5rem;
}

.ws__sep {
  width: 100%;
  height: 3px;
  background: var(--color-primary, #C5A059);
  margin-bottom: 3rem;
}

.ws__title {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: clamp(1.3rem, 3vw, 1.6rem);
  font-weight: 700;
  color: var(--color-main, #303b4f);
  text-align: center;
  margin-bottom: 0.4rem;
}

.ws__sub {
  text-align: center;
  color: var(--color-main-light, #6d7483);
  font-size: 0.88rem;
  margin-bottom: 2.2rem;
}

.ws__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
  margin-bottom: 2rem;
}

.ws__loading {
  grid-column: 1 / -1;
  text-align: center;
  padding: 3rem;
  color: var(--color-main-light, #6d7483);
  font-size: 0.9rem;
}

/* ── Card: photo fills, details overlaid on dark gradient ── */
.ws__card {
  display: block;
  border-radius: 20px;
  overflow: hidden;
  background: var(--bg-card, #ffffff);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s, transform 0.2s;
  position: relative;
}
.ws__card:hover {
  box-shadow: var(--box-shadow-md, 0 4px 12px rgba(0,0,0,0.08));
  transform: translateY(-3px);
}

.ws__card-photo {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  display: block;
  border-radius: 20px;
}
.ws__card-placeholder {
  width: 100%;
  aspect-ratio: 3 / 4;
  background: #e8ecf0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  color: #c0c5cc;
  border-radius: 20px;
}

/* Dark gradient overlay at bottom of image */
.ws__card-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 3rem 0.9rem 0.9rem;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
  border-radius: 0 0 20px 20px;
}
.ws__card-name {
  font-weight: 700;
  font-size: 0.9rem;
  color: #ffffff;
  margin-bottom: 0.15rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ws__card-rating {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.82rem;
}
.ws__card-stars { color: #ffd20a; font-size: 0.85rem; }
.ws__card-score { font-weight: 700; color: #ffd20a; }
.ws__card-detail {
  font-size: 0.76rem;
  color: rgba(255,255,255,0.8);
}

/* ── Bottom actions ── */
.ws__actions {
  text-align: center;
}
.ws__btn {
  display: inline-block;
  background: var(--color-main, #303b4f);
  color: #ffffff;
  padding: 0.7rem 1.8rem;
  border-radius: 25px;
  font-size: 0.88rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
  margin-bottom: 0.7rem;
}
.ws__btn:hover {
  background: #1a2332;
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(48,59,79,0.3);
}
.ws__note {
  font-size: 0.8rem;
  color: var(--color-main-light, #6d7483);
}

@media (max-width: 900px) {
  .ws__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .ws__grid { grid-template-columns: 1fr 1fr; gap: 0.8rem; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  async function loadWriters() {
    const grid = document.getElementById('writersGrid');
    if (!grid) return;

    try {
      const { data: writers, error } = await supabase
        .from('writers')
        .select('*')
        .eq('is_active', true)
        .order('full_name')
        .limit(4);

      if (error) throw error;

      const { data: stats } = await supabase.rpc('writer_stats');
      const statsMap: Record<string, any> = {};
      if (Array.isArray(stats)) stats.forEach((s: any) => { statsMap[s.writer_id] = s; });

      // Sort by most completed orders first
      writers.sort((a: any, b: any) => {
        const aCount = statsMap[a.id]?.completed_orders || 0;
        const bCount = statsMap[b.id]?.completed_orders || 0;
        return bCount - aCount;
      });

      if (!writers || !writers.length) {
        grid.innerHTML = '<div class="ws__loading">Our writers are being onboarded — check back soon!</div>';
        return;
      }

      grid.innerHTML = writers.slice(0, 4).map((w: any) => {
        const s = statsMap[w.id] || {};
        const rating = s.avg_rating ? Number(s.avg_rating).toFixed(1) : null;
        const completed = s.completed_orders || 0;

        const photoHtml = w.photo_url
          ? `<img class="ws__card-photo" src="${w.photo_url}" alt="${esc(w.full_name || '')}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" /><div class="ws__card-placeholder" style="display:none;">👤</div>`
          : `<div class="ws__card-placeholder">👤</div>`;

        return `
          <a class="ws__card" href="/ThesisArcPro/writers/">
            ${photoHtml}
            <div class="ws__card-body">
              <div class="ws__card-name">
                ${esc(w.full_name || 'Writer')}
                ${rating
                  ? `<span class="ws__card-rating"><span class="ws__card-stars">★</span> <span class="ws__card-score">${rating}</span></span>`
                  : ''
                }
              </div>
              ${w.education_level ? `<div class="ws__card-detail">${esc(w.education_level)}</div>` : ''}
              <div class="ws__card-detail">Orders completed: <strong>${completed}</strong></div>
            </div>
          </a>
        `;
      }).join('');

    } catch (err) {
      console.error('Writers load error:', err);
      grid.innerHTML = '<div class="ws__loading">Could not load writers.</div>';
    }
  }

  loadWriters();
</script>