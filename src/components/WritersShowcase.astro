---
const base = '/ThesisArcPro';
---
<section class="ws">
  <div class="ws__sep"></div>
  <div class="container">
    <h2 class="ws__title">Top essay writers ready to help you</h2>
    <p class="ws__sub">Hire qualified essay writer in your field and get 100% human-written papers</p>

    <div class="ws__grid" id="writersGrid">
      <div class="ws__loading">Loading writers...</div>
    </div>

    <div class="ws__actions">
      <a href={`${base}/writers`} class="ws__btn">Browse all writers</a>
      <p class="ws__note">⚠️ Qualified pros, ready to help</p>
    </div>
  </div>
</section>

<style>
.ws {
  background: var(--bg-body, #ffffff);
  padding: 0 0 3.5rem;
}

/* Gold separator line at top */
.ws__sep {
  width: 100%;
  height: 3px;
  background: var(--color-primary, #C5A059);
  margin-bottom: 3rem;
}

.ws__title {
  font-family: var(--font-heading, 'Poppins', sans-serif);
  font-size: clamp(1.3rem, 3vw, 1.6rem);
  font-weight: 700;
  color: var(--color-main, #303b4f);
  text-align: center;
  margin-bottom: 0.4rem;
}

.ws__sub {
  text-align: center;
  color: var(--color-main-light, #6d7483);
  font-size: 0.88rem;
  margin-bottom: 2.2rem;
}

/* ── 4-card grid ── */
.ws__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
  margin-bottom: 2rem;
}

.ws__loading {
  grid-column: 1 / -1;
  text-align: center;
  padding: 3rem;
  color: var(--color-main-light, #6d7483);
  font-size: 0.9rem;
}

/* ── Writer card ── */
.ws__card {
  display: block;
  border-radius: var(--border-radius-primary, 16px);
  overflow: hidden;
  border: 1px solid var(--color-secondary-lightest, #eef6fb);
  background: var(--bg-card, #ffffff);
  text-decoration: none;
  color: inherit;
  transition: box-shadow 0.2s, transform 0.2s;
}
.ws__card:hover {
  box-shadow: var(--box-shadow-md, 0 4px 12px rgba(0,0,0,0.08));
  transform: translateY(-3px);
}

.ws__card-photo {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  background: #e8ecf0;
}
.ws__card-placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: #e8ecf0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  color: #c0c5cc;
}

.ws__card-body {
  padding: 0.75rem 0.9rem 0.9rem;
}
.ws__card-name {
  font-weight: 700;
  font-size: 0.88rem;
  color: var(--color-main, #303b4f);
  margin-bottom: 0.2rem;
}
.ws__card-rating {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.8rem;
  margin-bottom: 0.15rem;
}
.ws__card-stars { color: #fbbf24; }
.ws__card-score { font-weight: 600; color: var(--color-main, #303b4f); }
.ws__card-detail {
  font-size: 0.76rem;
  color: var(--color-main-light, #6d7483);
}

/* ── Bottom actions ── */
.ws__actions {
  text-align: center;
}
.ws__btn {
  display: inline-block;
  background: var(--color-main, #303b4f);
  color: #ffffff;
  padding: 0.7rem 1.8rem;
  border-radius: 25px;
  font-size: 0.88rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.25s ease;
  margin-bottom: 0.7rem;
}
.ws__btn:hover {
  background: #1a2332;
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(48,59,79,0.3);
}
.ws__note {
  font-size: 0.8rem;
  color: var(--color-main-light, #6d7483);
}

/* ── Mobile ── */
@media (max-width: 900px) {
  .ws__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .ws__grid { grid-template-columns: 1fr 1fr; gap: 0.8rem; }
}
</style>

<script>
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJlaHZ3dnVqdWFtZWhvYW5mb21qIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDY0NTMyNjcsImV4cCI6MjA2MjAyOTI2N30.sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  function esc(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  async function loadWriters() {
    const grid = document.getElementById('writersGrid');
    if (!grid) return;

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/writers?is_active=eq.true&order=full_name.asc&limit=4`,
        { headers: { 'apikey': SUPABASE_KEY } }
      );
      const writers = await res.json();

      const statsRes = await fetch(
        `${SUPABASE_URL}/rest/v1/rpc/writer_stats`,
        { method: 'POST', headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY }, body: '{}' }
      );
      const stats = await statsRes.json();
      const statsMap: Record<string, any> = {};
      if (Array.isArray(stats)) stats.forEach((s: any) => { statsMap[s.writer_id] = s; });

      if (!writers.length) {
        grid.innerHTML = '<div class="ws__loading">Our writers are being onboarded — check back soon!</div>';
        return;
      }

      const photoBase = `${SUPABASE_URL}/storage/v1/object/public/writer-photos/`;

      grid.innerHTML = writers.slice(0, 4).map((w: any) => {
        const s = statsMap[w.id] || {};
        const rating = s.avg_rating ? Number(s.avg_rating).toFixed(1) : null;
        const completed = s.completed_orders || 0;
        const stars = rating ? '★'.repeat(Math.round(Number(rating))) : '';

        const photoHtml = w.photo_url
          ? `<img class="ws__card-photo" src="${photoBase}${encodeURIComponent(w.photo_url)}" alt="${esc(w.full_name || '')}" loading="lazy" />`
          : `<div class="ws__card-placeholder">👤</div>`;

        return `
          <a class="ws__card" href="/ThesisArcPro/writers/">
            ${photoHtml}
            <div class="ws__card-body">
              <div class="ws__card-name">${esc(w.full_name || 'Writer')}</div>
              ${rating
                ? `<div class="ws__card-rating"><span class="ws__card-stars">${stars}</span> <span class="ws__card-score">${rating}</span></div>`
                : `<div class="ws__card-rating" style="color:var(--color-main-light)">New writer</div>`
              }
              ${w.education_level ? `<div class="ws__card-detail">${esc(w.education_level)}</div>` : ''}
              <div class="ws__card-detail">Orders: <strong>${completed}</strong></div>
            </div>
          </a>
        `;
      }).join('');

    } catch (err) {
      console.error('Writers load error:', err);
      grid.innerHTML = '<div class="ws__loading">Could not load writers.</div>';
    }
  }

  loadWriters();
</script>