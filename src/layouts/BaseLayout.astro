---
import '../styles/global.css';

const { 
  title = 'ThesisArcPro', 
  description = 'Expert academic writing and research support for high school, college, Masters and PhD students. Essays, dissertations, research papers, editing and more.',
  image = 'https://thesisarcpro.github.io/ThesisArcPro/og-image.jpg',
  url = 'https://thesisarcpro.github.io/ThesisArcPro/'
} = Astro.props;

const fullTitle = `${title} | ThesisArcPro — Expert Academic Writing Support`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ✅ Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="academic writing help, essay writing service, dissertation support, research paper writing, homework help, thesis writing, PhD support, assignment help, editing proofreading, academic research" />
    <meta name="author" content="ThesisArcPro" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={url} />

    <!-- ✅ Google Search Console Verification -->
    <meta name="google-site-verification" content="IJfGWYI6-9uB6Qk8JYUVYFJBTPkv3mbLwxRHC8qFhcI" />

    <!-- ✅ Open Graph (Facebook, WhatsApp, LinkedIn previews) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="ThesisArcPro" />
    <meta property="og:locale" content="en_US" />

    <!-- ✅ Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- ✅ Schema Markup -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "ThesisArcPro",
      "description": "Expert academic writing and research support for students at all levels",
      "url": "https://thesisarcpro.github.io/ThesisArcPro/",
      "logo": "https://thesisarcpro.github.io/ThesisArcPro/favicon.svg",
      "serviceType": [
        "Essay Writing",
        "Dissertation Support",
        "Research Paper Writing",
        "Editing and Proofreading",
        "Homework Help",
        "Research Consulting"
      ],
      "areaServed": "Worldwide",
      "priceRange": "$$",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "email": "thesisarcpro069@gmail.com",
        "availableLanguage": "English"
      },
      "sameAs": []
    }
    </script>

    <!-- ✅ Favicon -->
    <link rel="icon" type="image/svg+xml" href="/ThesisArcPro/favicon.svg" />
    <link rel="apple-touch-icon" href="/ThesisArcPro/favicon.svg" />
    <meta name="theme-color" content="#1B2A4A" />

  </head>
  <body>
    <slot />

    <!--Start of Tawk.to Script-->
    <script type="text/javascript">
    var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
    (function(){
    var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
    s1.async=true;
    s1.src='https://embed.tawk.to/6a1bdd1033b64c1c2ac90830/1jpudf2m0';
    s1.charset='UTF-8';
    s1.setAttribute('crossorigin','*');
    s0.parentNode.insertBefore(s1,s0);
    })();
    </script>
    <!--End of Tawk.to Script-->

  </body>
</html>