---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us" description="Learn about ThesisArcPro — our mission, our team, and our commitment to academic excellence.">
  <Header />

  <main>
    <!-- Page Hero -->
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__eyebrow">Our Story</p>
        <h1>About ThesisArcPro</h1>
        <p class="page-hero__sub">We are a team of academic experts, researchers, and writers dedicated to helping students achieve their full potential.</p>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="mission">
      <div class="container mission__inner">
        <div class="mission__content">
          <p class="mission__eyebrow">Our Mission</p>
          <h2>Empowering Every Student To Succeed</h2>
          <hr class="gold-line" style="margin: 1rem 0 1.5rem;" />
          <p>ThesisArcPro was founded with a single mission — to make high quality academic support accessible to every student, regardless of their level or background.</p>
          <p>We believe every student deserves access to expert guidance. Whether you are a high school student struggling with your first essay or a PhD candidate working on your dissertation — we are here to help you succeed.</p>
          <p>Our team of over 50 qualified academic experts brings decades of combined experience across all disciplines and academic levels.</p>
        </div>
        <div class="mission__stats">
          <div class="mission__stat">
            <span class="stat__number">2,000+</span>
            <span class="stat__label">Students Helped</span>
          </div>
          <div class="mission__stat">
            <span class="stat__number">50+</span>
            <span class="stat__label">Expert Writers</span>
          </div>
          <div class="mission__stat">
            <span class="stat__number">98%</span>
            <span class="stat__label">Satisfaction Rate</span>
          </div>
          <div class="mission__stat">
            <span class="stat__number">4.9/5</span>
            <span class="stat__label">Average Rating</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="values">
      <div class="container">
        <p class="values__eyebrow">What We Stand For</p>
        <h2 class="section-title">Our Core Values</h2>
        <hr class="gold-line" />
        <div class="values__grid">
          <div class="value-card">
            <div class="value-card__icon">🎯</div>
            <h3>Excellence</h3>
            <p>We hold ourselves to the highest academic standards. Every piece of work we produce reflects our commitment to quality and excellence.</p>
          </div>
          <div class="value-card">
            <div class="value-card__icon">🤝</div>
            <h3>Integrity</h3>
            <p>We operate with complete transparency and honesty. Our ethical commitment to responsible academic support is at the heart of everything we do.</p>
          </div>
          <div class="value-card">
            <div class="value-card__icon">🔒</div>
            <h3>Confidentiality</h3>
            <p>Your privacy is sacred to us. We never share your personal information or order details with any third party under any circumstances.</p>
          </div>
          <div class="value-card">
            <div class="value-card__icon">⚡</div>
            <h3>Reliability</h3>
            <p>We deliver on our promises every time. On time delivery, plagiarism free work, and unlimited revisions — guaranteed.</p>
          </div>
          <div class="value-card">
            <div class="value-card__icon">🌍</div>
            <h3>Accessibility</h3>
            <p>We believe quality academic support should be available to every student worldwide — not just those at elite institutions.</p>
          </div>
          <div class="value-card">
            <div class="value-card__icon">📈</div>
            <h3>Growth</h3>
            <p>We are committed to helping students not just complete assignments but to genuinely grow their academic skills and confidence.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="why-us">
      <div class="container why-us__inner">
        <div class="why-us__content">
          <p class="why-us__eyebrow">Why ThesisArcPro</p>
          <h2>What Makes Us Different</h2>
          <hr class="gold-line" style="margin: 1rem 0 1.5rem;" />
          <div class="why-us__points">
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>Qualified Academic Experts</h4>
                <p>All our writers hold Masters or PhD degrees in their respective fields.</p>
              </div>
            </div>
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>All Academic Levels</h4>
                <p>From high school to PhD — we support students at every academic level.</p>
              </div>
            </div>
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>Fast Turnaround</h4>
                <p>Urgent deadlines? We can deliver quality work in as little as 6 hours.</p>
              </div>
            </div>
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>Affordable Pricing</h4>
                <p>Premium quality at student-friendly prices with flexible payment options.</p>
              </div>
            </div>
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>24/7 Customer Support</h4>
                <p>Our support team is always available to assist you at any time of day.</p>
              </div>
            </div>
            <div class="why-point">
              <div class="why-point__icon">✓</div>
              <div>
                <h4>Money Back Guarantee</h4>
                <p>Not satisfied? We offer a full refund — no questions asked.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="why-us__visual">
          <div class="why-us__card">
            <div class="card__icon">✦</div>
            <h3>Start Your Journey Today</h3>
            <p>Join over 2,000 students who have achieved academic success with ThesisArcPro.</p>
            <a href="/contact" class="btn-primary" style="width:100%; text-align:center; margin-top:1rem;">
              Book Free Consultation
            </a>
            <a href="/services" class="btn-outline-gold" style="width:100%; text-align:center; margin-top:0.8rem;">
              View Our Services
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.page-hero {
  background-color: var(--navy);
  padding: 10rem 0 5rem;
  text-align: center;
}

.page-hero__eyebrow {
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.page-hero h1 { color: var(--white); margin-bottom: 1.5rem; }

.page-hero__sub {
  color: rgba(255,255,255,0.7);
  font-size: 1.1rem;
  max-width: 600px;
  margin: 0 auto;
}

.mission {
  padding: var(--section-padding);
  background-color: var(--white);
}

.mission__inner {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 5rem;
  align-items: center;
}

.mission__eyebrow {
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.mission__content h2 { color: var(--navy); margin-bottom: 0.5rem; }

.mission__content p {
  color: var(--text-mid);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.mission__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  background-color: var(--navy);
  border-radius: 16px;
  padding: 2.5rem;
}

.mission__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 0.3rem;
}

.stat__number {
  color: var(--gold);
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
}

.stat__label {
  color: rgba(255,255,255,0.6);
  font-size: 0.85rem;
}

.values {
  padding: var(--section-padding);
  background-color: var(--off-white);
}

.values__eyebrow {
  text-align: center;
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.values__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.value-card {
  background-color: var(--white);
  border: 1px solid rgba(0,0,0,0.06);
  border-radius: 12px;
  padding: 2rem;
  transition: all 0.3s ease;
}

.value-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(27,42,74,0.1);
  border-color: var(--gold);
}

.value-card__icon { font-size: 2rem; margin-bottom: 1rem; }
.value-card h3 { color: var(--navy); font-size: 1.1rem; margin-bottom: 0.8rem; }
.value-card p { color: var(--text-mid); font-size: 0.9rem; line-height: 1.7; }

.why-us {
  padding: var(--section-padding);
  background-color: var(--navy);
}

.why-us__inner {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 5rem;
  align-items: center;
}

.why-us__eyebrow {
  color: var(--gold);
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 1rem;
}

.why-us__content h2 { color: var(--white); margin-bottom: 0.5rem; }

.why-us__points {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-top: 1rem;
}

.why-point {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}

.why-point__icon {
  color: var(--gold);
  font-weight: 700;
  font-size: 1.1rem;
  flex-shrink: 0;
  margin-top: 0.2rem;
}

.why-point h4 {
  color: var(--white);
  font-family: var(--font-body);
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
}

.why-point p {
  color: rgba(255,255,255,0.6);
  font-size: 0.85rem;
  line-height: 1.6;
}

.why-us__card {
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 2.5rem;
}

.why-us__card .card__icon {
  color: var(--gold);
  font-size: 2rem;
  margin-bottom: 1rem;
}

.why-us__card h3 { color: var(--white); font-size: 1.3rem; margin-bottom: 1rem; }
.why-us__card p { color: rgba(255,255,255,0.65); font-size: 0.95rem; line-height: 1.7; }

.btn-outline-gold {
  display: inline-block;
  background-color: transparent;
  color: var(--gold);
  padding: 0.85rem 2rem;
  border-radius: 4px;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 0.95rem;
  border: 2px solid var(--gold);
  transition: all 0.3s ease;
}

.btn-outline-gold:hover {
  background-color: var(--gold);
  color: var(--navy);
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .mission__inner,
  .why-us__inner {
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .values__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .values__grid {
    grid-template-columns: 1fr;
  }
}
</style>