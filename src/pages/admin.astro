---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="Admin Dashboard" description="ThesisArcPro Admin">

  <main>
    <section class="admin">
      <div class="container">

        <div class="admin__header">
          <div>
            <h1>Admin Dashboard</h1>
            <p id="statsText">Loading orders...</p>
          </div>
          <button id="logoutBtn" class="btn-logout">Log Out</button>
        </div>

        <!-- Stat tiles -->
        <div class="stat-tiles">
          <div class="stat-tile">
            <div class="stat-label">Total</div>
            <div class="stat-value" id="statTotal">0</div>
          </div>
          <div class="stat-tile">
            <div class="stat-label">New</div>
            <div class="stat-value stat-new" id="statNew">0</div>
          </div>
          <div class="stat-tile">
            <div class="stat-label">In Progress</div>
            <div class="stat-value stat-progress" id="statProgress">0</div>
          </div>
          <div class="stat-tile">
            <div class="stat-label">Collected</div>
            <div class="stat-value stat-money" id="statCollected">$0</div>
          </div>
        </div>

        <div class="controls-row">
          <div class="admin__tabs">
            <button class="tab active" data-tab="all">All Orders</button>
            <button class="tab" data-tab="new">New</button>
            <button class="tab" data-tab="in_progress">In Progress</button>
            <button class="tab" data-tab="in_review">In Review</button>
            <button class="tab" data-tab="revision">In Revision</button>
            <button class="tab" data-tab="completed">Completed</button>
            <button class="tab" data-tab="cancelled">Cancelled</button>
          </div>
          <div class="search-wrap">
            <span class="search-icon">🔍</span>
            <input class="search-input" type="text" id="searchInput" placeholder="Search topic, email, ticket" />
          </div>
        </div>

        <div id="loadingState" class="loading-state">
          <div class="spinner"></div>
          <p>Loading orders...</p>
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <div class="empty-icon">📋</div>
          <h3>No orders match this view</h3>
        </div>

        <div id="ordersGrid" class="orders-grid" style="display:none;"></div>

      </div>
    </section>
  </main>

  <!-- Update Status Modal -->
  <div class="modal-overlay" id="updateModal">
    <div class="modal-card">
      <button class="modal-close" id="modalClose">✕</button>
      <h2>Update Order</h2>
      <p id="modalOrderNum" class="modal-order-num"></p>
      <p id="modalClientEmail" class="modal-client-email"></p>

      <div class="form-group">
        <label>Order Status</label>
        <select id="statusSelect">
          <option value="new">🆕 New</option>
          <option value="in_progress">⚙️ In Progress</option>
          <option value="in_review">🔍 In Review</option>
          <option value="completed">✅ Completed</option>
          <option value="revision">🔄 Revision</option>
          <option value="cancelled">❌ Cancelled</option>
        </select>
      </div>

      <div class="form-group">
        <label>Completed File</label>
        <div class="current-file" id="currentFile" style="display:none;">
          <span id="currentFileName">📎 A file is already attached</span>
        </div>
        <input type="file" id="fileInput" accept=".pdf,.doc,.docx,.txt,.zip,.ppt,.pptx,.xls,.xlsx" />
        <span class="input-note">Choose the completed file to deliver to the client. Leave empty to keep the current file.</span>
        <div class="upload-progress" id="uploadProgress" style="display:none;">⏳ Uploading file…</div>
      </div>

      <button class="btn-update" id="saveUpdateBtn">💾 Save Changes</button>
    </div>
  </div>

</BaseLayout>

<style>
.admin { background: var(--navy); min-height: 100vh; padding: 8rem 0 4rem; }
.admin__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
.admin__header h1 { color: var(--white); font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 0.3rem; }
.admin__header p { color: rgba(255,255,255,0.6); font-size: 0.95rem; }
.btn-logout { background: none; border: 1.5px solid rgba(255,255,255,0.3); color: white; padding: 0.6rem 1.2rem; border-radius: 4px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.btn-logout:hover { background: rgba(255,255,255,0.1); }

/* Stat tiles */
.stat-tiles { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 2rem; }
.stat-tile { background: #141e35; border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 1rem 1.2rem; }
.stat-label { color: rgba(255,255,255,0.45); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; }
.stat-value { color: #f1f5f9; font-size: 1.7rem; font-weight: 800; margin-top: 0.3rem; }
.stat-value.stat-new { color: #818cf8; }
.stat-value.stat-progress { color: #fbbf24; }
.stat-value.stat-money { color: #4ade80; }
@media (max-width: 768px) { .stat-tiles { grid-template-columns: repeat(2, 1fr); } }

.controls-row { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem; }
.admin__tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.tab { background: none; border: none; color: rgba(255,255,255,0.5); padding: 0.5rem 1.2rem; border-radius: 20px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.tab.active { background: var(--gold); color: var(--navy); }
.tab:hover:not(.active) { color: white; }

.search-wrap { position: relative; width: 260px; max-width: 100%; }
.search-icon { position: absolute; left: 0.7rem; top: 50%; transform: translateY(-50%); font-size: 0.85rem; color: rgba(255,255,255,0.4); }
.search-input { width: 100%; background: #1e293b; border: 1px solid rgba(255,255,255,0.12); color: #f1f5f9; border-radius: 6px; padding: 0.5rem 0.8rem 0.5rem 2rem; font-size: 0.85rem; outline: none; transition: 0.2s; }
.search-input:focus { border-color: var(--gold); }
.search-input::placeholder { color: rgba(255,255,255,0.4); }

.loading-state { text-align: center; padding: 4rem; color: rgba(255,255,255,0.5); }
.spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 4rem; background: rgba(255,255,255,0.05); border-radius: 16px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h3 { color: white; }

/* Modal */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 20000; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal-card { background: white; border-radius: 16px; padding: 2rem; max-width: 480px; width: 90%; position: relative; }
.modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-mid); }
.modal-card h2 { color: var(--navy); margin-bottom: 0.3rem; }
.modal-order-num { color: var(--gold); font-weight: 700; margin-bottom: 0.2rem; }
.modal-client-email { color: var(--text-mid); font-size: 0.85rem; margin-bottom: 1.5rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.2rem; }
.form-group label { color: var(--navy); font-weight: 600; font-size: 0.9rem; }
.form-group select, .form-group input { padding: 0.85rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 6px; font-size: 0.95rem; outline: none; }
.form-group select:focus, .form-group input:focus { border-color: var(--gold); }
.form-group input[type="file"] { padding: 0.6rem; background: var(--off-white); cursor: pointer; }
.current-file { background: #e8f5e9; color: #2e7d32; padding: 0.6rem 0.8rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; }
.upload-progress { color: var(--navy); font-size: 0.85rem; font-weight: 600; }
.input-note { color: var(--text-light); font-size: 0.76rem; }
.btn-update { width: 100%; padding: 1rem; background: var(--navy); color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.3s ease; }
.btn-update:hover { background: var(--gold); color: var(--navy); }
.btn-update:disabled { opacity: 0.6; cursor: not-allowed; }
</style>

<style is:global>
  /* Order cards are injected via innerHTML, so these must be global and use
     explicit colors (CSS variables don't resolve in injected content). */
  .orders-grid { display: flex; flex-direction: column; gap: 0.7rem; }

  .order-card {
    background: #141e35;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 1rem 1.3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: all 0.18s ease;
  }
  .order-card:hover { border-color: rgba(197,160,89,0.55); background: #1a2540; }

  .order-card__left { flex: 1; min-width: 0; }
  .order-card__title { color: #f1f5f9; font-weight: 700; font-size: 0.93rem; margin-bottom: 0.15rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .order-card__email { color: #c5a059; font-size: 0.8rem; margin-bottom: 0.4rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .order-card__meta { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
  .meta-dot { color: rgba(255,255,255,0.2); }
  .meta-item { color: rgba(255,255,255,0.55); font-size: 0.78rem; }

  .order-card__right { display: flex; align-items: center; gap: 1.4rem; flex-shrink: 0; }
  .order-card__deadline { font-size: 0.82rem; font-weight: 600; white-space: nowrap; }
  .order-card__deadline.ok { color: #34d399; }
  .order-card__deadline.urgent { color: #fb923c; }
  .order-card__deadline.overdue { color: #f87171; }
  .order-card__deadline.none { color: rgba(255,255,255,0.4); }
  .order-card__amount { color: #f1f5f9; font-weight: 700; font-size: 0.92rem; white-space: nowrap; }
  .amount-paid { color: rgba(255,255,255,0.4); font-weight: 400; font-size: 0.8rem; }

  .status-badge { padding: 0.18rem 0.55rem; border-radius: 4px; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }
  .status-new { background: rgba(99,102,241,0.18); color: #818cf8; }
  .status-in_progress { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .status-in_review { background: rgba(56,138,221,0.18); color: #60a5fa; }
  .status-completed { background: rgba(34,197,94,0.15); color: #4ade80; }
  .status-revision { background: rgba(168,85,247,0.18); color: #c084fc; }
  .status-cancelled { background: rgba(239,68,68,0.16); color: #f87171; }

  .btn-update-order { background: #c5a059; color: #0f172a; border: none; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s ease; white-space: nowrap; }
  .btn-update-order:hover { background: #f1f5f9; }

  @media (max-width: 768px) {
    .order-card { flex-direction: column; align-items: flex-start; }
    .order-card__right { width: 100%; justify-content: space-between; }
  }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
  const BUCKET = 'completed-files';

  let allOrders: any[] = [];
  let currentOrder: any = null;
  let currentSession: any = null;
  let currentTab = 'all';

  // ── TEMPORARY DEBUG HELPERS (remove once the mobile loading issue is fixed) ──
  function setStatus(text: string) {
    const p = document.querySelector('#loadingState p');
    if (p) p.textContent = text;
  }

  function showDebugError(err: any) {
    console.error(err);
    const loading = document.getElementById('loadingState');
    if (loading) {
      loading.innerHTML = `
        <div style="max-width:480px;text-align:left;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:1rem;color:#f87171;font-size:0.78rem;font-family:monospace;white-space:pre-wrap;word-break:break-word;margin:0 auto;">
⚠️ Debug error:
${String(err?.message || err)}
        </div>`;
    }
  }

  function withTimeout<T>(promise: Promise<T>, ms: number, label: string): Promise<T> {
    return Promise.race([
      promise,
      new Promise<T>((_, reject) =>
        setTimeout(() => reject(new Error(`${label} timed out after ${ms / 1000}s — likely a hang, not a thrown error`)), ms)
      )
    ]);
  }

  window.addEventListener('error', (e) => showDebugError((e as ErrorEvent).error || (e as ErrorEvent).message));
  window.addEventListener('unhandledrejection', (e) => showDebugError((e as PromiseRejectionEvent).reason));
  // ── END DEBUG HELPERS ──

  async function checkAuth() {
    try {
      setStatus('Checking your login…');
      const { data: { session } } = await withTimeout(supabase.auth.getSession(), 10000, 'Session check');
      if (!session) {
        window.location.replace(`${base}/login/`);
        return;
      }
      currentSession = session;

      setStatus('Verifying admin access…');
      const res = await withTimeout(
        fetch(
          `${SUPABASE_URL}/rest/v1/profiles?email=eq.${encodeURIComponent(session.user.email)}&select=is_admin`,
          {
            headers: {
              'apikey': SUPABASE_KEY,
              'Authorization': `Bearer ${session.access_token}`
            }
          }
        ),
        10000,
        'Admin check'
      );
      if (!res.ok) {
        const text = await res.text();
        throw new Error(`Admin check failed (${res.status}): ${text}`);
      }
      const data = await res.json();

      if (!data[0]?.is_admin) {
        window.location.replace(`${base}/dashboard/`);
        return;
      }

      setStatus('Loading orders…');
      await loadOrders();
    } catch (err) {
      showDebugError(err);
    }
  }

  async function loadOrders() {
    try {
      const res = await withTimeout(
        fetch(
          `${SUPABASE_URL}/rest/v1/orders?order=created_at.desc`,
          {
            headers: {
              'apikey': SUPABASE_KEY,
              'Authorization': `Bearer ${currentSession.access_token}`
            }
          }
        ),
        10000,
        'Orders fetch'
      );
      if (!res.ok) {
        const text = await res.text();
        throw new Error(`Orders request failed (${res.status}): ${text}`);
      }
      allOrders = await res.json();
      updateStats();
      renderOrders();
    } catch (err) {
      showDebugError(err);
    }
  }

  function updateStats() {
    const total = allOrders.length;
    const newOrders = allOrders.filter(o => o.order_status === 'new').length;
    const inProgress = allOrders.filter(o => o.order_status === 'in_progress').length;
    const collected = allOrders.reduce((sum, o) => sum + Number(o.amount_paid || 0), 0);

    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set('statTotal', String(total));
    set('statNew', String(newOrders));
    set('statProgress', String(inProgress));
    set('statCollected', '$' + collected.toFixed(0));

    const statsText = document.getElementById('statsText');
    if (statsText) statsText.textContent = `${total} orders · managing all clients`;
  }

  // Escape values before injecting into innerHTML
  function esc(v: any) {
    return String(v ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function getStatusBadge(status: string) {
    const labels: Record<string, string> = {
      'new': '🆕 New',
      'in_progress': '⚙️ In Progress',
      'in_review': '🔍 In Review',
      'completed': '✅ Completed',
      'revision': '🔄 Revision',
      'cancelled': '❌ Cancelled',
    };
    const cls = ['new','in_progress','in_review','completed','revision','cancelled'].includes(status) ? status : 'new';
    const label = labels[status] || status;
    return `<span class="status-badge status-${cls}">${esc(label)}</span>`;
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: 'none' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: '⚠️ Overdue', cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');
    const search = (document.getElementById('searchInput') as HTMLInputElement)?.value.toLowerCase() || '';

    if (loading) loading.style.display = 'none';

    let filtered = currentTab === 'all'
      ? allOrders
      : allOrders.filter(o => o.order_status === currentTab);

    if (search) {
      filtered = filtered.filter(o =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.client_email || '').toLowerCase().includes(search) ||
        (o.order_number || '').toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'flex';
      grid.innerHTML = filtered.map(order => {
        const dl = deadlineInfo(order.deadline);
        return `
        <div class="order-card">
          <div class="order-card__left">
            <div class="order-card__title">${esc(order.topic || 'N/A')}</div>
            <div class="order-card__email">${esc(order.order_number || order.id)}</div>
            <div class="order-card__meta">
              ${getStatusBadge(order.order_status || 'new')}
              <span class="meta-dot">·</span>
              <span class="meta-item">${esc(order.pages || 1)} pages</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">${esc(order.assignment_type || 'N/A')}</span>
            </div>
          </div>
          <div class="order-card__right">
            <div class="order-card__deadline ${dl.cls}">${dl.text}</div>
            <div class="order-card__amount">$${Number(order.total_amount || 0).toFixed(2)} <span class="amount-paid">($${Number(order.amount_paid || 0).toFixed(2)})</span></div>
            <button class="btn-update-order" data-id="${esc(order.id)}">✏️ Update</button>
          </div>
        </div>
      `;
      }).join('');

      // Attach click listeners (safer than inline onclick with quoted values)
      grid.querySelectorAll('.btn-update-order').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id;
          const order = allOrders.find(o => String(o.id) === id);
          if (order) openUpdateModal(order);
        });
      });
    }
  }

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'all';
      renderOrders();
    });
  });

  // Search
  document.getElementById('searchInput')?.addEventListener('input', renderOrders);

  // Open update modal
  function openUpdateModal(order: any) {
    currentOrder = order;
    const modal = document.getElementById('updateModal');
    const modalOrderNum = document.getElementById('modalOrderNum');
    const statusSelect = document.getElementById('statusSelect') as HTMLSelectElement;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const currentFile = document.getElementById('currentFile');
    const currentFileName = document.getElementById('currentFileName');

    if (modalOrderNum) modalOrderNum.textContent = `Order ${order.order_number || order.id}`;
    const modalClientEmail = document.getElementById('modalClientEmail');
    if (modalClientEmail) modalClientEmail.textContent = order.client_email || '';
    if (statusSelect) statusSelect.value = order.order_status || 'new';
    if (fileInput) fileInput.value = '';

    // Show whether a file is already attached
    if (currentFile && currentFileName) {
      if (order.file_url) {
        const parts = String(order.file_url).split('/');
        currentFileName.textContent = '📎 Attached: ' + parts[parts.length - 1];
        currentFile.style.display = 'block';
      } else {
        currentFile.style.display = 'none';
      }
    }

    modal?.classList.add('active');
  }

  // Close modal
  document.getElementById('modalClose')?.addEventListener('click', () => {
    document.getElementById('updateModal')?.classList.remove('active');
  });

  // Save update — uploads file to Storage if one is chosen
  document.getElementById('saveUpdateBtn')?.addEventListener('click', async () => {
    if (!currentOrder) return;
    const status = (document.getElementById('statusSelect') as HTMLSelectElement).value;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const btn = document.getElementById('saveUpdateBtn') as HTMLButtonElement;
    const progress = document.getElementById('uploadProgress');

    btn.disabled = true;

    // Keep existing file path unless a new file is uploaded
    let filePath = currentOrder.file_url || null;

    try {
      const file = fileInput.files && fileInput.files[0];
      if (file) {
        if (progress) progress.style.display = 'block';
        btn.textContent = '⏳ Uploading…';

        const ticket = currentOrder.order_number || String(currentOrder.id);
        // Sanitize the filename and store under the ticket folder
        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
        const path = `${ticket}/${safeName}`;

        const { error: uploadError } = await supabase
          .storage
          .from(BUCKET)
          .upload(path, file, { upsert: true });

        if (uploadError) throw uploadError;
        filePath = path;
        if (progress) progress.style.display = 'none';
      }

      btn.textContent = '⏳ Saving…';

      await fetch(`${SUPABASE_URL}/rest/v1/orders?id=eq.${currentOrder.id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${currentSession.access_token}`
        },
        body: JSON.stringify({
          order_status: status,
          file_url: filePath,
          status_updated_at: new Date().toISOString()
        })
      });

      document.getElementById('updateModal')?.classList.remove('active');
      btn.textContent = '💾 Save Changes';
      btn.disabled = false;
      await loadOrders();

    } catch (err) {
      console.error(err);
      if (progress) progress.style.display = 'none';
      btn.textContent = '❌ Upload failed — try again';
      btn.disabled = false;
    }
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  checkAuth();
</script>
