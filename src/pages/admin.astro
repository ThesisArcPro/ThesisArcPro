---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="Admin Dashboard" description="ThesisArcPro Admin">
  <Header />

  <main>
    <section class="admin">
      <div class="container">

        <div class="admin__header">
          <div>
            <h1>Admin Dashboard</h1>
            <p id="statsText">Loading orders...</p>
          </div>
          <button id="logoutBtn" class="btn-logout">Log Out</button>
        </div>

        <div class="admin__tabs">
          <button class="tab active" data-tab="all">All Orders</button>
          <button class="tab" data-tab="new">New</button>
          <button class="tab" data-tab="in_progress">In Progress</button>
          <button class="tab" data-tab="completed">Completed</button>
        </div>

        <div id="loadingState" class="loading-state">
          <div class="spinner"></div>
          <p>Loading orders...</p>
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <div class="empty-icon">📋</div>
          <h3>No orders yet</h3>
        </div>

        <div id="ordersGrid" class="orders-grid" style="display:none;"></div>

      </div>
    </section>
  </main>

  <!-- Update Status Modal -->
  <div class="modal-overlay" id="updateModal">
    <div class="modal-card">
      <button class="modal-close" id="modalClose">✕</button>
      <h2>Update Order</h2>
      <p id="modalOrderNum" class="modal-order-num"></p>

      <div class="form-group">
        <label>Order Status</label>
        <select id="statusSelect">
          <option value="new">🆕 New</option>
          <option value="in_progress">⚙️ In Progress</option>
          <option value="completed">✅ Completed</option>
          <option value="revision">🔄 Revision</option>
          <option value="cancelled">❌ Cancelled</option>
        </select>
      </div>

      <div class="form-group">
        <label>Completed File URL (Google Drive link)</label>
        <input type="text" id="fileUrl" placeholder="https://drive.google.com/..." />
        <span class="input-note">Paste shareable Google Drive link here</span>
      </div>

      <button class="btn-update" id="saveUpdateBtn">💾 Save Changes</button>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
.admin { background: var(--navy); min-height: 100vh; padding: 8rem 0 4rem; }
.admin__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.admin__header h1 { color: var(--white); font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 0.3rem; }
.admin__header p { color: rgba(255,255,255,0.6); font-size: 0.95rem; }
.btn-logout { background: none; border: 1.5px solid rgba(255,255,255,0.3); color: white; padding: 0.6rem 1.2rem; border-radius: 4px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.btn-logout:hover { background: rgba(255,255,255,0.1); }
.admin__tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem; }
.tab { background: none; border: none; color: rgba(255,255,255,0.5); padding: 0.5rem 1.2rem; border-radius: 20px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.tab.active { background: var(--gold); color: var(--navy); }
.tab:hover:not(.active) { color: white; }
.loading-state { text-align: center; padding: 4rem; color: rgba(255,255,255,0.5); }
.spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 4rem; background: rgba(255,255,255,0.05); border-radius: 16px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h3 { color: white; }
.orders-grid { display: flex; flex-direction: column; gap: 0.8rem; }
.order-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 1.2rem 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; transition: all 0.2s ease; }
.order-card:hover { border-color: var(--gold); background: rgba(255,255,255,0.08); }
.order-card__left { flex: 1; min-width: 0; }
.order-card__title { color: white; font-weight: 700; font-size: 0.95rem; margin-bottom: 0.2rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.order-card__email { color: var(--gold); font-size: 0.82rem; margin-bottom: 0.4rem; }
.order-card__meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; }
.meta-dot { color: rgba(255,255,255,0.3); }
.meta-item { color: rgba(255,255,255,0.5); font-size: 0.82rem; }
.order-card__right { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
.order-card__deadline { color: var(--gold); font-size: 0.85rem; font-weight: 600; white-space: nowrap; }
.order-card__amount { color: white; font-weight: 700; font-size: 0.95rem; white-space: nowrap; }
.amount-paid { color: rgba(255,255,255,0.4); font-weight: 400; font-size: 0.82rem; }
.status-badge { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; }
.status-new { background: rgba(21,101,192,0.2); color: #90caf9; }
.status-in_progress { background: rgba(230,81,0,0.2); color: #ffcc80; }
.status-completed { background: rgba(46,125,50,0.2); color: #a5d6a7; }
.status-revision { background: rgba(156,39,176,0.2); color: #ce93d8; }
.status-cancelled { background: rgba(211,47,47,0.2); color: #ef9a9a; }
.btn-update-order { background: var(--gold); color: var(--navy); border: none; padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.82rem; font-weight: 700; cursor: pointer; transition: all 0.2s ease; white-space: nowrap; }
.btn-update-order:hover { background: white; }

/* Modal */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 20000; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal-card { background: white; border-radius: 16px; padding: 2rem; max-width: 480px; width: 90%; position: relative; }
.modal-close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-mid); }
.modal-card h2 { color: var(--navy); margin-bottom: 0.3rem; }
.modal-order-num { color: var(--gold); font-weight: 700; margin-bottom: 1.5rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.2rem; }
.form-group label { color: var(--navy); font-weight: 600; font-size: 0.9rem; }
.form-group select, .form-group input { padding: 0.85rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 6px; font-size: 0.95rem; outline: none; }
.form-group select:focus, .form-group input:focus { border-color: var(--gold); }
.input-note { color: var(--text-light); font-size: 0.76rem; }
.btn-update { width: 100%; padding: 1rem; background: var(--navy); color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.3s ease; }
.btn-update:hover { background: var(--gold); color: var(--navy); }
@media (max-width: 768px) { .order-card { flex-direction: column; align-items: flex-start; } .order-card__right { width: 100%; justify-content: space-between; } }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentOrderId: string = '';
  let currentSession: any = null;

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.replace(`${base}/login/`);
      return;
    }
    currentSession = session;

    // Check if admin
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/profiles?email=eq.${session.user.email}&select=is_admin`,
      {
        headers: {
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${session.access_token}`
        }
      }
    );
    const data = await res.json();

    if (!data[0]?.is_admin) {
      window.location.replace(`${base}/dashboard/`);
      return;
    }

    await loadOrders();
  }

  async function loadOrders() {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?order=created_at.desc`,
        {
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${currentSession.access_token}`
          }
        }
      );
      allOrders = await res.json();

      const statsText = document.getElementById('statsText');
      if (statsText) {
        const total = allOrders.length;
        const newOrders = allOrders.filter(o => o.order_status === 'new').length;
        const inProgress = allOrders.filter(o => o.order_status === 'in_progress').length;
        statsText.textContent = `${total} total orders · ${newOrders} new · ${inProgress} in progress`;
      }

      renderOrders(allOrders);
    } catch (err) {
      console.error('Error:', err);
    }
  }

  function getStatusBadge(status: string) {
    const map: Record<string, string> = {
      'new': '<span class="status-badge status-new">🆕 New</span>',
      'in_progress': '<span class="status-badge status-in_progress">⚙️ In Progress</span>',
      'completed': '<span class="status-badge status-completed">✅ Completed</span>',
      'revision': '<span class="status-badge status-revision">🔄 Revision</span>',
      'cancelled': '<span class="status-badge status-cancelled">❌ Cancelled</span>',
    };
    return map[status] || `<span class="status-badge status-new">${status}</span>`;
  }

  function timeLeft(deadline: string) {
    if (!deadline) return 'No deadline';
    const diff = new Date(deadline).getTime() - new Date().getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    if (diff < 0) return '⚠️ Overdue';
    if (days > 0) return `⏰ ${days}d left`;
    return `⏰ ${hours}h left`;
  }

  function renderOrders(orders: any[]) {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');

    if (loading) loading.style.display = 'none';

    if (!orders || orders.length === 0) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'flex';
      grid.innerHTML = orders.map(order => `
        <div class="order-card">
          <div class="order-card__left">
            <div class="order-card__title">${order.topic || 'N/A'}</div>
            <div class="order-card__email">${order.client_email || ''}</div>
            <div class="order-card__meta">
              ${getStatusBadge(order.order_status || 'new')}
              <span class="meta-dot">·</span>
              <span class="meta-item">${order.order_number}</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">${order.pages || 1} pages</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">${order.assignment_type || 'N/A'}</span>
            </div>
          </div>
          <div class="order-card__right">
            <div class="order-card__deadline">${timeLeft(order.deadline)}</div>
            <div class="order-card__amount">$${Number(order.total_amount || 0).toFixed(2)} <span class="amount-paid">($${Number(order.amount_paid || 0).toFixed(2)})</span></div>
            <button class="btn-update-order" onclick="openUpdateModal('${order.id}', '${order.order_number}', '${order.order_status}', '${order.file_url || ''}')">
              ✏️ Update
            </button>
          </div>
        </div>
      `).join('');
    }
  }

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const currentTab = (tab as HTMLElement).dataset.tab || 'all';
      const filtered = currentTab === 'all'
        ? allOrders
        : allOrders.filter(o => o.order_status === currentTab);
      renderOrders(filtered);
    });
  });

  // Open update modal
  function openUpdateModal(id: string, orderNum: string, status: string, fileUrl: string) {
    currentOrderId = id;
    const modal = document.getElementById('updateModal');
    const modalOrderNum = document.getElementById('modalOrderNum');
    const statusSelect = document.getElementById('statusSelect') as HTMLSelectElement;
    const fileUrlInput = document.getElementById('fileUrl') as HTMLInputElement;

    if (modalOrderNum) modalOrderNum.textContent = `Order ${orderNum}`;
    if (statusSelect) statusSelect.value = status;
    if (fileUrlInput) fileUrlInput.value = fileUrl;
    modal?.classList.add('active');
  }

  // Close modal
  document.getElementById('modalClose')?.addEventListener('click', () => {
    document.getElementById('updateModal')?.classList.remove('active');
  });

  // Save update
  document.getElementById('saveUpdateBtn')?.addEventListener('click', async () => {
    const status = (document.getElementById('statusSelect') as HTMLSelectElement).value;
    const fileUrl = (document.getElementById('fileUrl') as HTMLInputElement).value.trim();
    const btn = document.getElementById('saveUpdateBtn') as HTMLButtonElement;

    btn.textContent = '⏳ Saving...';
    btn.disabled = true;

    try {
      await fetch(`${SUPABASE_URL}/rest/v1/orders?id=eq.${currentOrderId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${currentSession.access_token}`
        },
        body: JSON.stringify({
          order_status: status,
          file_url: fileUrl || null,
          status_updated_at: new Date().toISOString()
        })
      });

      document.getElementById('updateModal')?.classList.remove('active');
      btn.textContent = '💾 Save Changes';
      btn.disabled = false;
      await loadOrders();

    } catch (err) {
      btn.textContent = '❌ Error — try again';
      btn.disabled = false;
    }
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  (window as any).openUpdateModal = openUpdateModal;

  checkAuth();
</script>