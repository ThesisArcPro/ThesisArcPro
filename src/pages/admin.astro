<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
  const BUCKET = 'completed-files';

  let allOrders: any[] = [];
  let allWriters: any[] = [];
  let currentOrder: any = null;
  let currentSession: any = null;
  let currentTab = 'all';

  async function loadWriters() {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/writers?order=full_name.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      allWriters = await res.json();
      const sel = document.getElementById('writerSelect') as HTMLSelectElement;
      if (sel) {
        sel.innerHTML = '<option value="">— No writer assigned —</option>' +
          allWriters.map(w => `<option value="${w.id}">${(w.full_name || '').replace(/</g,'&lt;')}</option>`).join('');
      }
    } catch (err) {
      console.error('Could not load writers', err);
    }
  }

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.replace(`${base}/login/`);
      return;
    }
    currentSession = session;

    // Check if admin
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/profiles?email=eq.${session.user.email}&select=is_admin`,
      {
        headers: {
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${session.access_token}`
        }
      }
    );
    const data = await res.json();

    if (!data[0]?.is_admin) {
      window.location.replace(`${base}/dashboard/`);
      return;
    }

    await loadOrders();
    await loadWriters();
  }

  async function loadOrders() {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?order=created_at.desc`,
        {
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${currentSession.access_token}`
          }
        }
      );
      allOrders = await res.json();
      updateStats();
      renderOrders();
    } catch (err) {
      console.error('Error:', err);
    }
  }

  function updateStats() {
    const total = allOrders.length;
    const newOrders = allOrders.filter(o => o.order_status === 'new').length;
    const inProgress = allOrders.filter(o => o.order_status === 'in_progress').length;
    const collected = allOrders.reduce((sum, o) => sum + Number(o.amount_paid || 0), 0);

    const set = (id: string, val: string) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set('statTotal', String(total));
    set('statNew', String(newOrders));
    set('statProgress', String(inProgress));
    set('statCollected', '$' + collected.toFixed(0));

    const statsText = document.getElementById('statsText');
    if (statsText) statsText.textContent = `${total} orders · managing all clients`;
  }

  // Escape values before injecting into innerHTML
  function esc(v: any) {
    return String(v ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function getStatusBadge(status: string) {
    const labels: Record<string, string> = {
      'new': '🆕 New',
      'in_progress': '⚙️ In Progress',
      'in_review': '🔍 In Review',
      'completed': '✅ Completed',
      'revision': '🔄 Revision',
      'cancelled': '❌ Cancelled',
    };
    const cls = ['new','in_progress','in_review','completed','revision','cancelled'].includes(status) ? status : 'new';
    const label = labels[status] || status;
    return `<span class="status-badge status-${cls}">${esc(label)}</span>`;
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: 'none' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: '⚠️ Overdue', cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');
    const search = (document.getElementById('searchInput') as HTMLInputElement)?.value.toLowerCase() || '';

    if (loading) loading.style.display = 'none';

    let filtered = currentTab === 'all'
      ? allOrders
      : allOrders.filter(o => o.order_status === currentTab);

    if (search) {
      filtered = filtered.filter(o =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.client_email || '').toLowerCase().includes(search) ||
        (o.order_number || '').toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'flex';
      grid.innerHTML = filtered.map(order => {
        const dl = deadlineInfo(order.deadline);
        return `
        <div class="order-card">
          <div class="order-card__left">
            <div class="order-card__title">${esc(order.topic || 'N/A')}</div>
            <div class="order-card__email">${esc(order.order_number || order.id)}</div>
            <div class="order-card__meta">
              ${getStatusBadge(order.order_status || 'new')}
              <span class="meta-dot">·</span>
              <span class="meta-item">${esc(order.pages || 1)} pages</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">${esc(order.assignment_type || 'N/A')}</span>
            </div>
          </div>
          <div class="order-card__right">
            <div class="order-card__deadline ${dl.cls}">${dl.text}</div>
            <div class="order-card__amount">$${Number(order.total_amount || 0).toFixed(2)} <span class="amount-paid">($${Number(order.amount_paid || 0).toFixed(2)})</span></div>
            <button class="btn-update-order" data-id="${esc(order.id)}">✏️ Update</button>
          </div>
        </div>
      `;
      }).join('');

      // Attach click listeners (safer than inline onclick with quoted values)
      grid.querySelectorAll('.btn-update-order').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = (btn as HTMLElement).dataset.id;
          const order = allOrders.find(o => String(o.id) === id);
          if (order) openUpdateModal(order);
        });
      });
    }
  }

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'all';
      renderOrders();
    });
  });

  // Search
  document.getElementById('searchInput')?.addEventListener('input', renderOrders);

  // Open update modal
  function openUpdateModal(order: any) {
    currentOrder = order;
    const modal = document.getElementById('updateModal');
    const modalOrderNum = document.getElementById('modalOrderNum');
    const statusSelect = document.getElementById('statusSelect') as HTMLSelectElement;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const currentFile = document.getElementById('currentFile');
    const currentFileName = document.getElementById('currentFileName');

    if (modalOrderNum) modalOrderNum.textContent = `Order ${order.order_number || order.id}`;
    const modalClientEmail = document.getElementById('modalClientEmail');
    if (modalClientEmail) modalClientEmail.textContent = order.client_email || '';
    if (statusSelect) statusSelect.value = order.order_status || 'new';
    const writerSelect = document.getElementById('writerSelect') as HTMLSelectElement;
    if (writerSelect) writerSelect.value = order.writer_id ? String(order.writer_id) : '';
    if (fileInput) fileInput.value = '';

    // Show the client's revision note if one exists
    const revisionNoteBox = document.getElementById('revisionNoteBox');
    const revisionNoteText = document.getElementById('revisionNoteText');
    if (revisionNoteBox && revisionNoteText) {
      if (order.revision_note && String(order.revision_note).trim()) {
        revisionNoteText.textContent = order.revision_note;
        revisionNoteBox.style.display = 'block';
      } else {
        revisionNoteBox.style.display = 'none';
      }
    }

    // Show whether a file is already attached
    if (currentFile && currentFileName) {
      if (order.file_url) {
        const parts = String(order.file_url).split('/');
        currentFileName.textContent = '📎 Attached: ' + parts[parts.length - 1];
        currentFile.style.display = 'block';
      } else {
        currentFile.style.display = 'none';
      }
    }

    modal?.classList.add('active');
  }

  // Close modal
  document.getElementById('modalClose')?.addEventListener('click', () => {
    document.getElementById('updateModal')?.classList.remove('active');
  });

  // Save update — uploads file to Storage if one is chosen
  document.getElementById('saveUpdateBtn')?.addEventListener('click', async () => {
    if (!currentOrder) return;
    const status = (document.getElementById('statusSelect') as HTMLSelectElement).value;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const btn = document.getElementById('saveUpdateBtn') as HTMLButtonElement;
    const progress = document.getElementById('uploadProgress');

    btn.disabled = true;

    // Keep existing file path unless a new file is uploaded
    let filePath = currentOrder.file_url || null;

    try {
      const file = fileInput.files && fileInput.files[0];
      if (file) {
        if (progress) progress.style.display = 'block';
        btn.textContent = '⏳ Uploading…';

        const ticket = currentOrder.order_number || String(currentOrder.id);
        // Sanitize the filename and store under the ticket folder
        const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
        const path = `${ticket}/${safeName}`;

        const { error: uploadError } = await supabase
          .storage
          .from(BUCKET)
          .upload(path, file, { upsert: true });

        if (uploadError) throw uploadError;
        filePath = path;
        if (progress) progress.style.display = 'none';
      }

      btn.textContent = '⏳ Saving…';

      await fetch(`${SUPABASE_URL}/rest/v1/orders?id=eq.${currentOrder.id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${currentSession.access_token}`
        },
        body: JSON.stringify({
          order_status: status,
          file_url: filePath,
          writer_id: (document.getElementById('writerSelect') as HTMLSelectElement)?.value || null,
          status_updated_at: new Date().toISOString()
        })
      });

      document.getElementById('updateModal')?.classList.remove('active');
      btn.textContent = '💾 Save Changes';
      btn.disabled = false;
      await loadOrders();

    } catch (err) {
      console.error(err);
      if (progress) progress.style.display = 'none';
      btn.textContent = '❌ Upload failed — try again';
      btn.disabled = false;
    }
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  checkAuth();

  // ── THEME TOGGLE ──
  const THEME_KEY = 'admin-theme';

  function getSystemPref() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(setting: string) {
    const actual = setting === 'system' ? getSystemPref() : setting;
    if (actual === 'dark') {
      document.body.classList.add('dark-mode');
    } else {
      document.body.classList.remove('dark-mode');
    }
    document.querySelectorAll('.tt-btn').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.theme === setting);
    });
    localStorage.setItem(THEME_KEY, setting);
  }

  document.querySelectorAll('.tt-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      applyTheme((btn as HTMLElement).dataset.theme || 'light');
    });
  });

  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (localStorage.getItem(THEME_KEY) === 'system') applyTheme('system');
  });

  applyTheme(localStorage.getItem(THEME_KEY) || 'light');

  // ═══ ADMIN INBOX ═══
  let inboxConversations: any[] = [];
  let inboxActiveId: string | null = null;
  let inboxSub: any = null;
  let inboxFilter = 'all';

  async function loadInbox() {
    const list = document.getElementById('inboxList')!;
    list.innerHTML = '<div class="inbox-loading">Loading…</div>';
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/conversations?order=updated_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      inboxConversations = await res.json();
      renderInboxList();
    } catch (err) { console.error(err); list.innerHTML = '<div class="inbox-loading">Could not load</div>'; }
  }

  function renderInboxList() {
    const list = document.getElementById('inboxList')!;
    const count = document.getElementById('inboxCount')!;
    let filtered = inboxFilter === 'all' ? inboxConversations : inboxConversations.filter((c: any) => c.type === inboxFilter);
    count.textContent = String(filtered.length);
    if (!filtered.length) { list.innerHTML = '<div class="inbox-loading">No conversations yet</div>'; return; }
    list.innerHTML = filtered.map((c: any) => {
      const isSupport = c.type === 'support';
      const initials = isSupport ? 'SP' : 'OR';
      const time = c.updated_at ? new Date(c.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
      const isActive = c.id === inboxActiveId;
      const label = c.title || (isSupport ? 'Support Chat' : 'Order Chat');
      return `<div class="inbox-item ${isActive ? 'active' : ''}" data-cid="${c.id}">
        <div class="inbox-item-avatar ${isSupport ? 'avatar-support' : 'avatar-order'}">${initials}</div>
        <div class="inbox-item-info">
          <div class="inbox-item-name">${esc(label)}</div>
          <div class="inbox-item-type">${isSupport ? 'Support' : 'Order chat'}</div>
        </div>
        <div class="inbox-item-time">${time}</div>
      </div>`;
    }).join('');
    list.querySelectorAll('.inbox-item').forEach(item => {
      item.addEventListener('click', () => openInboxThread((item as HTMLElement).dataset.cid!));
    });
  }

  // Ensure the order's assigned writer is a participant in this order chat.
  // Silent on auto-run; pass notify=true for the manual button.
  async function ensureOrderWriter(conv: any, notify = false) {
    if (!conv || conv.type !== 'order' || !conv.order_id) { if (notify) alert('This is not an order chat.'); return; }
    const hdr = { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` };
    try {
      const order = (await (await fetch(`${SUPABASE_URL}/rest/v1/orders?id=eq.${conv.order_id}&select=writer_id`, { headers: hdr })).json())[0];
      if (!order?.writer_id) { if (notify) alert('No writer is assigned to this order yet. Assign one in the order Update modal first.'); return; }
      const writer = (await (await fetch(`${SUPABASE_URL}/rest/v1/writers?id=eq.${order.writer_id}&select=auth_user_id,full_name`, { headers: hdr })).json())[0];
      if (!writer?.auth_user_id) { if (notify) alert('That writer has no linked account.'); return; }
      const existing = await (await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants?conversation_id=eq.${conv.id}&user_id=eq.${writer.auth_user_id}&select=id`, { headers: hdr })).json();
      if (existing.length) { if (notify) alert(`${writer.full_name || 'Writer'} is already in this chat.`); return; }
      await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants`, {
        method: 'POST',
        headers: { ...hdr, 'Content-Type': 'application/json' },
        body: JSON.stringify({ conversation_id: conv.id, user_id: writer.auth_user_id, role: 'writer', display_name: writer.full_name || 'Writer' })
      });
      if (notify) alert(`✅ ${writer.full_name || 'Writer'} added to this chat.`);
    } catch (err) { console.error('ensureOrderWriter', err); if (notify) alert('Could not add writer — check console.'); }
  }

  async function openInboxThread(conversationId: string) {
    inboxActiveId = conversationId;
    const conv = inboxConversations.find((c: any) => c.id === conversationId);
    document.getElementById('inboxEmpty')!.style.display = 'none';
    const thread = document.getElementById('inboxThread')!;
    thread.style.display = 'flex';
    const header = document.getElementById('inboxThreadHeader')!;
    const icon = conv?.type === 'support' ? '🛟' : '📋';
    const typeLabel = conv?.type === 'support' ? 'Support conversation' : 'Order chat';
    const writerBtn = conv?.type === 'order' ? `<button class="inbox-addwriter-btn" id="inboxAddWriterBtn">➕ Add writer</button>` : '';
    header.innerHTML = `<div style="flex:1;min-width:0;"><div class="inbox-thread-title">${icon} ${esc(conv?.title || 'Chat')}</div><div class="inbox-thread-sub">${typeLabel}</div></div>${writerBtn}`;
    if (conv?.type === 'order') {
      ensureOrderWriter(conv);  // auto-link the assigned writer
      document.getElementById('inboxAddWriterBtn')?.addEventListener('click', () => ensureOrderWriter(conv, true));
    }
    renderInboxList();
    const container = document.getElementById('inboxMessages')!;
    container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;font-size:0.85rem;">Loading…</div>';
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/messages?conversation_id=eq.${conversationId}&order=created_at.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      renderInboxMessages(await res.json());
    } catch (err) { container.innerHTML = '<div style="text-align:center;color:#94a3b8;">Could not load messages</div>'; }
    if (inboxSub) { inboxSub.unsubscribe(); inboxSub = null; }
    inboxSub = supabase.channel(`admin-inbox-${conversationId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages', filter: `conversation_id=eq.${conversationId}` },
        (payload: any) => {
          const msg = payload.new;
          const c = document.getElementById('inboxMessages')!;
          const ph = c.querySelector('div[style*="text-align:center"]');
          if (ph) c.innerHTML = '';
          const isMine = msg.sender_role === 'support' || msg.sender_id === currentSession.user.id;
          const time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
          c.insertAdjacentHTML('beforeend', `<div class="imsg-row ${isMine ? 'mine' : 'theirs'}">
            ${!isMine ? `<div class="imsg-sender">${esc(msg.sender_name || msg.sender_role || 'User')}</div>` : ''}
            <div class="imsg-bubble">${esc(msg.content)}</div>
            <div class="imsg-time">${time}</div>
          </div>`);
          c.scrollTop = c.scrollHeight;
        }
      ).subscribe();
  }

  function renderInboxMessages(messages: any[]) {
    const container = document.getElementById('inboxMessages')!;
    if (!messages.length) { container.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:2rem;font-size:0.85rem;">No messages yet.</div>'; return; }
    container.innerHTML = messages.map((m: any) => {
      const isSupport = m.sender_role === 'support' || m.sender_id === currentSession.user.id;
      const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
      const senderLabel = isSupport ? 'Support' : (m.sender_name || 'User');
      const avatarInitial = isSupport ? 'S' : (m.sender_name?.[0]?.toUpperCase() || 'U');
      return `<div class="imsg-row ${isSupport ? 'mine' : 'theirs'}">
        ${!isSupport ? `<div class="imsg-meta"><div class="imsg-avatar theirs-avatar">${avatarInitial}</div><div class="imsg-sender-name">${esc(senderLabel)}</div></div>` : ''}
        <div class="imsg-bubble">${esc(m.content)}</div>
        ${isSupport ? `<div class="imsg-meta-right"><div class="imsg-sender-name" style="text-align:right">You</div><div class="imsg-avatar mine-avatar">S</div></div>` : ''}
        <div class="imsg-time">${time}</div>
      </div>`;
    }).join('');
    container.scrollTop = container.scrollHeight;
  }

  async function inboxSend() {
    const input = document.getElementById('inboxInput') as HTMLInputElement;
    const content = input.value.trim();
    if (!content || !inboxActiveId) return;
    const btn = document.getElementById('inboxSendBtn') as HTMLButtonElement;
    btn.disabled = true; input.value = '';
    try {
      await fetch(`${SUPABASE_URL}/rest/v1/messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({ conversation_id: inboxActiveId, sender_id: currentSession.user.id, sender_name: 'Support', sender_role: 'support', content })
      });
      await fetch(`${SUPABASE_URL}/rest/v1/conversations?id=eq.${inboxActiveId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ updated_at: new Date().toISOString() })
      });
    } catch (err) { console.error(err); }
    btn.disabled = false; input.focus();
  }

  document.getElementById('inboxSendBtn')?.addEventListener('click', inboxSend);
  document.getElementById('inboxInput')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); inboxSend(); } });

  // Filter buttons
  document.querySelectorAll('.inbox-filter').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.inbox-filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      inboxFilter = (btn as HTMLElement).dataset.filter || 'all';
      renderInboxList();
    });
  });

  // Hook into the Inbox tab click
  document.querySelectorAll('.tab').forEach(tab => {
    if ((tab as HTMLElement).dataset.tab === 'inbox') {
      tab.addEventListener('click', () => {
        document.getElementById('loadingState')!.style.display = 'none';
        document.getElementById('emptyState')!.style.display = 'none';
        document.getElementById('ordersGrid')!.style.display = 'none';
        document.getElementById('inboxPanel')!.style.display = 'block';
        loadInbox();
      });
    }
  });

  // Make sure switching away from inbox hides it
  document.querySelectorAll('.tab').forEach(tab => {
    if ((tab as HTMLElement).dataset.tab !== 'inbox') {
      tab.addEventListener('click', () => {
        document.getElementById('inboxPanel')!.style.display = 'none';
      });
    }
  });
</script>
