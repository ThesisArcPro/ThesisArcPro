---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout 
  title="Academic Writing Blog | ThesisArcPro"
  description="Expert tips, guides and advice on essay writing, thesis development, research papers and academic success for university students worldwide.">

  <Header />
  <main class="blog-index">
    <section class="blog-hero">
      <h1>Academic Writing Blog</h1>
      <p>Expert guides to help university students write better 
      essays, dissertations, and research papers.</p>
    </section>

    <section class="blog-grid">

      <article class="blog-card">
        <span class="blog-category">Essay Writing</span>
        <h2>
          <a href="/ThesisArcPro/blog/how-to-write-an-essay-as-a-university-student">
            How to Write an Essay as a University Student: 
            A Step-by-Step Guide
          </a>
        </h2>
        <p>Master the art of academic essay writing. Learn how 
        to write an essay as a university student with our 
        step-by-step guide on structure, formatting, and 
        critical research.</p>
        <div class="blog-card-footer">
          <span class="blog-date">June 4, 2026</span>
          <a href="/ThesisArcPro/blog/how-to-write-an-essay-as-a-university-student" 
            class="read-more">Read More →</a>
        </div>
      </article>

      <article class="blog-card">
        <span class="blog-category">Thesis & Dissertation</span>
        <h2>
          <a href="/ThesisArcPro/blog/how-to-write-a-masters-thesis">
            How to Write a Master's Thesis: A Complete Guide 
            for Graduate Students
          </a>
        </h2>
        <p>Learn how to write a master's thesis step by step. 
        Our complete guide covers structure, format, proposal 
        writing and research tips for postgraduate students.</p>
        <div class="blog-card-footer">
          <span class="blog-date">June 4, 2026</span>
          <a href="/ThesisArcPro/blog/how-to-write-a-masters-thesis" 
            class="read-more">Read More →</a>
        </div>
      </article>

      <article class="blog-card">
        <span class="blog-category">Research Paper</span>
        <h2>
          <a href="/ThesisArcPro/blog/how-to-write-a-research-paper-without-plagiarism">
            How to Write a Research Paper Without Plagiarism: 
            10 Proven Methods for University Students
          </a>
        </h2>
        <p>Learn how to write a research paper without plagiarism 
        using our 10 proven methods. Discover step-by-step 
        strategies for paraphrasing, citing, and structuring.</p>
        <div class="blog-card-footer">
          <span class="blog-date">June 5, 2026</span>
          <a href="/ThesisArcPro/blog/how-to-write-a-research-paper-without-plagiarism" 
            class="read-more">Read More →</a>
        </div>
      </article>

      <article class="blog-card">
        <span class="blog-category">Editing & Proofreading</span>
        <h2>
          <a href="/ThesisArcPro/blog/essay-editing-checklist">
            Essay Editing Checklist: 10 Things to Fix 
            Before You Submit
          </a>
        </h2>
        <p>Ensure your paper is ready for submission with our 
        essay editing checklist. 10 critical things to fix from 
        structure to citation formatting for university 
        students.</p>
        <div class="blog-card-footer">
          <span class="blog-date">June 5, 2026</span>
          <a href="/ThesisArcPro/blog/essay-editing-checklist" 
            class="read-more">Read More →</a>
        </div>
      </article>

    </section>
  </main>
  <Footer />

</BaseLayout>

<style>
  .blog-hero {
    text-align: center;
    padding: 4rem 2rem 2rem;
  }

  .blog-hero h1 {
    font-size: 2.5rem;
    color: #1B2A4A;
    margin-bottom: 1rem;
  }

  .blog-hero p {
    font-size: 1.1rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
  }

  .blog-grid {
    max-width: 900px;
    margin: 2rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .blog-card {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 1.5rem;
    transition: box-shadow 0.3s ease;
  }

  .blog-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .blog-category {
    display: inline-block;
    background-color: #e7f1f5;
    color: #1B2A4A;
    font-size: 0.75rem;
    font-weight: bold;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .blog-card h2 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .blog-card h2 a {
    color: #1B2A4A;
    text-decoration: none;
  }

  .blog-card h2 a:hover {
    text-decoration: underline;
  }

  .blog-card p {
    color: #64748b;
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .blog-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid #e2e8f0;
  }

  .blog-date {
    font-size: 0.8rem;
    color: #94a3b8;
  }

  .read-more {
    display: inline-block;
    color: #1B2A4A;
    font-weight: bold;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .read-more:hover {
    text-decoration: underline;
  }
</style>