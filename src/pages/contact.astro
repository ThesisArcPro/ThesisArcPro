---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout 
  title="Place Order" 
  description="Place your order with ThesisArcPro — get an instant price quote for expert academic writing support."
  url="https://thesisarcpro.github.io/ThesisArcPro/contact">
  <Header />

  <div class="floating-left">
    <button class="float-btn float-btn--help" id="helpBtn" title="Help & Live Chat">
      <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 1C6.48 1 2 5.48 2 11c0 1.88.52 3.64 1.43 5.14L2 22l5.86-1.43C9.36 21.48 11.12 22 13 22c5.52 0 9-4.48 9-10S17.52 1 12 1zm0 2c3.87 0 7 3.13 7 7s-3.13 7-7 7c-1.55 0-2.98-.5-4.13-1.34L5 17l1.34-1.87C5.5 13.98 5 12.55 5 11c0-3.87 3.13-7 7-7zm-1 3v5h2V6h-2zm0 6v2h2v-2h-2z"/></svg>
      <span>Help</span>
    </button>
  </div>

  <div class="chat-popup" id="chatPopup">
    <div class="chat-popup__header">
      <div class="chat-popup__avatars">
        <div class="avatar avatar--1">T</div>
        <div class="avatar avatar--2">A</div>
        <div class="avatar avatar--3">P</div>
      </div>
      <button class="chat-popup__close" id="chatClose">✕</button>
      <h2>Hey there! 👋</h2>
      <p>How can we help?</p>
      <span class="chat-online">● We're online now</span>
    </div>
    <div class="chat-popup__body">
      <div class="chat-actions">
        <a href="https://wa.me/16624002088" target="_blank" class="chat-action-btn chat-action-btn--whatsapp">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <div>
            <span class="chat-action-btn__title">Chat on WhatsApp</span>
            <span class="chat-action-btn__sub">Instant response</span>
          </div>
          <svg class="chat-action-btn__arrow" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
        </a>
        <a href="https://mail.google.com/mail/?view=cm&to=thesisarcpro069@gmail.com&su=ThesisArcPro%20Enquiry" target="_blank" class="chat-action-btn chat-action-btn--email">
          <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          <div>
            <span class="chat-action-btn__title">Send us an Email</span>
            <span class="chat-action-btn__sub">thesisarcpro069@gmail.com</span>
          </div>
          <svg class="chat-action-btn__arrow" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M9 18l6-6-6-6"/></svg>
        </a>
      </div>
    </div>
    <div class="chat-popup__footer">
      <div class="chat-tabs">
        <button class="chat-tab chat-tab--active">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
          Home
        </button>
        <button class="chat-tab" id="messagesTab">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
          Messages
        </button>
        <button class="chat-tab">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
          Help
        </button>
      </div>
    </div>
  </div>
  <div class="chat-overlay" id="chatOverlay"></div>

  <!-- Payment Modal -->
  <div class="modal-overlay" id="paymentModal">
    <div class="modal-card">
      <button class="modal-close" id="paymentModalClose">✕</button>
      <div class="modal-icon">💰</div>
      <h2>Complete Payment</h2>
      <div id="paymentDetails" class="payment-details"></div>
      <div class="payment-policy">
        <p id="policyText"></p>
      </div>
      <a href="https://www.paypal.com/ncp/payment/X4GBU659AGXGQ" target="_blank" class="paypal-link-btn" id="paypalBtn">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.59 3.025-2.566 4.643-5.813 4.643h-2.19c-.988 0-1.829.722-1.974 1.699l-1.12 7.106-.313 1.983h3.293l.742-4.713.048-.306c.145-.977.986-1.699 1.974-1.699h1.245c3.863 0 6.637-1.57 7.49-6.114.333-1.726.163-3.168-.734-4.312z"/></svg>
        Pay with PayPal or Card
      </a>
      <p class="paypal-note">🔒 Secured by PayPal — Accepts Visa, Mastercard & PayPal</p>
      <div class="txn-group">
        <label for="txnId">Enter PayPal Transaction ID *</label>
        <input type="text" id="txnId" placeholder="e.g. 7GH123456789" />
        <span class="txn-note">Find it in your PayPal confirmation email</span>
      </div>
      <button class="btn-confirm-payment" id="confirmPaymentBtn" disabled>
        ✅ I Have Paid — Submit My Order
      </button>
    </div>
  </div>

  <main>
    <section class="page-hero">
      <div class="container page-hero__inner">
        <div class="page-hero__content">
          <p class="page-hero__eyebrow">Get Started</p>
          <h1>Place Your Order</h1>
          <p class="page-hero__sub">Fill in your details below and get an instant price quote. We will match you with the perfect expert within 30 minutes.</p>
        </div>
        <div class="page-hero__illustration">
          <img
            src="/ThesisArcPro/images/contact.svg"
            alt="Place your academic writing order and get expert help instantly"
            width="400"
            height="300"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="order-section">
      <div class="container order__inner">

        <div class="order__form-wrap">
          <div class="user-greeting" id="userGreeting" style="display:none;">
            <span id="greetingText"></span>
            <button id="logoutBtn" class="logout-btn">Log Out</button>
          </div>

          <h2>Order Details</h2>
          <p>Complete the form below to get your instant quote.</p>

          <form class="order-form" id="orderForm">

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required readonly />
            </div>

            <div class="form-group">
              <label for="topic">Topic / Title *</label>
              <input type="text" id="topic" name="topic" placeholder="Enter your assignment topic or title" required />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="type">Assignment Type *</label>
                <input type="text" id="type" name="type" list="type-list" placeholder="Select or type..." required />
                <datalist id="type-list">
                  <option>Essay</option>
                  <option>Research Paper</option>
                  <option>Discussion Post</option>
                  <option>Report</option>
                  <option>Take Home Exam</option>
                  <option>Dissertation / Thesis</option>
                  <option>Research Proposal</option>
                  <option>Literature Review</option>
                  <option>Case Study</option>
                  <option>Other</option>
                </datalist>
              </div>
              <div class="form-group">
                <label for="subject">Subject *</label>
                <input type="text" id="subject" name="subject" list="subject-list" placeholder="Select or type..." required />
                <datalist id="subject-list">
                  <option>Nursing & Healthcare</option>
                  <option>Business Management</option>
                  <option>English & Literature</option>
                  <option>Mathematics</option>
                  <option>Psychology</option>
                  <option>Law</option>
                  <option>Education</option>
                  <option>History</option>
                  <option>Science</option>
                  <option>Sociology</option>
                  <option>IT & Computer Science</option>
                  <option>Finance & Accounting</option>
                  <option>Other</option>
                </datalist>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="service">Service *</label>
                <input type="text" id="service" name="service" list="service-list" placeholder="Select or type..." required />
                <datalist id="service-list">
                  <option>Writing</option>
                  <option>Rewriting</option>
                  <option>Editing & Proofreading</option>
                  <option>Review My Work</option>
                  <option>Calculations / Problems</option>
                  <option>Other</option>
                </datalist>
              </div>
              <div class="form-group">
                <label for="language">Language *</label>
                <select id="language" name="language" required>
                  <option value="" disabled selected>Select language</option>
                  <option>English (US)</option>
                  <option>English (UK)</option>
                </select>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="level">Education Level *</label>
                <select id="level" name="level" required>
                  <option value="" disabled selected>Select level</option>
                  <option value="HighSchool" data-rate="12">High School ($12/pg)</option>
                  <option value="College" data-rate="13">College ($13/pg)</option>
                  <option value="Masters" data-rate="14">Masters ($14/pg)</option>
                  <option value="PhD" data-rate="15">PhD / Doctorate ($15/pg)</option>
                </select>
              </div>
              <div class="form-group">
                <label for="deadline">Deadline *</label>
                <div class="quick-deadlines">
                  <button type="button" class="quick-btn" data-hours="3">3hrs</button>
                  <button type="button" class="quick-btn" data-hours="6">6hrs</button>
                  <button type="button" class="quick-btn" data-hours="9">9hrs</button>
                  <button type="button" class="quick-btn" data-hours="12">12hrs</button>
                  <button type="button" class="quick-btn" data-hours="24">1 day</button>
                  <button type="button" class="quick-btn" data-hours="48">2 days</button>
                  <button type="button" class="quick-btn" data-hours="120">5 days</button>
                </div>
                <input type="datetime-local" id="deadline" name="deadline" />
              </div>
            </div>

            <div class="urgency-display" id="urgencyDisplay" style="display:none;">
              <span class="urgency-badge" id="urgencyBadge"></span>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="pages">Number of Pages *</label>
                <div class="pages-input">
                  <button type="button" id="minusBtn">−</button>
                  <input type="number" id="pages" name="pages" value="1" min="1" max="500" />
                  <button type="button" id="plusBtn">+</button>
                </div>
                <span class="pages-note">1 page = 275 words</span>
              </div>
              <div class="form-group">
                <label>Word Count</label>
                <div class="wordcount-display" id="wordCount">275 words</div>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="citation">Citation Style</label>
                <select id="citation" name="citation">
                  <option value="" disabled selected>Select style</option>
                  <option>APA 7</option>
                  <option>MLA 9</option>
                  <option>Chicago</option>
                  <option>Harvard</option>
                  <option>APA 6</option>
                  <option>Turabian</option>
                  <option>IEEE</option>
                  <option>Vancouver</option>
                  <option>Other</option>
                  <option>Not Required</option>
                </select>
              </div>
              <div class="form-group">
                <label for="sources">Sources Required</label>
                <input type="number" id="sources" name="sources" min="0" max="999" placeholder="e.g. 5" />
              </div>
            </div>
            <div class="addons">
              <h3>Add-ons</h3>
              <div class="addons__grid">
                <div class="addon-item">
                  <div class="addon-item__info">
                    <span class="addon-item__name">📊 Graphics & Tables</span>
                    <span class="addon-item__price">$5 each</span>
                  </div>
                  <div class="addon-qty">
                    <button type="button" onclick="changeAddon('graphics', -1)">−</button>
                    <span id="graphics-qty">0</span>
                    <button type="button" onclick="changeAddon('graphics', 1)">+</button>
                  </div>
                </div>
                <div class="addon-item">
                  <div class="addon-item__info">
                    <span class="addon-item__name">📚 Printable Sources</span>
                    <span class="addon-item__price">$4 each</span>
                  </div>
                  <div class="addon-qty">
                    <button type="button" onclick="changeAddon('sources', -1)">−</button>
                    <span id="sources-qty">0</span>
                    <button type="button" onclick="changeAddon('sources', 1)">+</button>
                  </div>
                </div>
                <div class="addon-item addon-item--free">
                  <div class="addon-item__info">
                    <span class="addon-item__name">🛡️ Plagiarism & AI Report</span>
                    <span class="addon-item__price free">FREE</span>
                  </div>
                  <div class="addon-qty addon-qty--free">
                    <span>✔ Included</span>
                  </div>
                </div>
                <div class="addon-item">
                  <div class="addon-item__info">
                    <span class="addon-item__name">📝 Abstract Page</span>
                    <span class="addon-item__price">$7 each</span>
                  </div>
                  <div class="addon-qty">
                    <button type="button" onclick="changeAddon('abstract', -1)">−</button>
                    <span id="abstract-qty">0</span>
                    <button type="button" onclick="changeAddon('abstract', 1)">+</button>
                  </div>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label for="instructions">Instructions / Description *</label>
              <textarea id="instructions" name="instructions" rows="5" placeholder="Describe your assignment in detail — include any specific requirements, rubric, or guidelines..." required></textarea>
            </div>

            <div class="form-group">
              <label for="files">Attach Files (optional)</label>
              <div class="file-upload">
                <input type="file" id="files" name="files" multiple accept=".pdf,.doc,.docx,.txt,.png,.jpg" />
                <p>📎 Drag & drop files here or click to browse</p>
                <span>Accepted: PDF, DOC, DOCX, TXT, PNG, JPG</span>
              </div>
            </div>

            <!-- Create Order Button -->
            <button type="button" class="btn-primary form-submit" id="createOrderBtn">
              🛒 Create Order
            </button>

            <!-- Submit Order Button — hidden until payment confirmed -->
            <button type="button" class="btn-submit-order" id="submitOrderBtn" style="display:none;">
              ✅ Submit Order
            </button>

          </form>
        </div>

        <div class="order__calculator">
          <div class="calculator-card">
            <h3>💰 Your Price</h3>
            <div class="calc-display">
              <div class="calc-total" id="calcTotal">$12.00</div>
              <div class="calc-label">Estimated Total</div>
            </div>
            <div class="calc-breakdown">
              <div class="breakdown-item">
                <span>Base price</span>
                <span id="basePriceDisplay">$12.00/pg</span>
              </div>
              <div class="breakdown-item">
                <span>Pages</span>
                <span id="pagesDisplay">x 1</span>
              </div>
              <div class="breakdown-item" id="urgencyRow" style="display:none;">
                <span id="urgencyLabel">Urgency</span>
                <span id="urgencyAmount">+$0.00</span>
              </div>
              <div class="breakdown-item" id="addonsRow" style="display:none;">
                <span>Add-ons</span>
                <span id="addonsAmount">+$0.00</span>
              </div>
              <div class="breakdown-divider"></div>
              <div class="breakdown-item breakdown-item--total">
                <span>Total</span>
                <span id="totalDisplay">$12.00</span>
              </div>
            </div>
            <div class="calc-features">
              <div class="calc-feature">✔ Free plagiarism & AI report</div>
              <div class="calc-feature">✔ Free unlimited revisions</div>
              <div class="calc-feature">✔ On time delivery guaranteed</div>
              <div class="calc-feature">✔ Money back guarantee</div>
            </div>
            <div class="calc-note">
              💬 Need a custom quote? <a href="https://wa.me/16624002088" target="_blank">Chat with us</a>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.floating-left { position: fixed; bottom: 2rem; left: 2rem; z-index: 9999; }
.float-btn--help { display: flex; align-items: center; gap: 0.5rem; background-color: var(--navy); color: var(--white); border: none; border-radius: 50px; padding: 0 1.3rem; height: 48px; font-weight: 700; font-size: 0.9rem; cursor: pointer; box-shadow: 0 4px 20px rgba(0,0,0,0.2); transition: all 0.3s ease; }
.float-btn--help svg { flex-shrink: 0; }
.float-btn--help:hover { background-color: var(--gold); color: var(--navy); transform: translateY(-2px); }
.chat-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.25); z-index: 10000; }
.chat-overlay.active { display: block; }
.chat-popup { position: fixed; bottom: 6rem; left: 2rem; width: 320px; background: var(--white); border-radius: 16px; box-shadow: 0 8px 40px rgba(0,0,0,0.18); z-index: 10001; overflow: hidden; transform: translateY(16px); opacity: 0; pointer-events: none; transition: all 0.25s ease; }
.chat-popup.active { transform: translateY(0); opacity: 1; pointer-events: all; }
.chat-popup__header { background: #1a73e8; padding: 1.5rem 1.5rem 1.3rem; position: relative; }
.chat-popup__avatars { display: flex; margin-bottom: 1rem; }
.avatar { width: 36px; height: 36px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.82rem; color: white; margin-left: -8px; }
.avatar:first-child { margin-left: 0; }
.avatar--1 { background: #e74c3c; }
.avatar--2 { background: #8e44ad; }
.avatar--3 { background: #f39c12; }
.chat-popup__close { position: absolute; top: 0.9rem; right: 0.9rem; background: rgba(255,255,255,0.2); border: none; color: white; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 0.8rem; display: flex; align-items: center; justify-content: center; }
.chat-popup__header h2 { color: white; font-size: 1.25rem; margin: 0 0 0.25rem; }
.chat-popup__header p { color: rgba(255,255,255,0.85); font-size: 0.92rem; margin: 0 0 0.5rem; }
.chat-online { font-size: 0.76rem; color: #a8f0c6; font-weight: 500; }
.chat-popup__body { padding: 1.2rem; }
.chat-actions { display: flex; flex-direction: column; gap: 0.6rem; }
.chat-action-btn { display: flex; align-items: center; gap: 0.8rem; padding: 0.85rem 1rem; border-radius: 10px; text-decoration: none; transition: all 0.2s ease; }
.chat-action-btn > div { flex: 1; }
.chat-action-btn__title { display: block; font-weight: 700; font-size: 0.88rem; }
.chat-action-btn__sub { display: block; font-size: 0.76rem; opacity: 0.7; margin-top: 0.1rem; }
.chat-action-btn__arrow { opacity: 0.4; flex-shrink: 0; }
.chat-action-btn--whatsapp { background: #e8faf0; color: #1a7a3c; border: 1px solid rgba(37,211,102,0.15); }
.chat-action-btn--whatsapp:hover { background: #25D366; color: white; }
.chat-action-btn--email { background: rgba(197,160,89,0.08); color: var(--navy); border: 1px solid rgba(197,160,89,0.2); }
.chat-action-btn--email:hover { background: var(--gold); color: var(--navy); }
.chat-popup__footer { border-top: 1px solid rgba(0,0,0,0.07); padding: 0.4rem 0; }
.chat-tabs { display: flex; justify-content: space-around; }
.chat-tab { display: flex; flex-direction: column; align-items: center; gap: 0.2rem; background: none; border: none; cursor: pointer; padding: 0.5rem 0.8rem; border-radius: 8px; font-size: 0.7rem; color: var(--text-light); transition: color 0.2s ease; }
.chat-tab--active { color: #1a73e8; }
.chat-tab:hover { color: var(--navy); }

/* Modal */
.modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 20000; align-items: center; justify-content: center; }
.modal-overlay.active { display: flex; }
.modal-card { background: var(--white); border-radius: 16px; padding: 2.5rem; max-width: 460px; width: 90%; position: relative; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
