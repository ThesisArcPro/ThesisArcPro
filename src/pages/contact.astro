.txn-group input:focus { border-color: var(--gold); }
.txn-note { font-size: 0.76rem; color: var(--text-light); }
.btn-confirm-payment:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbwAjvDXT5kJylGmH9Amczt3IPxiPct0ehphNzDa2TAD3ZrqPLdaqffJCiJ_S83PnOk5JQ/exec';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
  const base = '/ThesisArcPro';

  let currentTotal = 12;
  let currentSession: any = null;

  // Check auth
  async function checkAuth() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.replace(`${base}/login/`);
        return;
      }
      currentSession = session;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      if (emailInput) emailInput.value = session.user.email || '';

      const greeting = document.getElementById('userGreeting');
      const greetingText = document.getElementById('greetingText');
      if (greeting) greeting.style.display = 'flex';
      if (greetingText) greetingText.textContent = `👋 Welcome, ${session.user.email}`;
    } catch {
      window.location.replace(`${base}/login/`);
    }
  }

  checkAuth();

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  // Price calculator
  const levelSelect = document.getElementById('level') as HTMLSelectElement;
  const pagesInput = document.getElementById('pages') as HTMLInputElement;
  const deadlineInput = document.getElementById('deadline') as HTMLInputElement;

  const addons: Record<string, number> = { graphics: 0, sources: 0, abstract: 0 };
  const addonPrices: Record<string, number> = { graphics: 5, sources: 4, abstract: 7 };

  function changeAddon(type: string, delta: number) {
    addons[type] = Math.max(0, (addons[type] || 0) + delta);
    const el = document.getElementById(`${type}-qty`);
    if (el) el.textContent = String(addons[type]);
    calculatePrice();
  }

  function calculatePrice() {
    const selectedOption = levelSelect?.options[levelSelect.selectedIndex];
    const rate = parseFloat(selectedOption?.getAttribute('data-rate') || '12');
    const pages = parseInt(pagesInput?.value || '1');
    const words = pages * 275;

    const wordCountEl = document.getElementById('wordCount');
    const pagesDisplayEl = document.getElementById('pagesDisplay');
    const basePriceDisplayEl = document.getElementById('basePriceDisplay');
    if (wordCountEl) wordCountEl.textContent = `${words.toLocaleString()} words`;
    if (pagesDisplayEl) pagesDisplayEl.textContent = `x ${pages}`;
    if (basePriceDisplayEl) basePriceDisplayEl.textContent = `$${rate.toFixed(2)}/pg`;

    let urgencySurcharge = 0;
    let urgencyText = '';
    if (deadlineInput?.value) {
      const hoursLeft = (new Date(deadlineInput.value).getTime() - new Date().getTime()) / 3600000;
      if (hoursLeft < 6) { urgencySurcharge = rate * 0.5; urgencyText = '🔴 RUSH (under 6h): +50%'; }
      else if (hoursLeft < 12) { urgencySurcharge = rate * 0.3; urgencyText = '🟠 Urgent (6-12h): +30%'; }
      else if (hoursLeft < 24) { urgencySurcharge = rate * 0.2; urgencyText = '🟡 Same day (12-24h): +20%'; }
      else if (hoursLeft < 48) { urgencySurcharge = rate * 0.1; urgencyText = '🟢 Standard (1-2 days): +10%'; }
    }

    const urgencyBadgeEl = document.getElementById('urgencyBadge');
    const urgencyDisplayEl = document.getElementById('urgencyDisplay');
    if (urgencyBadgeEl) urgencyBadgeEl.textContent = urgencyText;
    if (urgencyDisplayEl) urgencyDisplayEl.style.display = urgencyText ? 'block' : 'none';

    const baseTotal = rate * pages;
    const urgencyTotal = urgencySurcharge * pages;
    let addonsTotal = 0;
    for (const [key, qty] of Object.entries(addons)) {
      addonsTotal += (addonPrices[key] || 0) * qty;
    }
    const total = baseTotal + urgencyTotal + addonsTotal;
    currentTotal = total;

    const urgencyRowEl = document.getElementById('urgencyRow');
    const urgencyLabelEl = document.getElementById('urgencyLabel');
    const urgencyAmountEl = document.getElementById('urgencyAmount');
    const addonsRowEl = document.getElementById('addonsRow');
    const addonsAmountEl = document.getElementById('addonsAmount');
    const calcTotalEl = document.getElementById('calcTotal');
    const totalDisplayEl = document.getElementById('totalDisplay');

    if (urgencyRowEl) urgencyRowEl.style.display = urgencyTotal > 0 ? 'flex' : 'none';
    if (urgencyLabelEl) urgencyLabelEl.textContent = urgencyText.split(':')[0] || 'Urgency';
    if (urgencyAmountEl) urgencyAmountEl.textContent = `+$${urgencyTotal.toFixed(2)}`;
    if (addonsRowEl) addonsRowEl.style.display = addonsTotal > 0 ? 'flex' : 'none';
    if (addonsAmountEl) addonsAmountEl.textContent = `+$${addonsTotal.toFixed(2)}`;
    if (calcTotalEl) calcTotalEl.textContent = `$${total.toFixed(2)}`;
    if (totalDisplayEl) totalDisplayEl.textContent = `$${total.toFixed(2)}`;
  }

  levelSelect?.addEventListener('change', calculatePrice);
  pagesInput?.addEventListener('input', calculatePrice);
  deadlineInput?.addEventListener('change', calculatePrice);

  document.getElementById('minusBtn')?.addEventListener('click', () => {
    const val = parseInt(pagesInput.value);
    if (val > 1) { pagesInput.value = String(val - 1); calculatePrice(); }
  });
  document.getElementById('plusBtn')?.addEventListener('click', () => {
    const val = parseInt(pagesInput.value);
    if (val < 500) { pagesInput.value = String(val + 1); calculatePrice(); }
  });

  // Quick deadline buttons
  document.querySelectorAll('.quick-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const hours = parseInt((btn as HTMLElement).dataset.hours || '0');
      const date = new Date();
      date.setHours(date.getHours() + hours);
      const local = new Date(date.getTime() - date.getTimezoneOffset() * 60000)
        .toISOString().slice(0, 16);
      deadlineInput.value = local;
      document.querySelectorAll('.quick-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      calculatePrice();
    });
  });

  // Transaction ID enables confirm button
  document.getElementById('txnId')?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value.trim();
    const btn = document.getElementById('confirmPaymentBtn') as HTMLButtonElement;
    btn.disabled = val.length < 5;
  });

  // Create Order button — validate then show payment modal
  document.getElementById('createOrderBtn')?.addEventListener('click', () => {
    const requiredFields = ['topic', 'type', 'subject', 'service', 'language', 'level', 'deadline', 'instructions'];
    for (const field of requiredFields) {
      const el = document.getElementById(field) as HTMLInputElement;
      if (!el?.value?.trim()) {
        el?.focus();
        alert(`Please fill in the "${field.charAt(0).toUpperCase() + field.slice(1)}" field before proceeding.`);
        return;
      }
    }
    const total = currentTotal;
    const isDeposit = total >= 30;
    const amountToPay = isDeposit ? total * 0.5 : total;

    const paymentDetails = document.getElementById('paymentDetails');
    const policyText = document.getElementById('policyText');

    if (paymentDetails) {
      paymentDetails.innerHTML = `
        <p style="font-size:1rem; color:var(--text-mid); margin:0 0 0.5rem;">Order Total</p>
        <p style="font-size:1.8rem; color:var(--navy); font-weight:800; margin:0 0 0.3rem;">$${total.toFixed(2)}</p>
        <p style="font-size:1rem; color:var(--text-mid); margin:0 0 0.3rem;">Pay Now</p>
        <p style="font-size:2rem; color:var(--gold); font-weight:800; margin:0;">$${amountToPay.toFixed(2)}</p>
      `;
    }

    if (policyText) {
      policyText.textContent = isDeposit
        ? `50% deposit required now. Remaining $${(total * 0.5).toFixed(2)} due on delivery.`
        : `Full payment required for orders under $30.`;
    }

    document.getElementById('paymentModal')?.classList.add('active');
  });

  // Close payment modal
  document.getElementById('paymentModalClose')?.addEventListener('click', () => {
    document.getElementById('paymentModal')?.classList.remove('active');
  });

  // Confirm payment — verify transaction ID then show Submit Order button
  document.getElementById('confirmPaymentBtn')?.addEventListener('click', async () => {
    const txnId = (document.getElementById('txnId') as HTMLInputElement).value.trim();
    const btn = document.getElementById('confirmPaymentBtn') as HTMLButtonElement;
    
    btn.textContent = '⏳ Verifying payment...';
    btn.disabled = true;

    try {
      const res = await fetch(
        'https://rehvwvujuamehoanfomj.supabase.co/functions/v1/verify-payment',
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ transactionId: txnId })
        }
      );

      const data = await res.json();

      if (data.valid) {
        document.getElementById('paymentModal')?.classList.remove('active');
        document.getElementById('createOrderBtn')!.style.display = 'none';
        const submitBtn = document.getElementById('submitOrderBtn')!;
        submitBtn.style.display = 'block';
        submitBtn.setAttribute('data-txn', txnId);
      } else {
        alert('❌ ' + (data.error || 'Invalid transaction ID. Please check and try again.'));
        btn.textContent = '✅ I Have Paid — Submit My Order';
        btn.disabled = false;
      }
    } catch (err) {
      alert('❌ Verification failed. Please try again.');
      btn.textContent = '✅ I Have Paid — Submit My Order';
      btn.disabled = false;
    }
  });

  // Submit Order — save to Google Sheets + Supabase
  document.getElementById('submitOrderBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('submitOrderBtn') as HTMLButtonElement;
    btn.textContent = '⏳ Submitting your order...';
    btn.disabled = true;

    const total = currentTotal;
    const isDeposit = total >= 30;
    const amountPaid = isDeposit ? total * 0.5 : total;

    // Collect form data
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const topic = (document.getElementById('topic') as HTMLInputElement).value;
    const type = (document.getElementById('type') as HTMLSelectElement).value;
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const service = (document.getElementById('service') as HTMLSelectElement).value;
    const language = (document.getElementById('language') as HTMLSelectElement).value;
    const level = (document.getElementById('level') as HTMLSelectElement).value;
    const pages = (document.getElementById('pages') as HTMLInputElement).value;
    const deadline = (document.getElementById('deadline') as HTMLInputElement).value;
    const instructions = (document.getElementById('instructions') as HTMLTextAreaElement).value;

    // Build addons string
    const addonsList = [];
    if (addons.graphics > 0) addonsList.push(`Graphics x${addons.graphics}`);
    if (addons.sources > 0) addonsList.push(`Sources x${addons.sources}`);
    if (addons.abstract > 0) addonsList.push(`Abstract x${addons.abstract}`);
    addonsList.push('Plagiarism & AI Report (FREE)');
    const addonsStr = addonsList.join(', ');

    const orderData = {
      clientEmail: email,
      topic,
      assignmentType: type,
      subject,
      service,
      language,
      level,
      pages,
      deadline,
      addons: addonsStr,
      totalPrice: `$${total.toFixed(2)}`,
      amountPaid: `$${amountPaid.toFixed(2)}`,
      paymentStatus: isDeposit ? '50% Deposit Paid' : 'Paid in Full',
      instructions
    };

    try {
      // Get order count from Supabase to generate ticket number
      const countRes = await fetch(`${SUPABASE_URL}/rest/v1/orders?select=id`, {
        headers: {
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${currentSession.access_token}`
        }
      });
      const countData = await countRes.json();
      const ticketId = 'T-' + String(1000 + (countData.length || 0));

      // Save to Google Sheets
      await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...orderData, ticketId })
      });

      // Save to Supabase
      if (currentSession) {
        await fetch(`${SUPABASE_URL}/rest/v1/orders`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${currentSession.access_token}`
          },
          body: JSON.stringify({
            order_number: ticketId,
            client_email: email,
            topic,
            assignment_type: type,
            subject,
            pages: parseInt(pages),
            deadline,
            total_amount: total,
            amount_paid: amountPaid,
            payment_status: isDeposit ? '50% Deposit Paid' : 'Paid in Full',
            order_status: 'new',
      instructions,
      transaction_id: document.getElementById('submitOrderBtn')?.getAttribute('data-txn') || ''
    })
        });
      }

      // Redirect to thank you page with ticket number
      window.location.href = `${base}/thankyou/?ticket=${ticketId}`;

    } catch (err) {
      btn.textContent = '❌ Error — please try again';
      btn.disabled = false;
    }
  });

  // Chat popup
  const helpBtn = document.getElementById('helpBtn');
  const chatPopup = document.getElementById('chatPopup');
  const chatClose = document.getElementById('chatClose');
  const chatOverlay = document.getElementById('chatOverlay');
  helpBtn?.addEventListener('click', () => { chatPopup?.classList.add('active'); chatOverlay?.classList.add('active'); });
  chatClose?.addEventListener('click', () => { chatPopup?.classList.remove('active'); chatOverlay?.classList.remove('active'); });
  chatOverlay?.addEventListener('click', () => { chatPopup?.classList.remove('active'); chatOverlay?.classList.remove('active'); });

  const chatTabs = document.querySelectorAll('.chat-tab');
  chatTabs.forEach((tab, index) => {
    tab.addEventListener('click', () => {
      chatTabs.forEach(t => t.classList.remove('chat-tab--active'));
      tab.classList.add('chat-tab--active');
      if (index === 1) {
        chatPopup?.classList.remove('active');
        chatOverlay?.classList.remove('active');
        setTimeout(() => {
          if (typeof (window as any).tidioChatApi !== 'undefined') { (window as any).tidioChatApi.open(); }
        }, 300);
      }
    });
  });

  calculatePrice();
  (window as any).changeAddon = changeAddon;
</script>