---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="My Orders" description="View your orders on ThesisArcPro">

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #c5a059;
    --sidebar-bg: #111827;
    --rail-bg: #0d1117;
    --main-bg: #0f172a;
    --panel-bg: #1e293b;
    --border: rgba(255,255,255,0.08);
    --text: #f1f5f9;
    --text-muted: rgba(255,255,255,0.45);
    --active-blue: #6366f1;
  }

  body {
    font-family: 'Inter', 'Segoe UI', sans-serif;
    background: var(--main-bg);
    color: var(--text);
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  .icon-rail {
    width: 64px;
    background: var(--rail-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0;
    gap: 0.5rem;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
    z-index: 10;
  }

  .rail-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 1.2rem;
    gap: 2px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .rail-icon span.label { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.3px; }
  .rail-icon:hover { color: var(--text); background: rgba(255,255,255,0.06); }
  .rail-icon.active { background: rgba(99,102,241,0.15); color: var(--active-blue); }
  .rail-spacer { flex: 1; }
  .rail-divider { width: 32px; height: 1px; background: var(--border); margin: 0.4rem 0; }

  .rail-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .badge-wrap { position: relative; }
  .badge {
    position: absolute;
    top: 4px; right: 4px;
    width: 16px; height: 16px;
    background: var(--active-blue);
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    color: white;
  }

  .sidebar {
    width: 220px;
    background: var(--sidebar-bg);
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-new-order {
    margin: 0 1rem 1.2rem;
    background: var(--active-blue);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: 0.2s;
    text-decoration: none;
    justify-content: center;
  }

  .sidebar-new-order:hover { background: #4f46e5; }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.2rem; padding: 0 0.5rem; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
  }

  .nav-item:hover { background: rgba(255,255,255,0.05); color: var(--text); }
  .nav-item.active { background: rgba(99,102,241,0.12); color: var(--active-blue); font-weight: 600; }
  .nav-item .icon { font-size: 1rem; width: 20px; text-align: center; }
  .sidebar-divider { height: 1px; background: var(--border); margin: 0.8rem 0.75rem; }

  .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  .main-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .main-header h1 { font-size: 1.5rem; font-weight: 800; color: var(--text); }

  .btn-new-order-main {
    background: var(--panel-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: 0.2s;
    text-decoration: none;
  }

  .btn-new-order-main:hover { background: rgba(255,255,255,0.08); border-color: var(--gold); }

  .tabs-bar {
    display: flex;
    align-items: center;
    padding: 0.8rem 2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .tabs { display: flex; gap: 0.2rem; }

  .tab {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    position: relative;
    top: 1px;
  }

  .tab.active { color: var(--active-blue); border-bottom-color: var(--active-blue); font-weight: 600; }
  .tab:hover:not(.active) { color: var(--text); }

  .tab .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--panel-bg);
    border-radius: 10px;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.1rem 0.45rem;
    margin-left: 0.4rem;
    color: var(--text-muted);
  }

  .tab.active .count { background: rgba(99,102,241,0.2); color: var(--active-blue); }

  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
  }

  .sort-wrap { display: flex; align-items: center; gap: 0.5rem; }
  .sort-label { font-size: 0.82rem; color: var(--text-muted); }

  .sort-select {
    background: var(--panel-bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    font-size: 0.82rem;
    cursor: pointer;
    outline: none;
  }

  .search-wrap { position: relative; width: 220px; }

  .search-icon {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .search-input {
    width: 100%;
    background: var(--panel-bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 0.4rem 0.8rem 0.4rem 2rem;
    font-size: 0.82rem;
    outline: none;
    transition: 0.2s;
  }

  .search-input:focus { border-color: var(--active-blue); }
  .search-input::placeholder { color: var(--text-muted); }
  .orders-area { flex: 1; overflow-y: auto; padding: 1.5rem 2rem 2rem; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 4rem;
    text-align: center;
  }

  .empty-illustration {
    width: 120px;
    height: 120px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    font-size: 3rem;
  }

  .empty-state h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .empty-state p { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }

  .btn-empty-order {
    background: var(--active-blue);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: 0.2s;
    text-decoration: none;
  }

  .btn-empty-order:hover { background: #4f46e5; }

  /* ── ORDER CARDS ── */
  .order-table { display: flex; flex-direction: column; gap: 0.75rem; }

  .order-table-head {
    display: grid;
    grid-template-columns: 1fr 140px 120px;
    padding: 0.5rem 1.5rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .order-table-head > div:nth-child(2),
  .order-table-head > div:nth-child(3) { text-align: right; }

  .order-row {
    display: grid;
    grid-template-columns: 1fr 140px 120px;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.5rem;
    background: #16213e;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .order-row:hover {
    background: #1a2a4a;
    border-color: rgba(99,102,241,0.45);
  }

  .col-topic { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .order-title { font-size: 0.93rem; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .order-meta { display: flex; align-items: center; gap: 0.3rem; font-size: 0.76rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; }
  .meta-dot { color: rgba(255,255,255,0.15); }
  .order-id { color: rgba(255,255,255,0.28); }

  .col-deadline { font-size: 0.82rem; color: var(--text-muted); text-align: right; white-space: nowrap; }
  .col-deadline.overdue { color: #f87171; }
  .col-deadline.urgent { color: #fb923c; }
  .col-deadline.ok { color: #34d399; }

  .col-amount { font-size: 0.9rem; font-weight: 700; color: var(--text); text-align: right; white-space: nowrap; }

  .status-badge {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(251,191,36,0.12);
    color: #fbbf24;
  }

  .status-badge.new { background: rgba(99,102,241,0.15); color: #818cf8; }
  .status-badge.completed { background: rgba(34,197,94,0.12); color: #4ade80; }

  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1rem;
    color: var(--text-muted);
  }

  .spinner {
    width: 36px; height: 36px;
    border: 3px solid rgba(255,255,255,0.08);
    border-top-color: var(--active-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .modal {
    position: fixed; inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .modal.open { display: flex; }
  .modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.65); }

  .modal-box {
    position: relative; z-index: 101;
    background: #1e293b;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
    width: 90%;
    max-width: 520px;
    max-height: 80vh;
    overflow-y: auto;
  }

  .modal-close {
    position: absolute; top: 1rem; right: 1rem;
    background: none; border: none;
    color: var(--text-muted); font-size: 1.2rem;
    cursor: pointer; transition: 0.2s;
  }

  .modal-close:hover { color: var(--text); }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }
</style>

<!-- ICON RAIL -->
<nav class="icon-rail">
  <a class="rail-icon" href={`${base}/`} title="Home">
    <span>🌐</span>
    <span class="label">Home</span>
  </a>
  <a class="rail-icon active" href="#" title="Orders">
    <span>✏️</span>
    <span class="label">Orders</span>
  </a>
  <div class="rail-spacer"></div>
  <div class="rail-divider"></div>
  <div class="rail-bottom">
    <a class="rail-icon" href="#" title="Balance">
      <span>👛</span>
      <span class="label">$0.00</span>
    </a>
    <a class="rail-icon" href={`${base}/contact/`} title="Support">
      <span>🎧</span>
    </a>
    <a class="rail-icon badge-wrap" href="#" title="Notifications">
      <span>🔔</span>
      <span class="badge" id="notifBadge">1</span>
    </a>
    <a class="rail-icon" href="#" title="Profile">
      <span>👤</span>
    </a>
  </div>
</nav>

<!-- SIDEBAR -->
<aside class="sidebar">
  <a href={`${base}/contact/`} class="sidebar-new-order">＋ New order</a>
  <nav class="sidebar-nav">
    <a class="nav-item active" href="#">
      <span class="icon">📁</span> My Orders
    </a>
    <a class="nav-item" href="#" id="writersLink">
      <span class="icon">👥</span> Writers
    </a>
    <a class="nav-item" href="#" id="chatsLink">
      <span class="icon">💬</span> Chats
    </a>
  </nav>
  <div class="sidebar-divider"></div>
  <nav class="sidebar-nav">
    <a class="nav-item" href="#" id="logoutBtn">
      <span class="icon">🚪</span> Logout
    </a>
  </nav>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="main-header">
    <h1>My Orders</h1>
    <a href={`${base}/contact/`} class="btn-new-order-main">New order ＋</a>
  </div>

  <div class="tabs-bar">
    <div class="tabs">
      <button class="tab active" data-tab="in_progress">
        Active <span class="count" id="activeCount">0</span>
      </button>
      <button class="tab" data-tab="completed">
        Closed <span class="count" id="closedCount">0</span>
      </button>
    </div>
  </div>

  <div class="controls-bar">
    <div class="sort-wrap">
      <span class="sort-label">Sort by</span>
      <select class="sort-select" id="sortSelect">
        <option>Deadline, latest</option>
        <option>Deadline, earliest</option>
        <option>Newest first</option>
      </select>
    </div>
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" type="text" placeholder="Search" id="searchInput" />
    </div>
  </div>

  <div class="orders-area">
    <div class="loading-state" id="loadingState">
      <div class="spinner"></div>
      <p>Loading your orders...</p>
    </div>

    <div class="empty-state" id="emptyState" style="display:none;">
      <div class="empty-illustration">📄</div>
      <h3>You have no active orders</h3>
      <p>Place your first order and track it right here.</p>
      <a href={`${base}/contact/`} class="btn-empty-order">New order ＋</a>
    </div>

    <div class="order-table" id="orderTable" style="display:none;">
      <div class="order-table-head">
        <div>Topic</div>
        <div>Time Left</div>
        <div>Amount Paid</div>
      </div>
      <div id="ordersList"></div>
    </div>
  </div>
</main>

<!-- MODAL -->
<div class="modal" id="detailModal">
  <div class="modal-overlay" id="modalOverlay"></div>
  <div class="modal-box">
    <button class="modal-close" id="modalClose">✕</button>
    <div id="modalContent"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'in_progress';

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.replace(`${base}/login/`); return; }
    await loadClientId(session);
    await loadOrders(session);
  }

  async function loadClientId(session: any) {
    const { data } = await supabase.from('profiles').select('client_id').eq('id', session.user.id).single();
    const display = document.getElementById('clientIdDisplay');
    if (display && data?.client_id) display.textContent = '#' + data.client_id;
  }

  async function loadOrders(session: any) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?client_email=eq.${session.user.email}&order=created_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
      );
      allOrders = await res.json();
      updateCounts();
      renderOrders();
    } catch (err) {
      console.error(err);
      document.getElementById('loadingState')!.style.display = 'none';
      document.getElementById('emptyState')!.style.display = 'flex';
    }
  }

  function updateCounts() {
    const active = allOrders.filter((o: any) => o.order_status === 'in_progress' || o.order_status === 'new').length;
    const closed = allOrders.filter((o: any) => o.order_status === 'completed').length;
    document.getElementById('activeCount')!.textContent = String(active);
    document.getElementById('closedCount')!.textContent = String(closed);
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: '' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: `⚠️ ${Math.abs(days)}d overdue`, cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function statusClass(status: string) {
    if (status === 'new') return 'new';
    if (status === 'completed') return 'completed';
    return '';
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState')!;
    const empty = document.getElementById('emptyState')!;
    const table = document.getElementById('orderTable')!;
    const list = document.getElementById('ordersList')!;
    const search = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    loading.style.display = 'none';

    let filtered = allOrders.filter((o: any) =>
      currentTab === 'in_progress'
        ? (o.order_status === 'in_progress' || o.order_status === 'new')
        : o.order_status === 'completed'
    );

    if (search) {
      filtered = filtered.filter((o: any) =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.assignment_type || '').toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      empty.style.display = 'flex';
      table.style.display = 'none';
      return;
    }

    empty.style.display = 'none';
    table.style.display = 'flex';

    list.innerHTML = filtered.map((o: any) => {
      const dl = deadlineInfo(o.deadline);
      return `
        <div class="order-row" data-id="${o.id}">
          <div class="col-topic">
            <div class="order-title">${o.topic || '(no topic)'}</div>
            <div class="order-meta">
              <span class="status-badge ${statusClass(o.order_status)}">${(o.order_status || '').replace(/_/g, ' ')}</span>
              <span class="meta-dot">·</span>
              <span>${o.pages || 1} pg</span>
              <span class="meta-dot">·</span>
              <span class="order-id">ID ${o.order_number || o.id}</span>
            </div>
          </div>
          <div class="col-deadline ${dl.cls}">${dl.text}</div>
          <div class="col-amount">$${Number(o.amount_paid || 0).toFixed(2)}</div>
        </div>
      `;
    }).join('');

    list.querySelectorAll('.order-row').forEach(row => {
      row.addEventListener('click', () => {
        const order = allOrders.find((o: any) => o.id === (row as HTMLElement).dataset.id);
        if (order) showModal(order);
      });
    });
  }

  function showModal(order: any) {
    const dl = deadlineInfo(order.deadline);
    const startDate = new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    const dueDate = order.deadline ? new Date(order.deadline).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'N/A';

    document.getElementById('modalContent')!.innerHTML = `
      <div style="font-size:1.15rem;font-weight:800;margin-bottom:0.5rem;color:var(--text);">${order.topic}</div>
      <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);margin-bottom:1.5rem;">ID ${order.order_number || order.id}</div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(255,255,255,0.07);">
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Status</div>
          <div style="font-weight:600;text-transform:capitalize;">${(order.order_status || '').replace(/_/g, ' ')}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Started</div>
          <div style="font-weight:600;">${startDate}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Deadline</div>
          <div style="font-weight:600;">${dueDate}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Time Left</div>
          <div style="font-weight:600;">${dl.text}</div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(255,255,255,0.07);">
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Pages</div>
          <div style="font-weight:600;">${order.pages || 1}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Type</div>
          <div style="font-weight:600;">${order.assignment_type || 'Essay'}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Subject</div>
          <div style="font-weight:600;">${order.subject || '—'}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Level</div>
          <div style="font-weight:600;">${order.education_level || '—'}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Amount Paid</div>
          <div style="font-weight:600;color:#4ade80;">$${Number(order.amount_paid || 0).toFixed(2)}</div>
        </div>
        <div>
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:0.5px;">Total</div>
          <div style="font-weight:600;">$${Number(order.total_amount || 0).toFixed(2)}</div>
        </div>
      </div>

      ${order.instructions ? `
        <div style="margin-bottom:1.5rem;">
          <div style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.5px;">Instructions</div>
          <div style="font-size:0.85rem;color:rgba(255,255,255,0.7);line-height:1.6;max-height:150px;overflow-y:auto;">${order.instructions}</div>
        </div>
      ` : ''}

      ${order.file_url
        ? `<a href="${order.file_url}" target="_blank" style="display:inline-block;background:#c5a059;color:#0f172a;padding:0.7rem 1.5rem;border-radius:6px;text-decoration:none;font-weight:700;">📥 Download Work</a>`
        : `<div style="text-align:center;padding:1rem;background:rgba(255,255,255,0.04);border-radius:6px;color:rgba(255,255,255,0.4);font-size:0.85rem;">⏳ Work in progress...</div>`
      }
    `;

    document.getElementById('detailModal')!.classList.add('open');
  }

  function closeModal() {
    document.getElementById('detailModal')!.classList.remove('open');
  }

  document.getElementById('modalClose')!.addEventListener('click', closeModal);
  document.getElementById('modalOverlay')!.addEventListener('click', closeModal);

  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'in_progress';
      renderOrders();
    });
  });

  document.getElementById('searchInput')!.addEventListener('input', renderOrders);

  document.getElementById('logoutBtn')!.addEventListener('click', async (e) => {
    e.preventDefault();
    await supabase.auth.signOut();
    window.location.href = `${base}/login/`;
  });

  init();
</script>
</BaseLayout>