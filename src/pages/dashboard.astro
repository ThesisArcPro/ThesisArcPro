---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="My Orders" description="View your orders on ThesisArcPro">

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #c5a059;
    --sidebar-bg: #111827;
    --rail-bg: #0d1117;
    --main-bg: #0f172a;
    --panel-bg: #1e293b;
    --border: rgba(255,255,255,0.08);
    --text: #f1f5f9;
    --text-muted: rgba(255,255,255,0.45);
    --active-blue: #6366f1;
  }

  body {
    font-family: 'Inter', 'Segoe UI', sans-serif;
    background: var(--main-bg);
    color: var(--text);
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  .icon-rail {
    width: 64px;
    background: var(--rail-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 1rem 0;
    gap: 0.5rem;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
    z-index: 10;
  }

  .rail-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 1.2rem;
    gap: 2px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .rail-icon span.label { font-size: 0.55rem; font-weight: 600; letter-spacing: 0.3px; }
  .rail-icon:hover { color: var(--text); background: rgba(255,255,255,0.06); }
  .rail-icon.active { background: rgba(99,102,241,0.15); color: var(--active-blue); }
  .rail-spacer { flex: 1; }
  .rail-divider { width: 32px; height: 1px; background: var(--border); margin: 0.4rem 0; }

  .rail-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .badge-wrap { position: relative; }
  .badge {
    position: absolute;
    top: 4px; right: 4px;
    width: 16px; height: 16px;
    background: var(--active-blue);
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    color: white;
  }

  .sidebar {
    width: 220px;
    background: var(--sidebar-bg);
    display: flex;
    flex-direction: column;
    padding: 1rem 0;
    border-right: 1px solid var(--border);
    flex-shrink: 0;
  }

  .sidebar-new-order {
    margin: 0 1rem 1.2rem;
    background: var(--active-blue);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: 0.2s;
    text-decoration: none;
    justify-content: center;
  }

  .sidebar-new-order:hover { background: #4f46e5; }
  .sidebar-nav { display: flex; flex-direction: column; gap: 0.2rem; padding: 0 0.5rem; }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.75rem;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.88rem;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
  }

  .nav-item:hover { background: rgba(255,255,255,0.05); color: var(--text); }
  .nav-item.active { background: rgba(99,102,241,0.12); color: var(--active-blue); font-weight: 600; }
  .nav-item .icon { font-size: 1rem; width: 20px; text-align: center; }
  .sidebar-divider { height: 1px; background: var(--border); margin: 0.8rem 0.75rem; }

  .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  .main-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .main-header h1 { font-size: 1.5rem; font-weight: 800; color: var(--text); }

  .btn-new-order-main {
    background: var(--panel-bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: 0.2s;
    text-decoration: none;
  }

  .btn-new-order-main:hover { background: rgba(255,255,255,0.08); border-color: var(--gold); }

  .tabs-bar {
    display: flex;
    align-items: center;
    padding: 0.8rem 2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .tabs { display: flex; gap: 0.2rem; }

  .tab {
    background: none;
    border: none;
    color: var(--text-muted);
    padding: 0.6rem 1rem;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
    position: relative;
    top: 1px;
  }

  .tab.active { color: var(--active-blue); border-bottom-color: var(--active-blue); font-weight: 600; }
  .tab:hover:not(.active) { color: var(--text); }

  .tab .count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--panel-bg);
    border-radius: 10px;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.1rem 0.45rem;
    margin-left: 0.4rem;
    color: var(--text-muted);
  }

  .tab.active .count { background: rgba(99,102,241,0.2); color: var(--active-blue); }

  .controls-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
  }

  .sort-wrap { display: flex; align-items: center; gap: 0.5rem; }
  .sort-label { font-size: 0.82rem; color: var(--text-muted); }

  .sort-select {
    background: var(--panel-bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 0.4rem 0.8rem;
    font-size: 0.82rem;
    cursor: pointer;
    outline: none;
  }

  .search-wrap { position: relative; width: 220px; }

  .search-icon {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .search-input {
    width: 100%;
    background: var(--panel-bg);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 0.4rem 0.8rem 0.4rem 2rem;
    font-size: 0.82rem;
    outline: none;
    transition: 0.2s;
  }

  .search-input:focus { border-color: var(--active-blue); }
  .search-input::placeholder { color: var(--text-muted); }
  .orders-area { flex: 1; overflow-y: auto; padding: 1.5rem 2rem 2rem; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 4rem;
    text-align: center;
  }

  .empty-illustration {
    width: 120px;
    height: 120px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    font-size: 3rem;
  }

  .empty-state h3 { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
  .empty-state p { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.5rem; }

  .btn-empty-order {
    background: var(--active-blue);
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1.5rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: 0.2s;
    text-decoration: none;
  }

  .btn-empty-order:hover { background: #4f46e5; }

  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 1rem;
    color: var(--text-muted);
  }

  .spinner {
    width: 36px; height: 36px;
    border: 3px solid rgba(255,255,255,0.08);
    border-top-color: var(--active-blue);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .modal {
    position: fixed; inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .modal.open { display: flex; }
  .modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.65); }

  .modal-box {
    position: relative; z-index: 101;
    background: #1e293b;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem;
    width: 90%;
    max-width: 560px;
    max-height: 82vh;
    overflow-y: auto;
  }

  .modal-close {
    position: absolute; top: 1rem; right: 1rem;
    background: none; border: none;
    color: var(--text-muted); font-size: 1.2rem;
    cursor: pointer; transition: 0.2s;
    z-index: 2;
  }

  .modal-close:hover { color: var(--text); }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }
</style>

<style is:global>
  /* These rules target content that JavaScript injects at runtime (order rows
     and modal contents). They must be global because Astro's scoped styles
     don't reach innerHTML content, and CSS variables don't resolve there. */

  /* ── ORDER CARDS ── */
  .order-table { display: flex; flex-direction: column; gap: 0.5rem; }

  .order-table-head {
    display: flex;
    justify-content: space-between;
    padding: 0.4rem 1.2rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .order-table-head-right { display: flex; gap: 3rem; }

  .order-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: #141e35;
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.18s;
  }

  .order-row:hover { background: #1a2a4a; border-color: rgba(99,102,241,0.45); }

  .col-left { display: flex; flex-direction: column; gap: 0.35rem; flex: 1; min-width: 0; overflow: hidden; }
  .order-title { font-size: 0.93rem; font-weight: 600; color: #f1f5f9; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .order-meta { display: flex; align-items: center; gap: 0.35rem; font-size: 0.76rem; color: rgba(255,255,255,0.45); white-space: nowrap; overflow: hidden; }
  .meta-dot { color: rgba(255,255,255,0.15); }
  .order-id { color: rgba(255,255,255,0.28); }

  .col-right { display: flex; align-items: center; gap: 2.5rem; flex-shrink: 0; }
  .col-deadline { font-size: 0.82rem; color: rgba(255,255,255,0.45); white-space: nowrap; min-width: 90px; text-align: right; }
  .col-deadline.overdue { color: #f87171; }
  .col-deadline.urgent { color: #fb923c; }
  .col-deadline.ok { color: #34d399; }
  .col-amount { font-size: 0.9rem; font-weight: 700; color: #f1f5f9; white-space: nowrap; min-width: 70px; text-align: right; }

  .status-badge {
    display: inline-block;
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(251,191,36,0.12);
    color: #fbbf24;
  }

  .status-badge.new { background: rgba(99,102,241,0.15); color: #818cf8; }
  .status-badge.in_progress { background: rgba(251,191,36,0.15); color: #fbbf24; }
  .status-badge.in_review { background: rgba(56,138,221,0.18); color: #60a5fa; }
  .status-badge.completed { background: rgba(34,197,94,0.12); color: #4ade80; }
  .status-badge.revision { background: rgba(168,85,247,0.18); color: #c084fc; }
  .status-badge.cancelled { background: rgba(239,68,68,0.16); color: #f87171; }

  /* ── ORDER DETAIL MODAL ── */
  .om-header { margin-bottom: 1.2rem; padding-right: 2rem; }
  .om-title { font-size: 1.15rem; font-weight: 800; color: #f1f5f9; line-height: 1.3; }
  .om-id { font-size: 0.75rem; color: rgba(255,255,255,0.35); margin-top: 0.3rem; }

  .om-tabs {
    display: flex;
    gap: 0.3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 1.3rem;
  }

  .om-tab {
    background: none;
    border: none;
    color: rgba(255,255,255,0.45);
    padding: 0.55rem 0.9rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    position: relative;
    top: 1px;
    transition: all 0.2s;
  }

  .om-tab:hover:not(.om-tab--active) { color: #f1f5f9; }
  .om-tab--active { color: #818cf8; border-bottom-color: #6366f1; }

  .om-panel { display: none; }
  .om-panel--active { display: block; }

  .om-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    margin-bottom: 1.3rem;
    padding-bottom: 1.3rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .om-grid:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .om-label {
    font-size: 0.66rem;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .om-value { font-weight: 600; font-size: 0.88rem; color: #f1f5f9; text-transform: capitalize; }
  .om-value.green { color: #4ade80; }

  .om-desc-label {
    font-size: 0.66rem;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .om-desc {
    font-size: 0.83rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-height: 220px;
    overflow-y: auto;
    padding-right: 0.5rem;
    white-space: pre-wrap;
  }

  .om-download {
    display: inline-block;
    background: #c5a059;
    color: #0f172a;
    padding: 0.7rem 1.5rem;
    border: none;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    cursor: pointer;
  }
  .om-download:hover { background: #d4b06a; }
  .om-download:disabled { opacity: 0.6; cursor: not-allowed; }
  .om-dl-note { color: #f87171; font-size: 0.8rem; margin-top: 0.6rem; }

  .om-nofile {
    text-align: center;
    padding: 1.4rem;
    background: rgba(255,255,255,0.03);
    border-radius: 8px;
    color: rgba(255,255,255,0.4);
    font-size: 0.85rem;
  }
</style>

<!-- SIDEBAR -->
<aside class="sidebar">
  <a href={`${base}/contact/`} class="sidebar-new-order">＋ New order</a>
  <nav class="sidebar-nav">
    <a class="nav-item active" href="#">
      <span class="icon">📁</span> My Orders
    </a>
    <a class="nav-item" href="#" id="writersLink">
      <span class="icon">👥</span> Writers
    </a>
    <a class="nav-item" href="#" id="chatsLink">
      <span class="icon">💬</span> Chats
    </a>
  </nav>
  <div class="sidebar-divider"></div>
  <nav class="sidebar-nav">
    <a class="nav-item" href="#" id="logoutBtn">
      <span class="icon">🚪</span> Logout
    </a>
  </nav>
</aside>

<!-- MAIN -->
<main class="main">
  <div class="main-header">
    <h1>My Orders</h1>
    <a href={`${base}/contact/`} class="btn-new-order-main">New order ＋</a>
  </div>

  <div class="tabs-bar">
    <div class="tabs">
      <button class="tab active" data-tab="in_progress">
        In Progress <span class="count" id="count_in_progress">0</span>
      </button>
      <button class="tab" data-tab="in_review">
        In Review <span class="count" id="count_in_review">0</span>
      </button>
      <button class="tab" data-tab="revision">
        In Revision <span class="count" id="count_revision">0</span>
      </button>
      <button class="tab" data-tab="completed">
        Completed <span class="count" id="count_completed">0</span>
      </button>
      <button class="tab" data-tab="cancelled">
        Cancelled <span class="count" id="count_cancelled">0</span>
      </button>
    </div>
  </div>

  <div class="controls-bar">
    <div class="sort-wrap">
      <span class="sort-label">Sort by</span>
      <select class="sort-select" id="sortSelect">
        <option>Deadline, latest</option>
        <option>Deadline, earliest</option>
        <option>Newest first</option>
      </select>
    </div>
    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input class="search-input" type="text" placeholder="Search" id="searchInput" />
    </div>
  </div>

  <div class="orders-area">
    <div class="loading-state" id="loadingState">
      <div class="spinner"></div>
      <p>Loading your orders...</p>
    </div>

    <div class="empty-state" id="emptyState" style="display:none;">
      <div class="empty-illustration">📄</div>
      <h3 id="emptyHeading">You have no active orders</h3>
      <p>Place your first order and track it right here.</p>
      <a href={`${base}/contact/`} class="btn-empty-order">New order ＋</a>
    </div>

    <div class="order-table" id="orderTable" style="display:none;">
      <div class="order-table-head">
        <div>Topic</div>
        <div class="order-table-head-right">
          <span>Time Left</span>
          <span>Amount Paid</span>
        </div>
      </div>
      <div id="ordersList"></div>
    </div>
  </div>
</main>

<!-- MODAL -->
<div class="modal" id="detailModal">
  <div class="modal-overlay" id="modalOverlay"></div>
  <div class="modal-box">
    <button class="modal-close" id="modalClose">✕</button>
    <div id="modalContent"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'in_progress';

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.replace(`${base}/login/`); return; }
    await loadOrders(session);
  }

  async function loadOrders(session: any) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?client_email=eq.${session.user.email}&order=created_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
      );
      allOrders = await res.json();
      updateCounts();
      renderOrders();
    } catch (err) {
      console.error(err);
      document.getElementById('loadingState')!.style.display = 'none';
      document.getElementById('emptyState')!.style.display = 'flex';
    }
  }

  function updateCounts() {
    // 'new' orders are counted under In Progress
    const countFor = (tab: string) => allOrders.filter((o: any) => {
      const s = o.order_status;
      if (tab === 'in_progress') return s === 'in_progress' || s === 'new';
      return s === tab;
    }).length;

    const set = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(val);
    };
    set('count_in_progress', countFor('in_progress'));
    set('count_in_review', countFor('in_review'));
    set('count_revision', countFor('revision'));
    set('count_completed', countFor('completed'));
    set('count_cancelled', countFor('cancelled'));
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: '' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: `⚠️ ${Math.abs(days)}d overdue`, cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function statusClass(status: string) {
    const known = ['new','in_progress','in_review','completed','revision','cancelled'];
    return known.includes(status) ? status : 'new';
  }

  // Escape user-supplied text before injecting into innerHTML
  function esc(v: any) {
    return String(v ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState')!;
    const empty = document.getElementById('emptyState')!;
    const table = document.getElementById('orderTable')!;
    const list = document.getElementById('ordersList')!;
    const search = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    loading.style.display = 'none';

    let filtered = allOrders.filter((o: any) =>
      currentTab === 'in_progress'
        ? (o.order_status === 'in_progress' || o.order_status === 'new')
        : o.order_status === currentTab
    );

    if (search) {
      filtered = filtered.filter((o: any) =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.assignment_type || '').toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      empty.style.display = 'flex';
      table.style.display = 'none';
      const emptyHeading = document.getElementById('emptyHeading');
      if (emptyHeading) emptyHeading.textContent = 'No orders in this view';
      return;
    }

    empty.style.display = 'none';
    table.style.display = 'flex';
    list.style.display = 'flex';
    list.style.flexDirection = 'column';
    list.style.gap = '0.5rem';

    list.innerHTML = filtered.map((o: any) => {
      const dl = deadlineInfo(o.deadline);
      return `
        <div class="order-row" data-id="${esc(o.id)}">
          <div class="col-left">
            <div class="order-title">${esc(o.topic || '(no topic)')}</div>
            <div class="order-meta">
              <span class="status-badge ${statusClass(o.order_status)}">${esc((o.order_status||'').replace(/_/g,' '))}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.pages||1)} page${o.pages>1?'s':''}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.assignment_type||'Essay')}</span>
              <span class="meta-dot">·</span>
              <span class="order-id">ID ${esc(o.order_number||o.id)}</span>
            </div>
          </div>
          <div class="col-right">
            <div class="col-deadline ${dl.cls}">${dl.text}</div>
            <div class="col-amount">$${Number(o.amount_paid||0).toFixed(2)}</div>
          </div>
        </div>
      `;
    }).join('');

    list.querySelectorAll('.order-row').forEach(row => {
      row.addEventListener('click', () => {
        const id = (row as HTMLElement).dataset.id;
        const order = allOrders.find((o: any) => String(o.id) === id);
        if (order) showModal(order);
      });
    });
  }

  function showModal(order: any) {
    const dl = deadlineInfo(order.deadline);
    const startDate = order.created_at
      ? new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
      : '—';
    const dueDate = order.deadline
      ? new Date(order.deadline).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
      : '—';

    const total = Number(order.total_amount || 0);
    const paid = Number(order.amount_paid || 0);
    const balance = Math.max(total - paid, 0);

    const field = (label: string, value: string, extraClass = '') =>
      `<div><div class="om-label">${label}</div><div class="om-value ${extraClass}">${value}</div></div>`;

    document.getElementById('modalContent')!.innerHTML = `
      <div class="om-header">
        <div class="om-title">${esc(order.topic || '(no topic)')}</div>
        <div class="om-id">ID ${esc(order.order_number || order.id)}</div>
      </div>

      <div class="om-tabs">
        <button class="om-tab om-tab--active" data-mtab="general">General</button>
        <button class="om-tab" data-mtab="instructions">Instructions</button>
        <button class="om-tab" data-mtab="files">Files</button>
      </div>

      <!-- GENERAL -->
      <div class="om-panel om-panel--active" data-mpanel="general">
        <div class="om-grid">
          ${field('Status', esc((order.order_status || '—').replace(/_/g,' ')))}
          ${field('Payment', esc(order.payment_status || '—'))}
          ${field('Started', esc(startDate))}
          ${field('Time Left', dl.text)}
          ${field('Total', `$${total.toFixed(2)}`)}
          ${field('Amount Paid', `$${paid.toFixed(2)}`, 'green')}
          ${field('Balance Due', `$${balance.toFixed(2)}`)}
          ${field('Deadline', esc(dueDate))}
        </div>
      </div>

      <!-- INSTRUCTIONS -->
      <div class="om-panel" data-mpanel="instructions">
        <div class="om-grid">
          ${field('Type', esc(order.assignment_type || '—'))}
          ${field('Pages', esc(order.pages || '—'))}
          ${field('Education level', esc(order.education_level || '—'))}
          ${field('Subject', esc(order.subject || '—'))}
          ${field('Language', esc(order.language || '—'))}
          ${field('Service', esc(order.service || '—'))}
        </div>
        <div>
          <div class="om-desc-label">Description</div>
          <div class="om-desc">${order.instructions ? esc(order.instructions) : 'No description provided.'}</div>
        </div>
      </div>

      <!-- FILES -->
      <div class="om-panel" data-mpanel="files">
        ${order.file_url
          ? `<button class="om-download" id="downloadBtn" data-path="${esc(order.file_url)}">📥 Download completed work</button>
             <div class="om-dl-note" id="dlNote"></div>`
          : `<div class="om-nofile">Your file will appear here once the work is delivered.</div>`
        }
      </div>
    `;

    // Signed download — generate a temporary link on click (private bucket)
    const downloadBtn = document.getElementById('downloadBtn');
    if (downloadBtn) {
      downloadBtn.addEventListener('click', async () => {
        const path = (downloadBtn as HTMLElement).dataset.path || '';
        const note = document.getElementById('dlNote');
        (downloadBtn as HTMLButtonElement).disabled = true;
        downloadBtn.textContent = '⏳ Preparing download…';
        try {
          const { data, error } = await supabase
            .storage
            .from('completed-files')
            .createSignedUrl(path, 120);
          if (error || !data?.signedUrl) throw error || new Error('No URL');
          window.open(data.signedUrl, '_blank');
          downloadBtn.textContent = '📥 Download completed work';
          (downloadBtn as HTMLButtonElement).disabled = false;
        } catch (err) {
          console.error(err);
          downloadBtn.textContent = '📥 Download completed work';
          (downloadBtn as HTMLButtonElement).disabled = false;
          if (note) note.textContent = 'Could not prepare the download. Please try again or contact support.';
        }
      });
    }

    // Tab switching inside the modal
    const content = document.getElementById('modalContent')!;
    content.querySelectorAll('.om-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const which = (tab as HTMLElement).dataset.mtab;
        content.querySelectorAll('.om-tab').forEach(t => t.classList.remove('om-tab--active'));
        content.querySelectorAll('.om-panel').forEach(p => p.classList.remove('om-panel--active'));
        tab.classList.add('om-tab--active');
        content.querySelector(`.om-panel[data-mpanel="${which}"]`)?.classList.add('om-panel--active');
      });
    });

    document.getElementById('detailModal')!.classList.add('open');
  }

  function closeModal() {
    document.getElementById('detailModal')!.classList.remove('open');
  }

  document.getElementById('modalClose')!.addEventListener('click', closeModal);
  document.getElementById('modalOverlay')!.addEventListener('click', closeModal);

  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'in_progress';
      renderOrders();
    });
  });

  document.getElementById('searchInput')!.addEventListener('input', renderOrders);

  document.getElementById('logoutBtn')!.addEventListener('click', async (e) => {
    e.preventDefault();
    await supabase.auth.signOut();
    window.location.href = `${base}/login/`;
  });

  init();
</script>
</BaseLayout>
