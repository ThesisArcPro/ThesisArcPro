<script>
  import { supabase } from '../lib/supabase.js';

  const base = '';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'in_progress';
  let currentSession: any = null;
  let myClientId: string | null = null;

  // Track the review popup state
  let reviewOrderNumber = '';
  let reviewClientEmail = '';
  let reviewClientId = '';
  let selectedRating = 0;

  // ── TEMPORARY DEBUG HELPERS (remove once the mobile loading issue is fixed) ──
  function setStatus(text: string) {
    const p = document.querySelector('#loadingState p');
    if (p) p.textContent = text;
  }

  function showDebugError(err: any) {
    console.error(err);
    const loading = document.getElementById('loadingState');
    if (loading) {
      loading.innerHTML = `
        <div style="max-width:480px;text-align:left;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;padding:1rem;color:#f87171;font-size:0.78rem;font-family:monospace;white-space:pre-wrap;word-break:break-word;">
⚠️ Debug error:
${String(err?.message || err)}
        </div>`;
    }
  }

  function withTimeout<T>(promise: Promise<T>, ms: number, label: string): Promise<T> {
    return Promise.race([
      promise,
      new Promise<T>((_, reject) =>
        setTimeout(() => reject(new Error(`${label} timed out after ${ms / 1000}s — likely a hang, not a thrown error`)), ms)
      )
    ]);
  }

  window.addEventListener('error', (e) => showDebugError((e as ErrorEvent).error || (e as ErrorEvent).message));
  window.addEventListener('unhandledrejection', (e) => showDebugError((e as PromiseRejectionEvent).reason));
  // ── END DEBUG HELPERS ──

  async function init() {
    try {
      setStatus('Checking your login…');
      const { data: { session } } = await withTimeout(supabase.auth.getSession(), 10000, 'Session check');
      if (!session) { window.location.replace(`${base}/login/`); return; }
      currentSession = session;
      // Look up this client's own client_id from their profile (for reviews)
      try {
        const pr = await fetch(
          `${SUPABASE_URL}/rest/v1/profiles?email=eq.${encodeURIComponent(session.user.email || '')}&select=client_id`,
          { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
        );
        const pdata = await pr.json();
        myClientId = pdata[0]?.client_id || null;
        const clientIdEl = document.getElementById('clientIdDisplay');
        if (clientIdEl && myClientId) clientIdEl.textContent = '#' + myClientId;
      } catch (e) { console.warn('Could not load client_id', e); }
      await loadOrders(session);
    } catch (err) {
      showDebugError(err);
    }
  }

  async function loadOrders(session: any) {
    try {
      setStatus('Fetching your orders…');
      const res = await withTimeout(
        fetch(
          `${SUPABASE_URL}/functions/v1/get-orders`,
          { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
        ),
        10000,
        'Orders fetch'
      );
      const json = await res.json();
      if (!res.ok) throw new Error(json.error || `Orders request failed (${res.status})`);
      allOrders = json.orders;
      updateCounts();
      renderOrders();
    } catch (err) {
      showDebugError(err);
    }
  }

  function updateCounts() {
    const countFor = (tab: string) => allOrders.filter((o: any) => {
      const s = o.order_status;
      if (tab === 'in_progress') return s === 'in_progress' || s === 'new';
      return s === tab;
    }).length;

    const set = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(val);
    };
    set('count_in_progress', countFor('in_progress'));
    set('count_in_review', countFor('in_review'));
    set('count_revision', countFor('revision'));
    set('count_completed', countFor('completed'));
    set('count_cancelled', countFor('cancelled'));
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: '' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: `⚠️ ${Math.abs(days)}d overdue`, cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function statusClass(status: string) {
    const known = ['new','in_progress','in_review','completed','revision','cancelled'];
    return known.includes(status) ? status : 'new';
  }

  function esc(v: any) {
    return String(v ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState')!;
    const empty = document.getElementById('emptyState')!;
    const table = document.getElementById('orderTable')!;
    const list = document.getElementById('ordersList')!;
    const search = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    loading.style.display = 'none';

    let filtered = allOrders.filter((o: any) =>
      currentTab === 'in_progress'
        ? (o.order_status === 'in_progress' || o.order_status === 'new')
        : o.order_status === currentTab
    );

    if (search) {
      filtered = filtered.filter((o: any) =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.assignment_type || '').toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      empty.style.display = 'flex';
      table.style.display = 'none';
      const emptyHeading = document.getElementById('emptyHeading');
      if (emptyHeading) emptyHeading.textContent = 'No orders in this view';
      return;
    }

    empty.style.display = 'none';
    table.style.display = 'flex';
    list.style.display = 'flex';
    list.style.flexDirection = 'column';
    list.style.gap = '0.5rem';

    list.innerHTML = filtered.map((o: any) => {
      const dl = deadlineInfo(o.deadline);
      return `
        <div class="order-row" data-id="${esc(o.id)}">
          <div class="col-left">
            <div class="order-title">${esc(o.topic || '(no topic)')}</div>
            <div class="order-meta">
              <span class="status-badge ${statusClass(o.order_status)}">${esc((o.order_status||'').replace(/_/g,' '))}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.pages||1)} page${o.pages>1?'s':''}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.assignment_type||'Essay')}</span>
              <span class="meta-dot">·</span>
              <span class="order-id">ID ${esc(o.order_number||o.id)}</span>
            </div>
          </div>
          <div class="col-right">
            <div class="col-deadline ${dl.cls}">${dl.text}</div>
            <div class="col-amount">$${Number(o.amount_paid||0).toFixed(2)}</div>
          </div>
        </div>
      `;
    }).join('');

    list.querySelectorAll('.order-row').forEach(row => {
      row.addEventListener('click', () => {
        const id = (row as HTMLElement).dataset.id;
        const order = allOrders.find((o: any) => String(o.id) === id);
        if (order) showModal(order);
      });
    });
