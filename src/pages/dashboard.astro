      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/order_files?order_id=eq.${orderId}&order=created_at.desc`,
        { headers: { apikey: SUPABASE_KEY, Authorization: `Bearer ${session?.access_token}` } }
      );
