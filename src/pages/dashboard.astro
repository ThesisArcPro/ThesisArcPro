---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="My Orders" description="View your orders on ThesisArcPro">
  <Header />

  <main>
    <section class="dashboard">
      <div class="container">

        <div class="dashboard__header">
          <div>
            <h1>My Orders</h1>
            <p id="welcomeText">Welcome back!</p>
          </div>
          <div class="dashboard__actions">
            <a href={`${base}/contact/`} class="btn-primary">+ New Order</a>
            <button id="logoutBtn" class="btn-logout">Log Out</button>
          </div>
        </div>

        <div class="dashboard__tabs">
          <button class="tab active" data-tab="all">All Orders</button>
          <button class="tab" data-tab="new">New</button>
          <button class="tab" data-tab="in_progress">In Progress</button>
          <button class="tab" data-tab="completed">Completed</button>
        </div>

        <div id="loadingState" class="loading-state">
          <div class="spinner"></div>
          <p>Loading your orders...</p>
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <div class="empty-icon">📋</div>
          <h3>No orders yet</h3>
          <p>Place your first order and it will appear here.</p>
          <a href={`${base}/contact/`} class="btn-primary">Place Order</a>
        </div>

        <div id="ordersGrid" class="orders-grid" style="display:none;"></div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.dashboard { background: var(--off-white); min-height: 100vh; padding: 8rem 0 4rem; }
.dashboard__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.dashboard__header h1 { color: var(--navy); font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 0.3rem; }
.dashboard__header p { color: var(--text-mid); font-size: 0.95rem; }
.dashboard__actions { display: flex; gap: 1rem; align-items: center; }
.btn-logout { background: none; border: 1.5px solid var(--navy); color: var(--navy); padding: 0.6rem 1.2rem; border-radius: 4px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.btn-logout:hover { background: var(--navy); color: white; }
.dashboard__tabs { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
.tab { background: white; border: 1.5px solid var(--border); color: var(--text-mid); padding: 0.5rem 1.2rem; border-radius: 20px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.tab.active { background: var(--navy); color: white; border-color: var(--navy); }
.tab:hover:not(.active) { border-color: var(--navy); color: var(--navy); }
.loading-state { text-align: center; padding: 4rem; color: var(--text-mid); }
.spinner { width: 40px; height: 40px; border: 3px solid var(--border); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 4rem; background: white; border-radius: 16px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h3 { color: var(--navy); margin-bottom: 0.5rem; }
.empty-state p { color: var(--text-mid); margin-bottom: 1.5rem; }
.orders-grid { display: grid; gap: 1rem; }
.order-card { background: white; border-radius: 12px; padding: 1.5rem; border: 1.5px solid var(--border); transition: all 0.2s ease; }
.order-card:hover { border-color: var(--gold); box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
.order-card__top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem; }
.order-card__ticket { font-size: 1.1rem; font-weight: 800; color: var(--navy); }
.order-card__date { color: var(--text-light); font-size: 0.82rem; }
.status-badge { padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
.status-new { background: #e3f2fd; color: #1565c0; }
.status-in_progress { background: #fff3e0; color: #e65100; }
.status-completed { background: #e8f5e9; color: #2e7d32; }
.order-card__body { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 1rem; }
.order-detail { display: flex; flex-direction: column; gap: 0.2rem; }
.order-detail__label { color: var(--text-light); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
.order-detail__value { color: var(--navy); font-size: 0.9rem; font-weight: 600; }
.order-card__footer { border-top: 1px solid var(--border); padding-top: 1rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
.order-card__instructions { color: var(--text-mid); font-size: 0.82rem; max-width: 600px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.download-btn { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--gold); color: var(--navy); padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.85rem; font-weight: 700; text-decoration: none; transition: all 0.2s ease; }
.download-btn:hover { background: var(--navy); color: white; }
@media (max-width: 768px) { .dashboard__header { flex-direction: column; } .order-card__top { flex-direction: column; } }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'all';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.replace(`${base}/login/`);
      return;
    }

    const welcomeText = document.getElementById('welcomeText');
    if (welcomeText) welcomeText.textContent = `Welcome back, ${session.user.email}`;

    await loadOrders(session);
  }

  async function loadOrders(session: any) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?client_email=eq.${session.user.email}&order=created_at.desc`,
        {
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${session.access_token}`
          }
        }
      );
      allOrders = await res.json();
      renderOrders(allOrders);
    } catch (err) {
      console.error('Error loading orders:', err);
    }
  }

  function getStatusBadge(status: string) {
    const map: Record<string, string> = {
      'new': '<span class="status-badge status-new">🆕 New</span>',
      'in_progress': '<span class="status-badge status-in_progress">⚙️ In Progress</span>',
      'completed': '<span class="status-badge status-completed">✅ Completed</span>',
    };
    return map[status] || `<span class="status-badge status-new">${status}</span>`;
  }

  function renderOrders(orders: any[]) {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');

    if (loading) loading.style.display = 'none';

    if (!orders || orders.length === 0) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'grid';
      grid.innerHTML = orders.map(order => `
        <div class="order-card">
          <div class="order-card__top">
            <div>
              <div class="order-card__ticket">${order.order_number || 'N/A'}</div>
              <div class="order-card__date">${new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
            </div>
            ${getStatusBadge(order.order_status || 'new')}
          </div>
          <div class="order-card__body">
            <div class="order-detail">
              <span class="order-detail__label">Topic</span>
              <span class="order-detail__value">${order.topic || 'N/A'}</span>
            </div>
            <div class="order-detail">
              <span class="order-detail__label">Type</span>
              <span class="order-detail__value">${order.assignment_type || 'N/A'}</span>
            </div>
            <div class="order-detail">
              <span class="order-detail__label">Pages</span>
              <span class="order-detail__value">${order.pages || 'N/A'}</span>
            </div>
            <div class="order-detail">
              <span class="order-detail__label">Deadline</span>
              <span class="order-detail__value">${order.deadline ? new Date(order.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'N/A'}</span>
            </div>
            <div class="order-detail">
              <span class="order-detail__label">Total</span>
              <span class="order-detail__value">$${order.total_amount || '0'}</span>
            </div>
            <div class="order-detail">
              <span class="order-detail__label">Amount Paid</span>
              <span class="order-detail__value">$${order.amount_paid || '0'}</span>
            </div>
          </div>
          <div class="order-card__footer">
            <div class="order-card__instructions">${order.instructions || ''}</div>
            ${order.file_url ? `<a href="${order.file_url}" target="_blank" class="download-btn">📥 Download Work</a>` : ''}
          </div>
        </div>
      `).join('');
    }
  }

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'all';
      const filtered = currentTab === 'all'
        ? allOrders
        : allOrders.filter(o => o.order_status === currentTab);
      renderOrders(filtered);
    });
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  checkAuth();
</script>