---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="My Orders" description="View your orders on ThesisArcPro">
  <Header />

  <main>
    <section class="dashboard">
      <div class="container">

        <div class="dashboard__header">
          <div>
            <h1>My Orders</h1>
            <p id="welcomeText">Welcome back!</p>
          </div>
          <div class="dashboard__actions">
            <a href={`${base}/contact/`} class="btn-primary">+ New Order</a>
            <button id="logoutBtn" class="btn-logout">Log Out</button>
          </div>
        </div>

        <div class="dashboard__tabs">
          <button class="tab active" data-tab="all">All Orders</button>
          <button class="tab" data-tab="new">New</button>
          <button class="tab" data-tab="in_progress">In Progress</button>
          <button class="tab" data-tab="completed">Completed</button>
        </div>

        <div id="loadingState" class="loading-state">
          <div class="spinner"></div>
          <p>Loading your orders...</p>
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <div class="empty-icon">📋</div>
          <h3>No orders yet</h3>
          <p>Place your first order and it will appear here.</p>
          <a href={`${base}/contact/`} class="btn-primary">Place Order</a>
        </div>

        <div id="ordersGrid" class="orders-grid" style="display:none;"></div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.dashboard { background: var(--navy); min-height: 100vh; padding: 8rem 0 4rem; }
.dashboard__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.dashboard__header h1 { color: var(--white); font-size: clamp(1.8rem, 4vw, 2.5rem); margin-bottom: 0.3rem; }
.dashboard__header p { color: rgba(255,255,255,0.6); font-size: 0.95rem; }
.dashboard__actions { display: flex; gap: 1rem; align-items: center; }
.btn-logout { background: none; border: 1.5px solid rgba(255,255,255,0.3); color: white; padding: 0.6rem 1.2rem; border-radius: 4px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.btn-logout:hover { background: rgba(255,255,255,0.1); }
.dashboard__tabs { display: flex; gap: 0.5rem; margin-bottom: 1.5rem; flex-wrap: wrap; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem; }
.tab { background: none; border: none; color: rgba(255,255,255,0.5); padding: 0.5rem 1.2rem; border-radius: 20px; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; }
.tab.active { background: var(--gold); color: var(--navy); }
.tab:hover:not(.active) { color: white; }
.loading-state { text-align: center; padding: 4rem; color: rgba(255,255,255,0.5); }
.spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 4rem; background: rgba(255,255,255,0.05); border-radius: 16px; }
.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h3 { color: white; margin-bottom: 0.5rem; }
.empty-state p { color: rgba(255,255,255,0.5); margin-bottom: 1.5rem; }
.orders-grid { display: flex; flex-direction: column; gap: 0.8rem; }
.order-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; padding: 1.2rem 1.5rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; transition: all 0.2s ease; cursor: pointer; }
.order-card:hover { border-color: var(--gold); background: rgba(255,255,255,0.08); }
.order-card__left { flex: 1; min-width: 0; }
.order-card__title { color: white; font-weight: 700; font-size: 0.95rem; margin-bottom: 0.4rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.order-card__meta { display: flex; align-items: center; gap: 0.4rem; flex-wrap: nowrap; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.meta-dot { color: rgba(255,255,255,0.3); }
.meta-item { color: rgba(255,255,255,0.5); font-size: 0.82rem; }
.order-card__right { display: flex; align-items: center; gap: 1.5rem; flex-shrink: 0; }
.order-card__deadline { color: var(--gold); font-size: 0.85rem; font-weight: 600; white-space: nowrap; }
.order-card__amount { color: white; font-weight: 700; font-size: 0.95rem; white-space: nowrap; }
.amount-paid { color: rgba(255,255,255,0.4); font-weight: 400; font-size: 0.82rem; }
.status-badge { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.75rem; font-weight: 700; text-transform: capitalize; letter-spacing: 0.5px; }
.status-new { background: rgba(21,101,192,0.2); color: #90caf9; }
.status-in_progress { background: rgba(230,81,0,0.2); color: #ffcc80; }
.status-completed { background: rgba(46,125,50,0.2); color: #a5d6a7; }
.download-btn { display: inline-flex; align-items: center; gap: 0.4rem; background: var(--gold); color: var(--navy); padding: 0.4rem 0.8rem; border-radius: 6px; font-size: 0.82rem; font-weight: 700; text-decoration: none; transition: all 0.2s ease; white-space: nowrap; }
.download-btn:hover { background: white; }
@media (max-width: 768px) { .order-card { flex-direction: column; align-items: flex-start; } .order-card__right { width: 100%; justify-content: space-between; } }
.detail-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
.detail-modal__overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); }
.detail-modal__content { position: relative; z-index: 1001; background: #1a1a1a; border-radius: 12px; padding: 2rem; max-width: 500px; width: 90%; max-height: 80vh; overflow-y: auto; color: white; }
.detail-modal__close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: white; transition: 0.2s; }
.detail-modal__close:hover { color: var(--gold); }
.detail-title { font-size: 1.3rem; font-weight: 800; margin-bottom: 1.5rem; }
.detail-section { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
.detail-section-title { font-size: 0.75rem; text-transform: uppercase; color: rgba(255,255,255,0.6); font-weight: 700; margin-bottom: 0.8rem; letter-spacing: 0.5px; }
.detail-item__label { color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.3rem; }
.detail-item__value { color: white; font-weight: 600; font-size: 0.95rem; }
.download-btn-modal { display: inline-block; background: var(--gold); color: var(--navy); padding: 0.6rem 1.2rem; border-radius: 6px; text-decoration: none; font-weight: 700; margin-top: 1rem; transition: 0.2s; }
.download-btn-modal:hover { background: #f0c13f; }
</style>

<!-- Order Detail Modal -->
<div id="detailModal" class="detail-modal" style="display:none;">
  <div class="detail-modal__overlay"></div>
  <div class="detail-modal__content">
    <button id="closeModal" class="detail-modal__close">✕</button>
    <div id="detailContent"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'all';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.replace(`${base}/login/`);
      return;
    }

    const welcomeText = document.getElementById('welcomeText');
    if (welcomeText) welcomeText.textContent = `Welcome back, ${session.user.email}`;

    await loadOrders(session);
  }

  async function loadOrders(session: any) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?client_email=eq.${session.user.email}&order=created_at.desc`,
        {
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${session.access_token}`
          }
        }
      );
      allOrders = await res.json();
      renderOrders(allOrders);
    } catch (err) {
      console.error('Error loading orders:', err);
    }
  }

  function getStatusBadge(status: string) {
    const map: Record<string, string> = {
      'new': '<span class="status-badge status-new">new</span>',
      'in_progress': '<span class="status-badge status-in_progress">in progress</span>',
      'completed': '<span class="status-badge status-completed">completed</span>',
    };
    return map[status] || `<span class="status-badge status-new">${status}</span>`;
  }

  function timeLeft(deadline: string) {
    if (!deadline) return 'No deadline';
    const diff = new Date(deadline).getTime() - new Date().getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    if (diff < 0) return '⚠️ Overdue';
    if (days > 0) return `⏰ ${days} day${days > 1 ? 's' : ''} left`;
    return `⏰ ${hours}h left`;
  }

  function renderOrders(orders: any[]) {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');

    if (loading) loading.style.display = 'none';

    if (!orders || orders.length === 0) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'flex';
      grid.innerHTML = orders.map(order => `
        <div class="order-card" data-order-id="${order.id}">
          <div class="order-card__left">
            <div class="order-card__title">${order.topic || 'N/A'}</div>
            <div class="order-card__meta">
              ${getStatusBadge(order.order_status || 'new')} 
              <span class="meta-dot">·</span>
              <span class="meta-item">${order.pages || 1} page${order.pages > 1 ? 's' : ''}</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">${order.assignment_type || 'N/A'}</span>
              <span class="meta-dot">·</span>
              <span class="meta-item">🇺🇸</span>
              <span class="meta-dot">|</span>
              <span class="meta-item">ID ${order.order_number}</span>
            </div>
          </div>
          <div class="order-card__right">
            <div class="order-card__deadline">${timeLeft(order.deadline)}</div>
            <div class="order-card__amount">$${Number(order.total_amount || 0).toFixed(2)} <span class="amount-paid">($${Number(order.amount_paid || 0).toFixed(2)})</span></div>
            ${order.file_url ? `<a href="${order.file_url}" target="_blank" class="download-btn">📥 Download</a>` : ''}
          </div>
        </div>
      `).join('');

      // Add click handlers to cards
      grid.querySelectorAll('.order-card').forEach(card => {
        card.addEventListener('click', () => {
          const orderId = card.getAttribute('data-order-id');
          const order = orders.find(o => o.id === orderId);
          if (order) showOrderDetail(order);
        });
      });
    }
  }

  function showOrderDetail(order: any) {
    const modal = document.getElementById('detailModal');
    const content = document.getElementById('detailContent');
    
    const daysLeft = Math.ceil((new Date(order.deadline).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24));
    const startedDate = new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    const dueDate = new Date(order.deadline).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    
    content!.innerHTML = `
      <div class="detail-title">${order.topic}</div>
      
      <div class="detail-section">
        <div class="detail-section-title">Deadline</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center;">
          <div>
            <div class="detail-item__label">Status</div>
            <div class="detail-item__value" style="text-transform: capitalize;">${order.order_status?.replace(/_/g, ' ')}</div>
            <div class="detail-item__label" style="margin-top: 1rem;">Started</div>
            <div class="detail-item__value">${startedDate}</div>
          </div>
          <div style="text-align: center;">
            <div style="font-size: 2.5rem; font-weight: 800; color: var(--gold);">${daysLeft}d</div>
            <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">left</div>
            <div style="margin-top: 1.5rem;">
              <div class="detail-item__label">Due date</div>
              <div class="detail-item__value">${dueDate}</div>
            </div>
          </div>
        </div>
      </div>
      
      <div class="detail-section">
        <div class="detail-section-title">Order</div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div>
            <div class="detail-item__label">My share</div>
            <div class="detail-item__value">$${Number(order.amount_paid || 0).toFixed(2)}</div>
          </div>
          <div>
            <div class="detail-item__label">Total</div>
            <div class="detail-item__value">$${Number(order.total_amount || 0).toFixed(2)}</div>
          </div>
        </div>
      </div>
      
      ${order.file_url ? `
        <div class="detail-section">
          <a href="${order.file_url}" target="_blank" class="download-btn-modal">📥 Download Work</a>
        </div>
      ` : `
        <div style="color: rgba(255,255,255,0.6); text-align: center; padding: 1rem; background: rgba(255,255,255,0.05); border-radius: 6px; margin-top: 1rem;">
          ⏳ Work in progress... Download link will appear when completed.
        </div>
      `}
    `;
    
    modal!.style.display = 'flex';
  }

  function closeModal() {
    const modal = document.getElementById('detailModal');
    if (modal) modal.style.display = 'none';
  }

  // Close modal on overlay click
  document.getElementById('detailModal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('detailModal')) {
      closeModal();
    }
  });

  // Close modal button
  document.getElementById('closeModal')?.addEventListener('click', closeModal);

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'all';
      const filtered = currentTab === 'all'
        ? allOrders
        : allOrders.filter(o => o.order_status === currentTab);
      renderOrders(filtered);
    });
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.replace(`${base}/login/`);
  });

  checkAuth();
</script>
