            <button class="oc-send" id="ocSend">Send</button>
          </div>
        </div>
      </div>
    `;

    // ── REVISION BUTTON ──
    const revisionBtn = document.getElementById('revisionBtn');
    const revisionForm = document.getElementById('revisionForm');
    const revisionSubmit = document.getElementById('revisionSubmit');
    const revisionReason = document.getElementById('revisionReason') as HTMLTextAreaElement;
    const actionMsg = document.getElementById('actionMsg');

    if (revisionBtn && revisionForm) {
      revisionBtn.addEventListener('click', () => {
        revisionForm.classList.toggle('open');
        revisionReason.focus();
      });
    }

    if (revisionSubmit && revisionReason && actionMsg) {
      revisionSubmit.addEventListener('click', async () => {
        const reason = revisionReason.value.trim();
        if (!reason) {
          actionMsg.textContent = 'Please describe what needs to be revised before submitting.';
          actionMsg.className = 'om-action-msg error';
          return;
        }
        (revisionSubmit as HTMLButtonElement).disabled = true;
        revisionSubmit.textContent = 'Submitting…';

        // Update status to revision AND save the client's note in the same PATCH
        const ok = await updateOrderStatus(String(order.id), 'revision', reason);
        if (ok) {
          const idx = allOrders.findIndex((o: any) => o.id === order.id);
          if (idx !== -1) {
            allOrders[idx].order_status = 'revision';
            allOrders[idx].revision_note = reason;
          }
          updateCounts();
          renderOrders();
          actionMsg.textContent = '✅ Revision request submitted successfully.';
          actionMsg.className = 'om-action-msg success';
          (revisionForm as HTMLElement).classList.remove('open');
          setTimeout(() => closeModal(), 1800);
        } else {
          actionMsg.textContent = 'Something went wrong. Please try again or contact support.';
          actionMsg.className = 'om-action-msg error';
          (revisionSubmit as HTMLButtonElement).disabled = false;
          revisionSubmit.textContent = 'Submit Revision Request';
