---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="My Orders" description="View your orders on ThesisArcPro">
  <Header />

  <main>
    <section class="dashboard">
      <div class="container">

        <div class="dashboard__header">
          <h1>My Orders</h1>
          <a href={`${base}/contact/`} class="btn-new-order">+ New Order</a>
        </div>

        <div class="dashboard__tabs">
          <button class="tab active" data-tab="in_progress">Active</button>
          <button class="tab" data-tab="completed">Closed</button>
        </div>

        <div id="loadingState" class="loading-state">
          <div class="spinner"></div>
          <p>Loading your orders...</p>
        </div>

        <div id="emptyState" class="empty-state" style="display:none;">
          <p>No orders yet</p>
        </div>

        <div id="ordersGrid" class="orders-grid" style="display:none;">
          <div class="order-header">
            <div class="col-topic">Topic</div>
            <div class="col-status">Status</div>
            <div class="col-pages">Pages</div>
            <div class="col-type">Type</div>
            <div class="col-deadline">Deadline</div>
          </div>
          <div id="ordersList"></div>
        </div>

      </div>
    </section>
  </main>

  <!-- Order Detail Modal -->
  <div id="detailModal" class="detail-modal" style="display:none;">
    <div class="detail-modal__overlay"></div>
    <div class="detail-modal__content">
      <button id="closeModal" class="detail-modal__close">✕</button>
      <div id="detailContent"></div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<style>
.dashboard { background: var(--navy); min-height: 100vh; padding: 8rem 0 4rem; }
.dashboard__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
.dashboard__header h1 { color: white; font-size: 2rem; font-weight: 800; margin: 0; }
.btn-new-order { background: var(--gold); color: var(--navy); padding: 0.7rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem; transition: all 0.2s ease; }
.btn-new-order:hover { background: #f0c13f; }
.dashboard__tabs { display: flex; gap: 2rem; margin-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 1rem; }
.tab { background: none; border: none; color: white; padding: 0.5rem 0; font-size: 0.95rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; position: relative; }
.tab.active { color: var(--gold); }
.tab.active::after { content: ''; position: absolute; bottom: -1rem; left: 0; right: 0; height: 2px; background: var(--gold); }
.tab:hover { color: var(--gold); }
.loading-state { text-align: center; padding: 4rem; color: rgba(255,255,255,0.5); }
.spinner { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
@keyframes spin { to { transform: rotate(360deg); } }
.empty-state { text-align: center; padding: 4rem; color: white; }
.orders-grid { display: flex; flex-direction: column; }
.order-header { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr 1.5fr; gap: 1.5rem; padding: 1rem 1.5rem; background: rgba(255,255,255,0.05); border-radius: 8px 8px 0 0; border-bottom: 1px solid rgba(255,255,255,0.1); font-weight: 700; color: white; font-size: 0.9rem; }
.order-card { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr 1.5fr; gap: 1.5rem; padding: 1.2rem 1.5rem; border: 1px solid rgba(255,255,255,0.1); border-top: none; background: rgba(255,255,255,0.02); transition: all 0.2s ease; cursor: pointer; }
.order-card:last-child { border-radius: 0 0 8px 8px; }
.order-card:hover { background: rgba(255,255,255,0.08); border-color: var(--gold); }
.col-topic, .col-status, .col-pages, .col-type, .col-deadline { color: white; font-size: 0.9rem; display: flex; align-items: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.status-badge { display: inline-block; padding: 0.3rem 0.8rem; border-radius: 4px; font-size: 0.8rem; font-weight: 700; text-transform: capitalize; background: rgba(255,152,0,0.2); color: #ffb74d; }
.detail-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
.detail-modal__overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); }
.detail-modal__content { position: relative; z-index: 1001; background: #1a1a1a; border-radius: 12px; padding: 2rem; max-width: 500px; width: 90%; max-height: 80vh; overflow-y: auto; color: white; }
.detail-modal__close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: white; transition: 0.2s; }
.detail-modal__close:hover { color: var(--gold); }
.detail-title { font-size: 1.3rem; font-weight: 800; margin-bottom: 1.5rem; color: white; }
.detail-section { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }
.detail-section-title { font-size: 0.75rem; text-transform: uppercase; color: rgba(255,255,255,0.6); font-weight: 700; margin-bottom: 0.8rem; letter-spacing: 0.5px; }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.detail-item__label { color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-bottom: 0.3rem; }
.detail-item__value { color: white; font-weight: 600; font-size: 0.95rem; }
.download-btn-modal { display: inline-block; background: var(--gold); color: var(--navy); padding: 0.7rem 1.5rem; border-radius: 6px; text-decoration: none; font-weight: 700; margin-top: 1rem; transition: 0.2s; }
.download-btn-modal:hover { background: #f0c13f; }
@media (max-width: 1024px) { 
  .order-header, .order-card { grid-template-columns: 2fr 1fr 1fr 1fr; }
  .col-type { display: none; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'in_progress';

  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.replace(`${base}/login/`);
      return;
    }

    await loadOrders(session);
  }

  async function loadOrders(session: any) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?client_email=eq.${session.user.email}&order=created_at.desc`,
        {
          headers: {
            'apikey': SUPABASE_KEY,
            'Authorization': `Bearer ${session.access_token}`
          }
        }
      );
      allOrders = await res.json();
      renderOrders(allOrders);
    } catch (err) {
      console.error('Error loading orders:', err);
    }
  }

  function getDeadlineText(deadline: string) {
    if (!deadline) return 'No deadline';
    const diff = new Date(deadline).getTime() - new Date().getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    
    if (diff < 0) {
      const overdueDays = Math.abs(days);
      return `⚠️ ${overdueDays}d overdue`;
    }
    if (days > 0) return `⏰ ${days}d left`;
    if (hours > 0) return `⏰ ${hours}h left`;
    return '⏰ Due soon';
  }

  function renderOrders(orders: any[]) {
    const loading = document.getElementById('loadingState');
    const empty = document.getElementById('emptyState');
    const grid = document.getElementById('ordersGrid');
    const list = document.getElementById('ordersList');

    if (loading) loading.style.display = 'none';

    const filtered = currentTab === 'in_progress'
      ? orders.filter(o => o.order_status === 'in_progress')
      : orders.filter(o => o.order_status === 'completed');

    if (!filtered || filtered.length === 0) {
      if (empty) empty.style.display = 'block';
      if (grid) grid.style.display = 'none';
      return;
    }

    if (empty) empty.style.display = 'none';
    if (grid) {
      grid.style.display = 'flex';
      if (list) {
        list.innerHTML = filtered.map(order => `
          <div class="order-card" data-order-id="${order.id}">
            <div class="col-topic">${order.topic || '(no topic)'}</div>
            <div class="col-status"><span class="status-badge">${order.order_status?.replace(/_/g, ' ')}</span></div>
            <div class="col-pages">${order.pages || 1}</div>
            <div class="col-type">${order.assignment_type || 'Essay'}</div>
            <div class="col-deadline">${getDeadlineText(order.deadline)}</div>
          </div>
        `).join('');

        // Add click handlers
        list.querySelectorAll('.order-card').forEach(card => {
          card.addEventListener('click', () => {
            const orderId = card.getAttribute('data-order-id');
            const order = allOrders.find(o => o.id === orderId);
            if (order) showOrderDetail(order);
          });
        });
      }
    }
  }

  function showOrderDetail(order: any) {
    const modal = document.getElementById('detailModal');
    const content = document.getElementById('detailContent');
    
    const daysLeft = Math.ceil((new Date(order.deadline).getTime() - new Date().getTime()) / (1000 * 60 * 60 * 24));
    const startedDate = new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    const dueDate = new Date(order.deadline).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    
    content!.innerHTML = `
      <div class="detail-title">${order.topic}</div>
      
      <div class="detail-section">
        <div class="detail-section-title">Status</div>
        <div class="detail-grid">
          <div>
            <div class="detail-item__label">Current Status</div>
            <div class="detail-item__value" style="text-transform: capitalize;">${order.order_status?.replace(/_/g, ' ')}</div>
          </div>
          <div>
            <div class="detail-item__label">Started</div>
            <div class="detail-item__value">${startedDate}</div>
          </div>
        </div>
      </div>
      
      <div class="detail-section">
        <div class="detail-section-title">Deadline</div>
        <div style="text-align: center; padding: 1rem;">
          <div style="font-size: 2rem; font-weight: 800; color: var(--gold);">${daysLeft}d</div>
          <div style="font-size: 0.8rem; color: rgba(255,255,255,0.6);">left</div>
          <div style="margin-top: 0.8rem; color: white;">${dueDate}</div>
        </div>
      </div>
      
      <div class="detail-section">
        <div class="detail-section-title">Order Details</div>
        <div class="detail-grid">
          <div>
            <div class="detail-item__label">Pages</div>
            <div class="detail-item__value">${order.pages}</div>
          </div>
          <div>
            <div class="detail-item__label">Type</div>
            <div class="detail-item__value">${order.assignment_type}</div>
          </div>
          <div>
            <div class="detail-item__label">Amount Paid</div>
            <div class="detail-item__value">$${Number(order.amount_paid || 0).toFixed(2)}</div>
          </div>
          <div>
            <div class="detail-item__label">Total</div>
            <div class="detail-item__value">$${Number(order.total_amount || 0).toFixed(2)}</div>
          </div>
        </div>
      </div>
      
      ${order.file_url ? `
        <div class="detail-section">
          <a href="${order.file_url}" target="_blank" class="download-btn-modal">📥 Download Work</a>
        </div>
      ` : `
        <div style="color: rgba(255,255,255,0.6); text-align: center; padding: 1rem; background: rgba(255,255,255,0.05); border-radius: 6px;">
          ⏳ Work in progress...
        </div>
      `}
    `;
    
    modal!.style.display = 'flex';
  }

  function closeModal() {
    const modal = document.getElementById('detailModal');
    if (modal) modal.style.display = 'none';
  }

  // Close modal on overlay click
  document.getElementById('detailModal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('detailModal')) {
      closeModal();
    }
  });

  // Close modal button
  document.getElementById('closeModal')?.addEventListener('click', closeModal);

  // Tabs
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = (tab as HTMLElement).dataset.tab || 'in_progress';
      renderOrders(allOrders);
    });
  });

  checkAuth();
</script>