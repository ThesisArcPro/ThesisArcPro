        if (!confirmed) return;

        (completeBtn as HTMLButtonElement).disabled = true;
        completeBtn.textContent = 'Updating…';

        const ok = await updateOrderStatus(String(order.id), 'completed');
        if (ok) {
          const idx = allOrders.findIndex((o: any) => o.id === order.id);
          if (idx !== -1) allOrders[idx].order_status = 'completed';
          updateCounts();
          renderOrders();
          closeModal();
          reviewOrderNumber = order.order_number || String(order.id);
          reviewClientEmail = currentSession?.user?.email || '';
          reviewClientId = myClientId || order.client_id || '';
          openReviewModal();
        } else {
          actionMsg.textContent = 'Something went wrong. Please try again or contact support.';
          actionMsg.className = 'om-action-msg error';
          (completeBtn as HTMLButtonElement).disabled = false;
          completeBtn.textContent = '✅ Mark as Complete';
        }
