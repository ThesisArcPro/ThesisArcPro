  // ═══ UNREAD / NOTIFICATIONS ═══
  let unreadOrderIds = new Set<string>();
  let myConvParticipants: any[] = [];   // {conversation_id, last_read_at, order_id}
  let unreadGlobalSub: any = null;

  function playPing() {
    try {
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const osc = ctx.createOscillator(); const gain = ctx.createGain();
      osc.connect(gain); gain.connect(ctx.destination);
      osc.type = 'sine';
      osc.frequency.setValueAtTime(880, ctx.currentTime);
      osc.frequency.setValueAtTime(660, ctx.currentTime + 0.12);
      gain.gain.setValueAtTime(0.18, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + 0.35);
      osc.start(); osc.stop(ctx.currentTime + 0.35);
    } catch (e) {}
  }

  async function refreshUnread() {
    if (!currentSession) return;
    try {
      // 1. My participant rows + the conversation's order_id
      const pRes = await fetch(
        `${SUPABASE_URL}/rest/v1/conversation_participants?user_id=eq.${currentSession.user.id}&select=conversation_id,last_read_at,conversations(order_id,type)`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      const parts = await pRes.json();
      myConvParticipants = parts.map((p: any) => ({
        conversation_id: p.conversation_id,
        last_read_at: p.last_read_at,
        order_id: p.conversations?.order_id ? String(p.conversations.order_id) : null
      }));

      if (!myConvParticipants.length) { unreadOrderIds = new Set(); paintUnread(); return; }

      // 2. Fetch recent messages for those conversations in one call
      const ids = myConvParticipants.map(p => p.conversation_id);
      const inList = ids.map(i => `"${i}"`).join(',');
      const mRes = await fetch(
        `${SUPABASE_URL}/rest/v1/messages?conversation_id=in.(${inList})&select=conversation_id,sender_id,created_at&order=created_at.desc&limit=200`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      const msgs = await mRes.json();

      // 3. A conversation is unread if it has a message from someone else, newer than my last_read_at
      const newUnread = new Set<string>();
      for (const p of myConvParticipants) {
        const lr = p.last_read_at ? new Date(p.last_read_at).getTime() : 0;
        const hasNew = msgs.some((m: any) =>
          m.conversation_id === p.conversation_id &&
          m.sender_id !== currentSession.user.id &&
          new Date(m.created_at).getTime() > lr
        );
        if (hasNew && p.order_id) newUnread.add(p.order_id);
      }
      unreadOrderIds = newUnread;
      paintUnread();
    } catch (err) { console.error('refreshUnread', err); }
  }

  function paintUnread() {
    // Sidebar badge
    const badge = document.getElementById('chatsBadge');
    if (badge) {
      const n = unreadOrderIds.size;
      if (n > 0) { badge.textContent = String(n); (badge as HTMLElement).style.display = 'inline-flex'; }
      else (badge as HTMLElement).style.display = 'none';
    }
    // Dots on order rows
    document.querySelectorAll('.order-row').forEach(row => {
      const id = (row as HTMLElement).dataset.id || '';
      let dot = row.querySelector('.unread-dot');
      if (unreadOrderIds.has(id)) {
        if (!dot) {
          dot = document.createElement('span');
          dot.className = 'unread-dot';
          (row as HTMLElement).querySelector('.col-right')?.prepend(dot);
        }
      } else if (dot) { dot.remove(); }
    });
  }

  // Mark a conversation read (stamp last_read_at = now)
  async function markConversationRead(conversationId: string, orderId: string) {
    try {
      await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants?user_id=eq.${currentSession.user.id}&conversation_id=eq.${conversationId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ last_read_at: new Date().toISOString() })
      });
    } catch (e) { console.error(e); }
    unreadOrderIds.delete(orderId);
    paintUnread();
  }

  // Global subscription: any new message in ANY of my conversations
  function startGlobalUnreadSub() {
    if (unreadGlobalSub) return;
    unreadGlobalSub = supabase.channel('client-unread-all')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages' }, (payload: any) => {
        const m = payload.new;
        if (m.sender_id === currentSession.user.id) return;            // ignore my own
        const mine = myConvParticipants.find(p => p.conversation_id === m.conversation_id);
        if (!mine) return;                                             // not my conversation
        playPing();
        if (mine.order_id) { unreadOrderIds.add(mine.order_id); paintUnread(); }
      }).subscribe();
  }

  // Kick off once orders + session are ready
  (async function initUnread() {
    for (let i = 0; i < 40 && !currentSession; i++) await new Promise(r => setTimeout(r, 250));
    if (!currentSession) return;
    await refreshUnread();
    startGlobalUnreadSub();
  })();

  // ── THEME TOGGLE (icon + popup) ──
  const THEME_KEY = 'dashboard-theme';
  const themeIconBtn = document.getElementById('themeIconBtn');
  const themePopup = document.getElementById('themePopup');
  const themePopupOverlay = document.getElementById('themePopupOverlay');
  const themeIconCurrent = document.getElementById('themeIconCurrent');

  const themeIcons: Record<string, string> = { dark: '🌙', light: '☀️', system: '💻' };

  function getSystemPref() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function applyTheme(setting: string) {
    const actual = setting === 'system' ? getSystemPref() : setting;
    if (actual === 'dark') {
      document.body.classList.add('dark-mode');
    } else {
      document.body.classList.remove('dark-mode');
    }
    document.querySelectorAll('.theme-popup__opt').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.theme === setting);
    });
    if (themeIconCurrent) themeIconCurrent.textContent = themeIcons[setting] || '☀️';
    localStorage.setItem(THEME_KEY, setting);
  }

  // Open popup
  themeIconBtn?.addEventListener('click', () => {
    themePopup?.classList.add('open');
  });

  // Close popup
  themePopupOverlay?.addEventListener('click', () => {
    themePopup?.classList.remove('open');
  });

  // Option clicks
  document.querySelectorAll('.theme-popup__opt').forEach(btn => {
    btn.addEventListener('click', () => {
      applyTheme((btn as HTMLElement).dataset.theme || 'light');
      themePopup?.classList.remove('open');
    });
  });

  // System preference change
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (localStorage.getItem(THEME_KEY) === 'system') applyTheme('system');
  });

  applyTheme(localStorage.getItem(THEME_KEY) || 'light');
</script>
</BaseLayout>
