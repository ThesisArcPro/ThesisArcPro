  // ═══ ORDER CHAT (client side) ═══
  let ocConvId: string | null = null;
  let ocOrder: any = null;
  let ocSub: any = null;

  function ocRender(messages: any[]) {
    const c = document.getElementById('ocMessages');
    if (!c) return;
    if (!messages.length) { c.innerHTML = '<div class="oc-empty">No messages yet. Say hello to your writer!</div>'; return; }
    c.innerHTML = messages.map((m: any) => {
      const mine = m.sender_id === currentSession.user.id;
      const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
      const who = m.sender_role === 'support' ? 'Support' : (m.sender_name || 'Writer');
      return `<div class="oc-row ${mine ? 'mine' : 'theirs'}">
        ${!mine ? `<div class="oc-name">${esc(who)}</div>` : ''}
        <div class="oc-bubble">${esc(m.content)}</div>
        <div class="oc-time">${time}</div>
      </div>`;
    }).join('');
    c.scrollTop = c.scrollHeight;
  }

  async function ocFindConversation(orderId: string) {
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/conversations?type=eq.order&order_id=eq.${orderId}&select=id&limit=1`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
    );
    const rows = await res.json();
    return rows[0]?.id || null;
  }

  async function openOrderChat(order: any) {
    ocOrder = order;
    ocConvId = null;
    if (ocSub) { ocSub.unsubscribe(); ocSub = null; }
    const c = document.getElementById('ocMessages')!;
    c.innerHTML = '<div class="oc-loading">Loading…</div>';
    try {
      ocConvId = await ocFindConversation(String(order.id));
      if (!ocConvId) { ocRender([]); return; }
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/messages?conversation_id=eq.${ocConvId}&order=created_at.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      ocRender(await res.json());
      ocSubscribe();
      if (ocConvId) markConversationRead(ocConvId, String(order.id));
    } catch (err) { console.error(err); c.innerHTML = '<div class="oc-empty">Could not load chat.</div>'; }
  }

  function ocSubscribe() {
    if (!ocConvId || ocSub) return;
    ocSub = supabase.channel(`oc-${ocConvId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages', filter: `conversation_id=eq.${ocConvId}` },
        (payload: any) => {
          const m = payload.new;
          const c = document.getElementById('ocMessages')!;
          const ph = c.querySelector('.oc-empty, .oc-loading'); if (ph) c.innerHTML = '';
          const mine = m.sender_id === currentSession.user.id;
          const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
          const who = m.sender_role === 'support' ? 'Support' : (m.sender_name || 'Writer');
          c.insertAdjacentHTML('beforeend', `<div class="oc-row ${mine ? 'mine' : 'theirs'}">${!mine ? `<div class="oc-name">${esc(who)}</div>` : ''}<div class="oc-bubble">${esc(m.content)}</div><div class="oc-time">${time}</div></div>`);
          c.scrollTop = c.scrollHeight;
        }).subscribe();
  }

  async function ocSend() {
    const input = document.getElementById('ocInput') as HTMLInputElement;
    const text = input.value.trim();
    if (!text || !ocOrder) return;
    const btn = document.getElementById('ocSend') as HTMLButtonElement;
    btn.disabled = true; input.value = '';
    const clientName = currentSession.user.email?.split('@')[0] || 'Client';
    try {
      // First message creates the conversation + adds client as participant
      if (!ocConvId) {
        const title = `Order ${ocOrder.order_number || ocOrder.id}`;
        const cRes = await fetch(`${SUPABASE_URL}/rest/v1/conversations`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=representation' },
          body: JSON.stringify({ type: 'order', order_id: Number(ocOrder.id), title })
        });
        ocConvId = (await cRes.json())[0]?.id;
        if (!ocConvId) throw new Error('Could not create conversation');
        await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
          body: JSON.stringify({ conversation_id: ocConvId, user_id: currentSession.user.id, role: 'client', display_name: clientName })
        });
        ocSubscribe();
      }
      await fetch(`${SUPABASE_URL}/rest/v1/messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({ conversation_id: ocConvId, sender_id: currentSession.user.id, sender_name: clientName, sender_role: 'client', content: text })
      });
      await fetch(`${SUPABASE_URL}/rest/v1/conversations?id=eq.${ocConvId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ updated_at: new Date().toISOString() })
      });
    } catch (err) { console.error(err); alert('Could not send message. Please try again.'); }
    btn.disabled = false; input.focus();
  }

  document.addEventListener('click', (e) => { if ((e.target as HTMLElement)?.id === 'ocSend') ocSend(); });
  document.addEventListener('keydown', (e) => { if ((e.target as HTMLElement)?.id === 'ocInput' && (e as KeyboardEvent).key === 'Enter') { e.preventDefault(); ocSend(); } });
  async function loadClientFiles(orderId: string) {
