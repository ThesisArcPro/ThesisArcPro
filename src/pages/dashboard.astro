      box.innerHTML = files.map((f: any) => `
        <div class="cf-row">
          <div class="cf-info"><span class="cf-type">${esc(f.file_type || 'File')}</span><span class="cf-name">${esc(f.file_name || 'file')}</span></div>
          <button class="cf-dl" data-path="${esc(f.file_path)}">📥 Download</button>
        </div>`).join('');
      box.querySelectorAll('.cf-dl').forEach(btn => {
        btn.addEventListener('click', async () => {
          const path = (btn as HTMLElement).dataset.path || '';
          (btn as HTMLButtonElement).disabled = true; btn.textContent = '⏳ Preparing…';
          try {
            const { data, error } = await supabase.storage.from('completed-files').createSignedUrl(path, 120);
            if (error || !data?.signedUrl) throw error || new Error('No URL');
            window.open(data.signedUrl, '_blank');
          } catch { alert('Could not prepare the download. Please try again.'); }
          (btn as HTMLButtonElement).disabled = false; btn.textContent = '📥 Download';
        });
      });
    } catch (err) { console.error(err); box.innerHTML = '<div class="om-nofile">Could not load files.</div>'; }
  }
  
