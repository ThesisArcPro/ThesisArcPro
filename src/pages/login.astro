---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Login" 
  description="Login to your ThesisArcPro account to place orders and track your academic writing projects."
  url="https://thesisarcpro.github.io/ThesisArcPro/login">
  <Header />

  <main>
    <section class="auth-section">
      <div class="container auth__inner">

        <div class="auth-card">
          <div class="auth-card__header">
            <h1>Welcome Back</h1>
            <p>Login to place your order</p>
          </div>

          <div id="errorMsg" class="auth-error" style="display:none;"></div>

          <form class="auth-form" id="loginForm">
            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" placeholder="your@email.com" required />
            </div>

            <div class="form-group">
              <label for="password">Password *</label>
              <input type="password" id="password" placeholder="Your password" required />
            </div>

            <button type="submit" class="btn-primary auth-submit" id="submitBtn">
              Login
            </button>
          </form>

          <div class="auth-footer">
            <p>Don't have an account? <a href="/ThesisArcPro/signup/">Sign up here</a></p>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.auth-section { padding: 10rem 0 5rem; background-color: var(--off-white); min-height: 100vh; }
.auth__inner { display: flex; justify-content: center; }
.auth-card { background: var(--white); border-radius: 16px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); width: 100%; max-width: 480px; }
.auth-card__header { margin-bottom: 2rem; }
.auth-card__header h1 { color: var(--navy); font-size: 1.8rem; margin-bottom: 0.5rem; }
.auth-card__header p { color: var(--text-mid); }
.auth-form { display: flex; flex-direction: column; gap: 1.2rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-group label { color: var(--navy); font-size: 0.9rem; font-weight: 600; }
.form-group input { padding: 0.85rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 6px; font-family: var(--font-body); font-size: 0.95rem; color: var(--text-dark); background-color: var(--white); transition: border-color 0.3s ease; outline: none; width: 100%; }
.form-group input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(197,160,89,0.1); }
.auth-submit { width: 100%; padding: 1rem; font-size: 1rem; border: none; cursor: pointer; border-radius: 8px; font-weight: 700; margin-top: 0.5rem; }
.auth-footer { margin-top: 1.5rem; text-align: center; color: var(--text-mid); font-size: 0.9rem; }
.auth-footer a { color: var(--gold); font-weight: 600; text-decoration: none; }
.auth-footer a:hover { text-decoration: underline; }
.auth-error { background: #fdeaea; border: 1px solid #e74c3c; color: #c0392b; padding: 0.8rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1rem; }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const form = document.getElementById('loginForm');
  const errorMsg = document.getElementById('errorMsg');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    errorMsg!.style.display = 'none';
    submitBtn.textContent = 'Logging in...';
    submitBtn.disabled = true;

    try {
      const { error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) throw error;

      window.location.href = '/ThesisArcPro/contact/';

    } catch (error: any) {
      errorMsg!.textContent = error.message || 'Invalid email or password.';
      errorMsg!.style.display = 'block';
      submitBtn.textContent = 'Login';
      submitBtn.disabled = false;
    }
  });
</script>