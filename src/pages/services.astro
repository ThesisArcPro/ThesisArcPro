---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = '/ThesisArcPro';
---

<BaseLayout title="Services" description="Explore ThesisArcPro's full range of academic writing and research support services for all student levels.">
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="page-hero__eyebrow">What We Offer</p>
        <h1>Our Academic Services</h1>
        <p class="page-hero__sub">From high school homework to PhD dissertations — expert academic support for every student at every level.</p>
      </div>
    </section>

    <section class="services-detail">
      <div class="container">

        <div class="service-row">
          <div class="service-row__icon">📝</div>
          <div class="service-row__content">
            <h2>Essay & Assignment Help</h2>
            <p>Our expert writers provide professional essay writing and assignment support for high school and college students across all subjects and academic levels.</p>
            <div class="service-row__features">
              <span>✓ All subjects covered</span>
              <span>✓ Any deadline met</span>
              <span>✓ Plagiarism free</span>
              <span>✓ Free revisions</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

        <div class="service-row service-row--reverse">
          <div class="service-row__icon">🔬</div>
          <div class="service-row__content">
            <h2>Research Paper Writing</h2>
            <p>Our researchers produce in-depth, well-structured research papers across all academic disciplines with access to premium academic databases.</p>
            <div class="service-row__features">
              <span>✓ APA, MLA, Harvard, Chicago</span>
              <span>✓ Primary & secondary research</span>
              <span>✓ Academic database access</span>
              <span>✓ Proper citations</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

        <div class="service-row">
          <div class="service-row__icon">🎓</div>
          <div class="service-row__content">
            <h2>Dissertation & Thesis Support</h2>
            <p>Full dissertation and thesis support for Masters and PhD students. From your initial proposal through to your final defence, our expert consultants guide you every step of the way.</p>
            <div class="service-row__features">
              <span>✓ Proposal writing</span>
              <span>✓ Chapter by chapter support</span>
              <span>✓ Research methodology</span>
              <span>✓ Statistical analysis</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

        <div class="service-row service-row--reverse">
          <div class="service-row__icon">✏️</div>
          <div class="service-row__content">
            <h2>Editing & Proofreading</h2>
            <p>Our professional editors review your work for grammar, spelling, punctuation, style, structure, and academic tone to the highest academic standards.</p>
            <div class="service-row__features">
              <span>✓ Grammar & spelling</span>
              <span>✓ Structure & flow</span>
              <span>✓ Academic tone</span>
              <span>✓ Formatting & referencing</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

        <div class="service-row">
          <div class="service-row__icon">📚</div>
          <div class="service-row__content">
            <h2>Homework Assistance</h2>
            <p>Fast, reliable homework help for high school students across all subjects. Our tutors provide clear, well-explained answers that help students understand the material.</p>
            <div class="service-row__features">
              <span>✓ Math & Sciences</span>
              <span>✓ English & Languages</span>
              <span>✓ History & Social Studies</span>
              <span>✓ Fast turnaround</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

        <div class="service-row service-row--reverse">
          <div class="service-row__icon">💡</div>
          <div class="service-row__content">
            <h2>Research Consulting</h2>
            <p>One-on-one expert consulting sessions for researchers who need guidance on research design, methodology, data analysis, and academic writing.</p>
            <div class="service-row__features">
              <span>✓ 1-on-1 expert sessions</span>
              <span>✓ Research design</span>
              <span>✓ Data analysis guidance</span>
              <span>✓ Academic writing coaching</span>
            </div>
            <a href="#" class="btn-primary auth-gate-page">Order Now</a>
          </div>
        </div>

      </div>
    </section>

    <section class="services-cta">
      <div class="container services-cta__inner">
        <h2>Ready To Get Started?</h2>
        <p>Book a free consultation today and let us match you with the perfect expert for your needs.</p>
        <div class="services-cta__buttons">
          <a href="#" class="btn-primary auth-gate-page">Book Free Consultation</a>
          <a href="#" class="btn-secondary auth-gate-page">Get a Quote</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.page-hero { background-color: var(--navy); padding: 10rem 0 5rem; text-align: center; }
.page-hero__eyebrow { color: var(--gold); font-size: 0.85rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1rem; }
.page-hero h1 { color: var(--white); margin-bottom: 1.5rem; }
.page-hero__sub { color: rgba(255,255,255,0.7); font-size: 1.1rem; max-width: 600px; margin: 0 auto; }
.services-detail { padding: var(--section-padding); background-color: var(--bg-body); }
.service-row { display: grid; grid-template-columns: auto 1fr; gap: 3rem; align-items: start; padding: 3rem 0; border-bottom: 1px solid var(--card-border); }
.service-row:last-child { border-bottom: none; }
.service-row--reverse { grid-template-columns: 1fr auto; }
.service-row--reverse .service-row__icon { order: 2; }
.service-row--reverse .service-row__content { order: 1; }
.service-row__icon { font-size: 4rem; width: 100px; height: 100px; background-color: var(--bg-section-alt); border: 1px solid var(--card-border); border-radius: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.service-row__content h2 { color: var(--heading-color); margin-bottom: 1rem; font-size: 1.8rem; }
.service-row__content p { color: var(--body-color); line-height: 1.8; margin-bottom: 1.5rem; max-width: 680px; }
.service-row__features { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 1.5rem; }
.service-row__features span { background-color: var(--bg-section-alt); color: var(--heading-color); font-size: 0.85rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 20px; border: 1px solid var(--card-border); }
.services-cta { background-color: var(--bg-section-alt); padding: 5rem 0; }
.services-cta__inner { text-align: center; }
.services-cta h2 { color: var(--heading-color); margin-bottom: 1rem; }
.services-cta p { color: var(--body-color); margin-bottom: 2rem; font-size: 1.1rem; }
.services-cta__buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
@media (max-width: 768px) {
  .service-row { grid-template-columns: 1fr; gap: 1.5rem; }
  .service-row--reverse .service-row__icon { order: 0; }
  .service-row--reverse .service-row__content { order: 0; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';
  const { data: { session } } = await supabase.auth.getSession();
  const btns = document.querySelectorAll('.auth-gate-page');
  btns.forEach(btn => {
    btn.setAttribute('href', '/ThesisArcPro/contact/');
  });
</script>