---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Sign Up" 
  description="Create your ThesisArcPro account to place orders and track your academic writing projects."
  url="https://thesisarcpro.github.io/ThesisArcPro/signup">
  <Header />

  <main>
    <section class="auth-section">
      <div class="container auth__inner">

        <div class="auth-card">
          <div class="auth-card__header">
            <h1>Create Account</h1>
            <p>Sign up to place your order and track progress</p>
          </div>

          <div id="errorMsg" class="auth-error" style="display:none;"></div>
          <div id="successMsg" class="auth-success" style="display:none;"></div>

          <form class="auth-form" id="signupForm">
            <div class="form-group">
              <label for="fullName">Full Name *</label>
              <input type="text" id="fullName" placeholder="Your full name" required />
            </div>

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input type="email" id="email" placeholder="your@email.com" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone / WhatsApp (optional)</label>
              <input type="tel" id="phone" placeholder="+1 234 567 8900" />
            </div>

            <div class="form-group">
              <label for="password">Password *</label>
              <input type="password" id="password" placeholder="Min 8 characters" required />
            </div>

            <div class="form-group">
              <label for="confirmPassword">Confirm Password *</label>
              <input type="password" id="confirmPassword" placeholder="Repeat your password" required />
            </div>

            <button type="submit" class="btn-primary auth-submit" id="submitBtn">
              Create Account
            </button>
          </form>

          <div class="auth-footer">
            <p>Already have an account? <a href="/ThesisArcPro/login/">Login here</a></p>
          </div>
        </div>

        <div class="auth-info">
          <h2>Why Create an Account?</h2>
          <div class="auth-benefits">
            <div class="benefit">
              <span class="benefit__icon">📋</span>
              <div>
                <strong>Track Your Orders</strong>
                <p>See all your orders and their status in one place</p>
              </div>
            </div>
            <div class="benefit">
              <span class="benefit__icon">⚡</span>
              <div>
                <strong>Faster Ordering</strong>
                <p>Your details auto-fill every time you place an order</p>
              </div>
            </div>
            <div class="benefit">
              <span class="benefit__icon">🔒</span>
              <div>
                <strong>Secure Payments</strong>
                <p>Pay safely and securely via PayPal</p>
              </div>
            </div>
            <div class="benefit">
              <span class="benefit__icon">📧</span>
              <div>
                <strong>Order Notifications</strong>
                <p>Get email updates on your order progress</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
.auth-section { padding: 10rem 0 5rem; background-color: var(--off-white); min-height: 100vh; }
.auth__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
.auth-card { background: var(--white); border-radius: 16px; padding: 2.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.08); }
.auth-card__header { margin-bottom: 2rem; }
.auth-card__header h1 { color: var(--navy); font-size: 1.8rem; margin-bottom: 0.5rem; }
.auth-card__header p { color: var(--text-mid); }
.auth-form { display: flex; flex-direction: column; gap: 1.2rem; }
.form-group { display: flex; flex-direction: column; gap: 0.4rem; }
.form-group label { color: var(--navy); font-size: 0.9rem; font-weight: 600; }
.form-group input { padding: 0.85rem 1rem; border: 1.5px solid rgba(0,0,0,0.12); border-radius: 6px; font-family: var(--font-body); font-size: 0.95rem; color: var(--text-dark); background-color: var(--white); transition: border-color 0.3s ease; outline: none; width: 100%; }
.form-group input:focus { border-color: var(--gold); box-shadow: 0 0 0 3px rgba(197,160,89,0.1); }
.auth-submit { width: 100%; padding: 1rem; font-size: 1rem; border: none; cursor: pointer; border-radius: 8px; font-weight: 700; margin-top: 0.5rem; }
.auth-footer { margin-top: 1.5rem; text-align: center; color: var(--text-mid); font-size: 0.9rem; }
.auth-footer a { color: var(--gold); font-weight: 600; text-decoration: none; }
.auth-footer a:hover { text-decoration: underline; }
.auth-error { background: #fdeaea; border: 1px solid #e74c3c; color: #c0392b; padding: 0.8rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1rem; }
.auth-success { background: #eafaf1; border: 1px solid #2ecc71; color: #1a7a3c; padding: 0.8rem 1rem; border-radius: 8px; font-size: 0.9rem; margin-bottom: 1rem; }
.auth-info h2 { color: var(--navy); margin-bottom: 1.5rem; }
.auth-benefits { display: flex; flex-direction: column; gap: 1.5rem; }
.benefit { display: flex; gap: 1rem; align-items: flex-start; }
.benefit__icon { font-size: 1.8rem; flex-shrink: 0; }
.benefit strong { display: block; color: var(--navy); margin-bottom: 0.3rem; }
.benefit p { color: var(--text-mid); font-size: 0.9rem; margin: 0; }
@media (max-width: 768px) {
  .auth__inner { grid-template-columns: 1fr; }
  .auth-info { display: none; }
}
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const form = document.getElementById('signupForm');
  const errorMsg = document.getElementById('errorMsg');
  const successMsg = document.getElementById('successMsg');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const fullName = (document.getElementById('fullName') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

    // Validation
    if (password !== confirmPassword) {
      errorMsg!.textContent = 'Passwords do not match!';
      errorMsg!.style.display = 'block';
      return;
    }

    if (password.length < 8) {
      errorMsg!.textContent = 'Password must be at least 8 characters!';
      errorMsg!.style.display = 'block';
      return;
    }

    errorMsg!.style.display = 'none';
    submitBtn.textContent = 'Creating account...';
    submitBtn.disabled = true;

    try {
      // Create auth user
      const { data, error } = await supabase.auth.signUp({
        email,
        password,
        options: {
          data: { full_name: fullName, phone }
        }
      });

      if (error) throw error;

      // Save profile to database
      if (data.user) {
        await supabase.from('profiles').insert({
          id: data.user.id,
          email,
          full_name: fullName,
          phone
        });
      }

      successMsg!.textContent = '✅ Account created! Please check your email to verify your account, then login.';
      successMsg!.style.display = 'block';
      submitBtn.textContent = 'Account Created!';

      setTimeout(() => {
        window.location.href = '/ThesisArcPro/login/';
      }, 3000);

    } catch (error: any) {
      errorMsg!.textContent = error.message || 'Something went wrong. Please try again.';
      errorMsg!.style.display = 'block';
      submitBtn.textContent = 'Create Account';
      submitBtn.disabled = false;
    }
  });
</script>
