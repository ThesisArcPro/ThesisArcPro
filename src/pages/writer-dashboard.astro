<div class="modal" id="detailModal">
  <div class="modal-overlay" id="modalOverlay"></div>
  <div class="modal-box">
    <button class="modal-close" id="modalClose">✕</button>
    <div id="modalContent"></div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '/ThesisArcPro';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  let allOrders: any[] = [];
  let currentTab = 'in_progress';
  let currentProfileTab = 'overview';
  let currentSession: any = null;
  let writerId: number | null = null;
  let writerData: any = null;
  let writerReviews: any[] = [];
  let activeOrderId: number | null = null;
  let activeOrderNumber = '';

  function esc(v: any) {
    return String(v ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function deadlineInfo(deadline: string) {
    if (!deadline) return { text: 'No deadline', cls: '' };
    const diff = new Date(deadline).getTime() - Date.now();
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    if (diff < 0) return { text: `⚠️ ${Math.abs(days)}d overdue`, cls: 'overdue' };
    if (days === 0 && hours > 0) return { text: `⏰ ${hours}h left`, cls: 'urgent' };
    if (days <= 2) return { text: `⏰ ${days}d left`, cls: 'urgent' };
    return { text: `⏰ ${days}d left`, cls: 'ok' };
  }

  function statusClass(status: string) {
    const known = ['new','in_progress','in_review','completed','revision','cancelled'];
    return known.includes(status) ? status : 'new';
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.replace(`${base}/writer-login/`); return; }
    currentSession = session;

    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/writers?auth_user_id=eq.${session.user.id}&select=*`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
    );
    const data = await res.json();
    if (!data.length) {
      await supabase.auth.signOut();
      window.location.replace(`${base}/writer-login/`);
      return;
    }

    writerData = data[0];
    writerId = writerData.id;
    const nameEl = document.getElementById('writerName');
    const subEl = document.getElementById('writerSub');
    if (nameEl) nameEl.textContent = 'My Orders';
    if (subEl) subEl.textContent = `Welcome back, ${writerData.full_name}`;

    await loadOrders();
    await loadWriterReviews();
  }

  async function loadWriterReviews() {
    try {
      const orderNumbers = allOrders.map(o => o.order_number).filter(Boolean);
      if (!orderNumbers.length) { writerReviews = []; return; }
      const inList = orderNumbers.map((n: string) => `"${n}"`).join(',');
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/reviews?order_number=in.(${inList})&order=created_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      writerReviews = await res.json();
    } catch (err) { console.error(err); writerReviews = []; }
  }

  async function loadOrders() {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/orders?writer_id=eq.${writerId}&select=id,order_number,topic,assignment_type,pages,deadline,order_status,instructions,education_level,subject,language,service,created_at&order=created_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      allOrders = await res.json();
      updateCounts();
      renderOrders();
    } catch (err) {
      console.error(err);
    }
  }

  function updateCounts() {
    const countFor = (tab: string) => allOrders.filter((o: any) => {
      const s = o.order_status;
      if (tab === 'in_progress') return s === 'in_progress' || s === 'new';
      return s === tab;
    }).length;

    const set = (id: string, val: number) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(val);
    };
    set('count_in_progress', countFor('in_progress'));
    set('count_in_review', countFor('in_review'));
    set('count_revision', countFor('revision'));
    set('count_completed', countFor('completed'));
    set('count_cancelled', countFor('cancelled'));
  }

  function renderOrders() {
    const loading = document.getElementById('loadingState')!;
    const empty = document.getElementById('emptyState')!;
    const table = document.getElementById('orderTable')!;
    const list = document.getElementById('ordersList')!;
    const search = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();

    loading.style.display = 'none';

    let filtered = allOrders.filter((o: any) =>
      currentTab === 'in_progress'
        ? (o.order_status === 'in_progress' || o.order_status === 'new')
        : o.order_status === currentTab
    );

    if (search) {
      filtered = filtered.filter((o: any) =>
        (o.topic || '').toLowerCase().includes(search) ||
        (o.assignment_type || '').toLowerCase().includes(search) ||
        String(o.order_number || o.id).toLowerCase().includes(search)
      );
    }

    if (!filtered.length) {
      empty.style.display = 'flex';
      table.style.display = 'none';
      const emptyHeading = document.getElementById('emptyHeading');
      if (emptyHeading) emptyHeading.textContent = 'No orders in this view';
      return;
    }

    empty.style.display = 'none';
    table.style.display = 'flex';
    list.style.display = 'flex';
    list.style.flexDirection = 'column';
    list.style.gap = '0.5rem';

    list.innerHTML = filtered.map((o: any) => {
      const dl = deadlineInfo(o.deadline);
      return `
        <div class="order-row" data-id="${esc(o.id)}">
          <div class="col-left">
            <div class="order-title">${esc(o.topic || '(no topic)')}</div>
            <div class="order-meta">
              <span class="status-badge ${statusClass(o.order_status)}">${esc((o.order_status||'').replace(/_/g,' '))}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.pages||1)} page${(o.pages||1)>1?'s':''}</span>
              <span class="meta-dot">·</span>
              <span>${esc(o.assignment_type||'Essay')}</span>
              <span class="meta-dot">·</span>
              <span class="order-id">ID ${esc(o.order_number||o.id)}</span>
            </div>
          </div>
          <div class="col-right">
            <div class="col-deadline ${dl.cls}">${dl.text}</div>
          </div>
        </div>
      `;
    }).join('');

    list.querySelectorAll('.order-row').forEach(row => {
      row.addEventListener('click', () => {
        const id = (row as HTMLElement).dataset.id;
        const order = allOrders.find((o: any) => String(o.id) === id);
        if (order) showModal(order);
      });
    });
  }

  function showModal(order: any) {
    activeOrderId = order.id;
    activeOrderNumber = order.order_number || String(order.id);

    const dl = deadlineInfo(order.deadline);
    const startDate = order.created_at
      ? new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
      : '—';
    const dueDate = order.deadline
      ? new Date(order.deadline).toLocaleString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
      : '—';

    const field = (label: string, value: string) =>
      `<div><div class="om-label">${label}</div><div class="om-value">${value}</div></div>`;

    document.getElementById('modalContent')!.innerHTML = `
      <div class="om-header">
        <div class="om-title">${esc(order.topic || '(no topic)')}</div>
        <div class="om-id">ID ${esc(order.order_number || order.id)}</div>
      </div>

      <div class="om-tabs">
        <button class="om-tab om-tab--active" data-mtab="general">General</button>
        <button class="om-tab" data-mtab="instructions">Instructions</button>
        <button class="om-tab" data-mtab="files">Files</button>
        <button class="om-tab" data-mtab="chat">💬 Chat</button>
      </div>

      <!-- GENERAL -->
      <div class="om-panel om-panel--active" data-mpanel="general">
        <div class="om-grid">
          ${field('Status', esc((order.order_status || '—').replace(/_/g,' ')))}
          ${field('Pages', esc(order.pages || '—'))}
          ${field('Started', esc(startDate))}
          ${field('Time Left', dl.text)}
          ${field('Type', esc(order.assignment_type || '—'))}
          ${field('Deadline', esc(dueDate))}
        </div>
      </div>

      <!-- INSTRUCTIONS -->
      <div class="om-panel" data-mpanel="instructions">
        <div class="om-grid">
          ${field('Type', esc(order.assignment_type || '—'))}
          ${field('Pages', esc(order.pages || '—'))}
          ${field('Education level', esc(order.education_level || '—'))}
          ${field('Subject', esc(order.subject || '—'))}
          ${field('Language', esc(order.language || '—'))}
          ${field('Service', esc(order.service || '—'))}
        </div>
        <div>
          <div class="om-desc-label">Description</div>
          <div class="om-desc">${order.instructions ? esc(order.instructions) : 'No description provided.'}</div>
        </div>
      </div>

      <!-- FILES (writer upload) -->
      <div class="om-panel" data-mpanel="files">
        <p class="upload-order-id">Order: ${esc(activeOrderNumber)} — ${esc(order.topic || '')}</p>

        <div class="form-group">
          <label>Submit file as</label>
          <select id="fileType">
            <option value="">— Select file type —</option>
            <option value="Final Copy">Final Copy</option>
            <option value="Revision">Revision</option>
            <option value="AI Report">AI Report</option>
            <option value="Turnitin Report">Turnitin Report</option>
            <option value="Graphics & Tables">Graphics & Tables</option>
            <option value="Abstract">Abstract</option>
            <option value="Early Draft">Early Draft</option>
            <option value="Outline">Outline</option>
            <option value="Printable Sources">Printable Sources</option>
          </select>
        </div>

        <div class="form-group">
          <label>Choose file</label>
          <input type="file" id="fileInput" accept=".pdf,.doc,.docx,.txt,.zip,.ppt,.pptx,.xls,.xlsx,.png,.jpg,.jpeg" />
        </div>

        <button class="upload-btn" id="uploadBtn">📤 Upload File</button>
        <div class="upload-msg" id="uploadMsg" style="display:none;"></div>

        <div class="files-section">
          <h3>Uploaded Files</h3>
          <div id="filesList" class="files-list"></div>
        </div>

        <div class="review-action" id="reviewActionWrap">
          <button class="btn-review" id="markReviewBtn">📤 Submit & Mark as In Review</button>
          <div class="review-msg" id="reviewMsg"></div>
        </div>
      </div>

      <!-- CHAT -->
      <div class="om-panel" data-mpanel="chat">
        <div class="woc-thread">
          <div class="woc-messages" id="wocMessages"><div class="woc-loading">Loading…</div></div>
          <div class="woc-input-bar">
            <input type="text" class="woc-input" id="wocInput" placeholder="Message the client…" />
            <button class="woc-send" id="wocSend">Send</button>
          </div>
        </div>
      </div>
    `;

    // Modal tab switching
    const content = document.getElementById('modalContent')!;
    content.querySelectorAll('.om-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const which = (tab as HTMLElement).dataset.mtab;
        content.querySelectorAll('.om-tab').forEach(t => t.classList.remove('om-tab--active'));
        content.querySelectorAll('.om-panel').forEach(p => p.classList.remove('om-panel--active'));
        tab.classList.add('om-tab--active');
        content.querySelector(`.om-panel[data-mpanel="${which}"]`)?.classList.add('om-panel--active');
        if (which === 'files') loadOrderFiles();
        if (which === 'chat') openWriterOrderChat(order);
      });
    });

    document.getElementById('uploadBtn')?.addEventListener('click', handleUpload);

    // Mark as In Review
    const reviewBtn = document.getElementById('markReviewBtn');
    const reviewWrap = document.getElementById('reviewActionWrap');
    // hide the button if the order is already past in_review
    if (reviewWrap && ['completed', 'cancelled'].includes(order.order_status)) {
      (reviewWrap as HTMLElement).style.display = 'none';
    }
    reviewBtn?.addEventListener('click', async () => {
      const msg = document.getElementById('reviewMsg')!;
      const btn = reviewBtn as HTMLButtonElement;
      if (!confirm('Mark this order as "In Review"? The client and admin will be notified it\'s ready to review.')) return;
      btn.disabled = true; btn.textContent = '⏳ Updating…';
      try {
        const r = await fetch(`${SUPABASE_URL}/rest/v1/orders?id=eq.${order.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', apikey: SUPABASE_KEY, Authorization: `Bearer ${currentSession.access_token}`, Prefer: 'return=minimal' },
          body: JSON.stringify({ order_status: 'in_review', status_updated_at: new Date().toISOString() })
        });
        if (!r.ok) throw new Error('Update failed');
        // reflect locally
        const idx = allOrders.findIndex((o: any) => o.id === order.id);
        if (idx !== -1) allOrders[idx].order_status = 'in_review';
        order.order_status = 'in_review';
        updateCounts();
        renderOrders();
        msg.textContent = '✅ Order marked as In Review.';
        msg.className = 'review-msg success';
        btn.textContent = '✓ In Review';
      } catch (err) {
        console.error(err);
        msg.textContent = 'Could not update. Please try again.';
        msg.className = 'review-msg error';
        btn.disabled = false; btn.textContent = '📤 Submit & Mark as In Review';
      }
    });

    document.getElementById('detailModal')!.classList.add('open');
  }

  // ── FILES: load + delete ──
  async function loadOrderFiles() {
    const filesList = document.getElementById('filesList');
    if (!filesList) return;
    filesList.innerHTML = '<div class="no-files">Loading…</div>';

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/order_files?order_id=eq.${activeOrderId}&order=created_at.desc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      const files = await res.json();

      if (!files.length) {
        filesList.innerHTML = '<div class="no-files">No files uploaded yet.</div>';
        return;
      }

      filesList.innerHTML = files.map((f: any) => `
        <div class="file-row" data-file-id="${f.id}" data-file-path="${esc(f.file_path)}">
          <div class="file-info">
            <span class="file-type-badge">${esc(f.file_type)}</span>
            <div class="file-name">${esc(f.file_name)}</div>
          </div>
          <button class="file-delete" data-file-id="${f.id}" data-file-path="${esc(f.file_path)}">🗑️</button>
        </div>
      `).join('');

      filesList.querySelectorAll('.file-delete').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          e.stopPropagation();
          const fileId = (btn as HTMLElement).dataset.fileId;
          const filePath = (btn as HTMLElement).dataset.filePath;
          if (!confirm('Delete this file?')) return;

          await supabase.storage.from('completed-files').remove([filePath || '']);
          await fetch(`${SUPABASE_URL}/rest/v1/order_files?id=eq.${fileId}`, {
            method: 'DELETE',
            headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` }
          });
          await loadOrderFiles();
        });
      });

    } catch (err) {
      console.error(err);
      filesList.innerHTML = '<div class="no-files">Could not load files.</div>';
    }
  }

  // ── UPLOAD ──
  async function handleUpload() {
    const fileType = (document.getElementById('fileType') as HTMLSelectElement).value;
    const fileInput = document.getElementById('fileInput') as HTMLInputElement;
    const btn = document.getElementById('uploadBtn') as HTMLButtonElement;
    const msg = document.getElementById('uploadMsg')!;

    if (!fileType) {
      msg.textContent = 'Please select a file type.';
      msg.className = 'upload-msg error';
      msg.style.display = 'block';
      return;
    }

    const file = fileInput.files && fileInput.files[0];
    if (!file) {
      msg.textContent = 'Please choose a file.';
      msg.className = 'upload-msg error';
      msg.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = '⏳ Uploading…';
    msg.style.display = 'none';

    try {
      const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
      const path = `${activeOrderNumber}/${fileType.replace(/[^a-zA-Z0-9]/g, '_')}_${Date.now()}_${safeName}`;

      const { error: upErr } = await supabase.storage.from('completed-files').upload(path, file, { upsert: true });
      if (upErr) throw upErr;

      const res = await fetch(`${SUPABASE_URL}/rest/v1/order_files`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_KEY,
          'Authorization': `Bearer ${currentSession.access_token}`
        },
        body: JSON.stringify({
          order_id: activeOrderId,
          order_number: activeOrderNumber,
          file_type: fileType,
          file_name: file.name,
          file_path: path,
          uploaded_by: 'writer'
        })
      });

      if (!res.ok) throw new Error('Failed to save file record');

      msg.textContent = `✅ ${fileType} uploaded successfully!`;
      msg.className = 'upload-msg success';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '📤 Upload File';
      fileInput.value = '';
      (document.getElementById('fileType') as HTMLSelectElement).value = '';

      await loadOrderFiles();

    } catch (err) {
      console.error(err);
      msg.textContent = 'Upload failed. Please try again.';
      msg.className = 'upload-msg error';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = '📤 Upload File';
    }
  }
// ═══ WRITER ORDER CHAT ═══
  let wocConvId: string | null = null;
  let wocOrder: any = null;
  let wocSub: any = null;

  function wocRender(messages: any[]) {
    const c = document.getElementById('wocMessages');
    if (!c) return;
    if (!messages.length) { c.innerHTML = '<div class="woc-empty">No messages yet. Say hello to the client!</div>'; return; }
    c.innerHTML = messages.map((m: any) => {
      const mine = m.sender_id === currentSession.user.id;
      const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
      const who = m.sender_role === 'support' ? 'Support' : (m.sender_name || 'Client');
      return `<div class="woc-row ${mine ? 'mine' : 'theirs'}">
        ${!mine ? `<div class="woc-name">${esc(who)}</div>` : ''}
        <div class="woc-bubble">${esc(m.content)}</div>
        <div class="woc-time">${time}</div>
      </div>`;
    }).join('');
    c.scrollTop = c.scrollHeight;
  }

  async function wocFindConversation(orderId: string) {
    const res = await fetch(
      `${SUPABASE_URL}/rest/v1/conversations?type=eq.order&order_id=eq.${orderId}&select=id&limit=1`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
    );
    const rows = await res.json();
    return rows[0]?.id || null;
  }

  // Make sure the writer is a participant (self-add, always RLS-allowed)
  async function wocEnsureSelf(convId: string) {
    try {
      const existing = await (await fetch(
        `${SUPABASE_URL}/rest/v1/conversation_participants?conversation_id=eq.${convId}&user_id=eq.${currentSession.user.id}&select=id`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      )).json();
      if (existing.length) return;
      await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({ conversation_id: convId, user_id: currentSession.user.id, role: 'writer', display_name: writerData?.full_name || 'Writer' })
      });
    } catch (e) { console.error('wocEnsureSelf', e); }
  }

  async function openWriterOrderChat(order: any) {
    wocOrder = order;
    wocConvId = null;
    if (wocSub) { wocSub.unsubscribe(); wocSub = null; }
    const c = document.getElementById('wocMessages')!;
    c.innerHTML = '<div class="woc-loading">Loading…</div>';
    try {
      wocConvId = await wocFindConversation(String(order.id));
      if (!wocConvId) { wocRender([]); return; }   // no chat yet; created on first message
      await wocEnsureSelf(wocConvId);
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/messages?conversation_id=eq.${wocConvId}&order=created_at.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      wocRender(await res.json());
      wocSubscribe();
    } catch (err) { console.error(err); c.innerHTML = '<div class="woc-empty">Could not load chat.</div>'; }
  }

  function wocSubscribe() {
    if (!wocConvId || wocSub) return;
    wocSub = supabase.channel(`woc-${wocConvId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages', filter: `conversation_id=eq.${wocConvId}` },
        (payload: any) => {
          const m = payload.new;
          const c = document.getElementById('wocMessages')!;
          const ph = c.querySelector('.woc-empty, .woc-loading'); if (ph) c.innerHTML = '';
          const mine = m.sender_id === currentSession.user.id;
          const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
          const who = m.sender_role === 'support' ? 'Support' : (m.sender_name || 'Client');
          c.insertAdjacentHTML('beforeend', `<div class="woc-row ${mine ? 'mine' : 'theirs'}">${!mine ? `<div class="woc-name">${esc(who)}</div>` : ''}<div class="woc-bubble">${esc(m.content)}</div><div class="woc-time">${time}</div></div>`);
          c.scrollTop = c.scrollHeight;
        }).subscribe();
  }

  async function wocSend() {
    const input = document.getElementById('wocInput') as HTMLInputElement;
    const text = input.value.trim();
    if (!text || !wocOrder) return;
    const btn = document.getElementById('wocSend') as HTMLButtonElement;
    btn.disabled = true; input.value = '';
    try {
      if (!wocConvId) {
        const title = `Order ${wocOrder.order_number || wocOrder.id}`;
        const cRes = await fetch(`${SUPABASE_URL}/rest/v1/conversations`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=representation' },
          body: JSON.stringify({ type: 'order', order_id: Number(wocOrder.id), title })
        });
        wocConvId = (await cRes.json())[0]?.id;
        if (!wocConvId) throw new Error('Could not create conversation');
        await wocEnsureSelf(wocConvId);
        wocSubscribe();
      }
      await fetch(`${SUPABASE_URL}/rest/v1/messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({ conversation_id: wocConvId, sender_id: currentSession.user.id, sender_name: writerData?.full_name || 'Writer', sender_role: 'writer', content: text })
      });
      await fetch(`${SUPABASE_URL}/rest/v1/conversations?id=eq.${wocConvId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ updated_at: new Date().toISOString() })
      });
    } catch (err) { console.error(err); alert('Could not send message. Please try again.'); }
    btn.disabled = false; input.focus();
  }

