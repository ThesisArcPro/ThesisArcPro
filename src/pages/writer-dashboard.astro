  // ═══ CHAT SYSTEM ═══
  let chatConversations: any[] = [];
  let activeConversationId: string | null = null;
  let chatSubscription: any = null;

  async function loadConversations() {
    const chatList = document.getElementById('chatList')!;
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/conversation_participants?user_id=eq.${currentSession.user.id}&select=conversation_id,conversations(id,type,title,updated_at,order_id)`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      const data = await res.json();
      chatConversations = data.map((d: any) => d.conversations).filter(Boolean).sort((a: any, b: any) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());

      if (!chatConversations.length) {
        chatList.innerHTML = '<div class="chat-list-loading">No conversations yet</div>';
        return;
      }
      renderChatList();
    } catch (err) { console.error(err); chatList.innerHTML = '<div class="chat-list-loading">Could not load chats</div>'; }
  }

  function renderChatList(filter = '') {
    const chatList = document.getElementById('chatList')!;
    let filtered = chatConversations;
    if (filter) filtered = filtered.filter((c: any) => (c.title || '').toLowerCase().includes(filter));

    chatList.innerHTML = filtered.map((c: any) => {
      const isSupport = c.type === 'support';
      const avatarClass = isSupport ? 'avatar-support' : 'avatar-order';
      const icon = isSupport ? 'SP' : 'OR';
      const title = c.title || (isSupport ? 'Support' : 'Order Chat');
      const typeLabel = isSupport ? 'Support conversation' : 'Order chat';
      const time = c.updated_at ? new Date(c.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '';
      const isActive = c.id === activeConversationId;

      return `<div class="chat-item ${isActive ? 'active' : ''}" data-cid="${c.id}">
        <div class="chat-item-avatar ${avatarClass}">${icon}</div>
        <div class="chat-item-info">
          <div class="chat-item-name">${esc(title)}</div>
          <div class="chat-item-type">${typeLabel}</div>
        </div>
        <div class="chat-item-time">${time}</div>
      </div>`;
    }).join('');

    chatList.querySelectorAll('.chat-item').forEach(item => {
      item.addEventListener('click', () => {
        const cid = (item as HTMLElement).dataset.cid!;
        openConversation(cid);
      });
    });
  }

  async function openConversation(conversationId: string) {
    activeConversationId = conversationId;
    const conv = chatConversations.find((c: any) => c.id === conversationId);

    document.getElementById('chatMainEmpty')!.style.display = 'none';
    const thread = document.getElementById('chatThread')!;
    thread.style.display = 'flex';

    const header = document.getElementById('chatThreadHeader')!;
    const title = conv?.title || (conv?.type === 'support' ? 'Support' : 'Order Chat');
    const typeLabel = conv?.type === 'support' ? 'Support channel' : conv?.type === 'order' ? `Order chat` : 'Direct message';
    header.innerHTML = `<div class="chat-thread-title">${esc(title)}</div><div class="chat-thread-sub">${typeLabel}</div>`;

    renderChatList((document.getElementById('chatSearchInput') as HTMLInputElement).value.toLowerCase());
    await loadMessages(conversationId);
    subscribeTo(conversationId);
  }

  async function loadMessages(conversationId: string) {
    const container = document.getElementById('chatMessages')!;
    container.innerHTML = '<div style="text-align:center;color:var(--text-muted);padding:2rem;">Loading…</div>';

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/messages?conversation_id=eq.${conversationId}&order=created_at.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` } }
      );
      const messages = await res.json();
      renderMessages(messages);
    } catch (err) { console.error(err); container.innerHTML = '<div style="text-align:center;color:var(--text-muted);">Could not load messages</div>'; }
  }

  function renderMessages(messages: any[]) {
    const container = document.getElementById('chatMessages')!;
    if (!messages.length) {
      container.innerHTML = '<div style="text-align:center;color:var(--text-muted);padding:2rem;">No messages yet. Say hello!</div>';
      return;
    }
    container.innerHTML = messages.map((m: any) => {
      const isMine = m.sender_id === currentSession.user.id;
      const time = m.created_at ? new Date(m.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
      return `<div class="msg-row ${isMine ? 'mine' : 'theirs'}">
        ${!isMine ? `<div class="msg-sender">${esc(m.sender_name || m.sender_role || 'User')}</div>` : ''}
        <div class="msg-bubble">${esc(m.content)}</div>
        <div class="msg-time">${time}</div>
      </div>`;
    }).join('');
    container.scrollTop = container.scrollHeight;
  }

  function subscribeTo(conversationId: string) {
    if (chatSubscription) { chatSubscription.unsubscribe(); chatSubscription = null; }
    chatSubscription = supabase
      .channel(`chat-${conversationId}`)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'messages', filter: `conversation_id=eq.${conversationId}` },
        (payload: any) => {
          const msg = payload.new;
          const container = document.getElementById('chatMessages')!;
          const isMine = msg.sender_id === currentSession.user.id;
          const time = msg.created_at ? new Date(msg.created_at).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '';
          const noMsgYet = container.querySelector('div[style*="text-align:center"]');
          if (noMsgYet) container.innerHTML = '';
          container.insertAdjacentHTML('beforeend', `<div class="msg-row ${isMine ? 'mine' : 'theirs'}">
            ${!isMine ? `<div class="msg-sender">${esc(msg.sender_name || msg.sender_role || 'User')}</div>` : ''}
            <div class="msg-bubble">${esc(msg.content)}</div>
            <div class="msg-time">${time}</div>
          </div>`);
          container.scrollTop = container.scrollHeight;
        }
      )
      .subscribe();
  }

  // Send message
  document.getElementById('chatSendBtn')?.addEventListener('click', sendMessage);
  document.getElementById('chatInput')?.addEventListener('keydown', (e) => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } });

  async function sendMessage() {
    const input = document.getElementById('chatInput') as HTMLInputElement;
    const content = input.value.trim();
    if (!content || !activeConversationId) return;

    const btn = document.getElementById('chatSendBtn') as HTMLButtonElement;
    btn.disabled = true;
    input.value = '';

    try {
      await fetch(`${SUPABASE_URL}/rest/v1/messages`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({
          conversation_id: activeConversationId,
          sender_id: currentSession.user.id,
          sender_name: writerData?.full_name || 'Writer',
          sender_role: 'writer',
          content: content
        })
      });
      // Update conversation timestamp
      await fetch(`${SUPABASE_URL}/rest/v1/conversations?id=eq.${activeConversationId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=minimal' },
        body: JSON.stringify({ updated_at: new Date().toISOString() })
      });
    } catch (err) { console.error(err); }
    btn.disabled = false;
    input.focus();
  }

  // Search chats
  document.getElementById('chatSearchInput')?.addEventListener('input', (e) => {
    renderChatList((e.target as HTMLInputElement).value.toLowerCase());
  });

  // New Chat Modal
  document.getElementById('newChatBtn')?.addEventListener('click', () => document.getElementById('newChatModal')!.classList.add('open'));
  document.getElementById('newChatClose')?.addEventListener('click', () => { document.getElementById('newChatModal')!.classList.remove('open'); document.getElementById('orderSelectWrap')!.style.display = 'none'; });
  document.getElementById('newChatOverlay')?.addEventListener('click', () => { document.getElementById('newChatModal')!.classList.remove('open'); document.getElementById('orderSelectWrap')!.style.display = 'none'; });

  document.querySelectorAll('.new-chat-opt').forEach(opt => {
    opt.addEventListener('click', async () => {
      const type = (opt as HTMLElement).dataset.chatType;
      if (type === 'support') {
        await createConversation('support', null, 'Support');
        document.getElementById('newChatModal')!.classList.remove('open');
      } else if (type === 'order') {
        const wrap = document.getElementById('orderSelectWrap')!;
        const select = document.getElementById('chatOrderSelect') as HTMLSelectElement;
        select.innerHTML = allOrders.map(o => `<option value="${o.id}">${esc(o.order_number || o.id)} — ${esc(o.topic || '(no topic)')}</option>`).join('');
        wrap.style.display = 'block';
      }
    });
  });

  document.getElementById('startOrderChatBtn')?.addEventListener('click', async () => {
    const select = document.getElementById('chatOrderSelect') as HTMLSelectElement;
    const orderId = select.value;
    const order = allOrders.find(o => String(o.id) === orderId);
    const title = order ? `Order ${order.order_number || order.id}` : 'Order Chat';
    await createConversation('order', Number(orderId), title);
    document.getElementById('newChatModal')!.classList.remove('open');
    document.getElementById('orderSelectWrap')!.style.display = 'none';
  });

  async function createConversation(type: string, orderId: number | null, title: string) {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/conversations`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}`, 'Prefer': 'return=representation' },
        body: JSON.stringify({ type, order_id: orderId, title })
      });
      const convs = await res.json();
      const conv = convs[0];
      if (!conv) throw new Error('Failed to create conversation');

      // Add self as participant
      await fetch(`${SUPABASE_URL}/rest/v1/conversation_participants`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${currentSession.access_token}` },
        body: JSON.stringify({ conversation_id: conv.id, user_id: currentSession.user.id, role: 'writer', display_name: writerData?.full_name || 'Writer' })
      });

      await loadConversations();
      openConversation(conv.id);
    } catch (err) { console.error(err); alert('Could not create conversation. Please try again.'); }
  }

  // Load chats when switching to chat view
  const origChatNav = document.querySelector('.nav-item[data-view="chat"]');
  if (origChatNav) {
    const origHandler = origChatNav.getAttribute('data-view');
    origChatNav.addEventListener('click', () => { setTimeout(() => loadConversations(), 100); });
  }
</script>

</body>
</html>