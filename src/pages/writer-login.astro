---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '';
---

<BaseLayout title="Writer Login" description="ThesisArcPro Writer Portal">
  <div class="wl">
    <div class="wl__card">
      <h1>Writer Portal</h1>
      <p class="wl__sub">Log in with the credentials provided by your admin.</p>

      <div class="form-group">
        <label>Email</label>
        <input type="email" id="email" placeholder="your@email.com" />
      </div>

      <div class="form-group">
        <label>Password</label>
        <input type="password" id="password" placeholder="••••••••" />
      </div>

      <button class="wl__btn" id="loginBtn">Log In</button>
      <div class="wl__msg" id="msg" style="display:none;"></div>
    </div>
  </div>
</BaseLayout>

<style>
.wl {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  padding: 2rem;
  font-family: 'Poppins', sans-serif;
}
.wl__card {
  background: #ffffff;
  border-radius: 16px;
  padding: 2.5rem;
  width: 100%;
  max-width: 400px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
}
.wl__card h1 {
  font-size: 1.5rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 0.3rem;
}
.wl__sub {
  color: #64748b;
  font-size: 0.88rem;
  margin-bottom: 2rem;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  margin-bottom: 1.2rem;
}
.form-group label {
  font-size: 0.85rem;
  font-weight: 600;
  color: #303b4f;
}
.form-group input {
  padding: 0.75rem 1rem;
  border: 1.5px solid #e2e8f0;
  border-radius: 10px;
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}
.form-group input:focus {
  border-color: #046fcd;
}
.wl__btn {
  width: 100%;
  padding: 0.85rem;
  background: #046fcd;
  color: white;
  border: none;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 0.5rem;
}
.wl__btn:hover { background: #0361b3; }
.wl__btn:disabled { opacity: 0.6; cursor: not-allowed; }
.wl__msg {
  margin-top: 1rem;
  padding: 0.7rem 0.9rem;
  border-radius: 8px;
  font-size: 0.82rem;
  font-weight: 600;
}
.wl__msg.error { background: #fef2f2; color: #dc2626; }
.wl__msg.success { background: #ecfdf5; color: #16a34a; }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  const base = '';
  const SUPABASE_URL = 'https://rehvwvujuamehoanfomj.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';

  // If already logged in as a writer, redirect
  (async () => {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/writers?auth_user_id=eq.${session.user.id}&select=id`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${session.access_token}` } }
      );
      const data = await res.json();
      if (data.length > 0) {
        window.location.replace(`${base}/writer-dashboard/`);
      }
    }
  })();

  document.getElementById('loginBtn')?.addEventListener('click', async () => {
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value.trim();
    const btn = document.getElementById('loginBtn') as HTMLButtonElement;
    const msg = document.getElementById('msg') as HTMLElement;

    if (!email || !password) {
      msg.textContent = 'Please enter both email and password.';
      msg.className = 'wl__msg error';
      msg.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Logging in…';
    msg.style.display = 'none';

    try {
      const { data, error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) throw error;

      // Verify this user is a writer
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/writers?auth_user_id=eq.${data.user.id}&select=id`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${data.session.access_token}` } }
      );
      const writers = await res.json();

      if (!writers.length) {
        await supabase.auth.signOut();
        msg.textContent = 'This account is not linked to a writer profile. Contact your admin.';
        msg.className = 'wl__msg error';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Log In';
        return;
      }

      msg.textContent = '✅ Welcome! Redirecting…';
      msg.className = 'wl__msg success';
      msg.style.display = 'block';
      setTimeout(() => {
        window.location.href = `${base}/writer-dashboard/`;
      }, 800);

    } catch (err: any) {
      msg.textContent = err.message || 'Login failed. Check your credentials.';
      msg.className = 'wl__msg error';
      msg.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Log In';
    }
  });

  // Enter key submits
  document.getElementById('password')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('loginBtn')?.click();
  });
</script>
