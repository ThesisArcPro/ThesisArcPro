---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = 'https://rehvwvujuamehoanfomj.supabase.co';
const supabaseKey = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
const supabase = createClient(supabaseUrl, supabaseKey);

let writers = [];
let error = null;

try {
  const { data, error: fetchError } = await supabase
    .from('writers')
    .select('*')
    .order('rating', { ascending: false });
  
  if (fetchError) {
    error = fetchError.message;
    console.error('Supabase error:', fetchError);
  } else {
    writers = data || [];
  }
} catch (e) {
  error = e.message;
  console.error('Error:', e);
}
---

<BaseLayout
  title="Our Expert Academic Writers | ThesisArcPro"
  description="Meet our team of qualified academic writers. All writers have degrees in their specializations and proven track records of delivering high-quality academic papers.">

  <main class="writers-page">
    <section class="writers-hero">
      <h1>Our Expert Academic Writers</h1>
      <p>Meet the qualified professionals behind ThesisArcPro. All our writers hold advanced degrees and have extensive experience supporting students across the UK, USA, Australia, and Canada.</p>
    </section>

    {error ? (
      <div class="error-message">
        <p>Error loading writers: {error}</p>
      </div>
    ) : writers.length > 0 ? (
      <section class="writers-grid">
        {writers.map((writer) => (
          <article class="writer-card">
            <div class="writer-image">
              {writer.photo ? (
                <img
                  src={writer.photo}
                  alt={writer.name}
                  loading="lazy"
                />
              ) : (
                <div class="placeholder">
                  <span>{writer.name.charAt(0)}</span>
                </div>
              )}
            </div>

            <div class="writer-info">
              <h2>{writer.name}</h2>
              <p class="qualification">{writer.qualification}</p>

              <div class="writer-stats">
                <div class="stat">
                  <span class="rating">⭐ {writer.rating.toFixed(1)}</span>
                </div>
                <div class="stat">
                  <span class="orders">{writer.orders_completed} orders</span>
                </div>
              </div>

              <p class="experience">{writer.experience_years} years experience</p>

              <div class="specializations">
                {writer.specializations && writer.specializations.split(', ').slice(0, 3).map((spec) => (
                  <span class="spec-badge">{spec}</span>
                ))}
              </div>

              <a href={`/writers/${writer.slug}`} class="view-profile">
                View Profile →
              </a>
            </div>
          </article>
        ))}
      </section>
    ) : (
      <div class="no-writers">
        <p>No writers found. Please check back soon.</p>
      </div>
    )}
  </main>

</BaseLayout>

<style>
  .writers-page {
    background-color: #ffffff;
  }

  .writers-hero {
    text-align: center;
    padding: 4rem 2rem;
    background: linear-gradient(135deg, #1B2A4A 0%, #2d4a7a 100%);
    color: white;
  }

  .writers-hero h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .writers-hero p {
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
    opacity: 0.9;
  }

  .writers-grid {
    max-width: 1200px;
    margin: 3rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }

  .writer-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }

  .writer-card:hover {
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    border-color: #C9A84C;
    transform: translateY(-4px);
  }

  .writer-image {
    width: 100%;
    height: 200px;
    background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .writer-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1B2A4A 0%, #2d4a7a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: white;
    font-weight: bold;
  }

  .writer-info {
    padding: 1.5rem;
  }

  .writer-info h2 {
    font-size: 1.3rem;
    color: #1B2A4A;
    margin-bottom: 0.25rem;
  }

  .qualification {
    color: #64748b;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .writer-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .stat {
    flex: 1;
  }

  .rating {
    display: block;
    font-size: 1.1rem;
    color: #1B2A4A;
    font-weight: bold;
  }

  .orders {
    display: block;
    font-size: 0.9rem;
    color: #64748b;
  }

  .experience {
    color: #64748b;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .specializations {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .spec-badge {
    display: inline-block;
    background-color: #f0f4f8;
    color: #1B2A4A;
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
  }

  .view-profile {
    display: inline-block;
    color: #C9A84C;
    text-decoration: none;
    font-weight: bold;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .view-profile:hover {
    color: #1B2A4A;
    text-decoration: underline;
  }

  .error-message {
    text-align: center;
    padding: 2rem;
    color: #dc2626;
    background-color: #fee2e2;
    margin: 2rem;
    border-radius: 8px;
  }

  .no-writers {
    text-align: center;
    padding: 2rem;
    color: #64748b;
  }
</style>