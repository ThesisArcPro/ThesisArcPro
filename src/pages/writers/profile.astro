---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = 'https://rehvwvujuamehoanfomj.supabase.co';
const supabaseKey = 'sb_publishable_CKxnbue4T6cVn9BOIg8BkQ_kBNBiM_h';
const supabase = createClient(supabaseUrl, supabaseKey);

export async function getStaticPaths() {
  const { data: writers } = await supabase
    .from('writers')
    .select('slug');

  return (writers || []).map((writer) => ({
    params: { slug: writer.slug }
  }));
}

const { slug } = Astro.params;

const { data: writer } = await supabase
  .from('writers')
  .select('*')
  .eq('slug', slug)
  .single();

const { data: reviews } = await supabase
  .from('reviews')
  .select('*')
  .eq('writer_id', writer.id)
  .order('created_at', { ascending: false });

if (!writer) {
  return Astro.redirect('/writers');
}

const avgRating = reviews && reviews.length > 0
  ? (reviews.reduce((sum, r) => sum + r.overall_rating, 0) / reviews.length).toFixed(1)
  : writer.rating.toFixed(1);
---

<BaseLayout
  title={`${writer.name} - Academic Writer | ThesisArcPro`}
  description={`Meet ${writer.name}, an expert academic writer. ${writer.qualification}. ${reviews?.length || 0} reviews.`}>

  <main class="writer-profile-page">
    <section class="writer-header">
      <div class="writer-hero">
        <div class="writer-image">
          {writer.photo ? (
            <img src={writer.photo} alt={writer.name} />
          ) : (
            <div class="placeholder">
              <span>{writer.name.charAt(0)}</span>
            </div>
          )}
        </div>
        <div class="writer-details">
          <h1>{writer.name}</h1>
          <p class="qualification">{writer.qualification}</p>
          <div class="stats">
            <div class="stat">
              <span class="rating">⭐ {avgRating}</span>
              <span class="count">{reviews?.length || 0} reviews</span>
            </div>
            <div class="stat">
              <span class="orders">{writer.orders_completed}</span>
              <span class="label">orders completed</span>
            </div>
            <div class="stat">
              <span class="experience">{writer.experience_years}</span>
              <span class="label">years experience</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="writer-info">
      <div class="bio">
        <h2>About</h2>
        <p>{writer.bio || 'Expert academic writer with proven track record.'}</p>
      </div>

      <div class="specializations">
        <h2>Specializations</h2>
        <div class="specs">
          {writer.specializations ? writer.specializations.split(', ').map((spec) => (
            <span class="spec">{spec}</span>
          )) : <p>Multiple subjects</p>}
        </div>
      </div>
    </section>

    {reviews && reviews.length > 0 && (
      <section class="reviews-section">
        <h2>Student Reviews ({reviews.length})</h2>
        <div class="reviews-list">
          {reviews.map((review) => (
            <div class="review-card">
              <div class="review-header">
                <div>
                  <span class="customer-name">{review.customer_name || 'Anonymous'}</span>
                  <span class="review-date">{new Date(review.created_at).toLocaleDateString()}</span>
                </div>
                <span class="review-rating">⭐ {review.overall_rating}</span>
              </div>
              <p class="review-comment">{review.comment || ''}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="cta-section">
      <h2>Ready to Work with {writer.name}?</h2>
      <a href="/ThesisArcPro/contact" class="cta-button">Place an Order</a>
    </section>
  </main>

</BaseLayout>

<style>
  .writer-profile-page {
    background-color: #ffffff;
  }

  .writer-header {
    background: linear-gradient(135deg, #1B2A4A 0%, #2d4a7a 100%);
    color: white;
    padding: 3rem 2rem;
  }

  .writer-hero {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .writer-image {
    width: 250px;
    height: 250px;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255,255,255,0.1);
  }

  .writer-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    background: rgba(255,255,255,0.2);
  }

  .writer-details h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .qualification {
    font-size: 1.1rem;
    opacity: 0.9;
    margin-bottom: 1.5rem;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat span {
    display: block;
  }

  .rating, .orders, .experience {
    font-size: 1.8rem;
    font-weight: bold;
    margin-bottom: 0.25rem;
  }

  .count, .label {
    font-size: 0.9rem;
    opacity: 0.8;
  }

  .writer-info {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 2rem;
  }

  .writer-info h2 {
    font-size: 1.5rem;
    color: #1B2A4A;
    margin-bottom: 1rem;
  }

  .bio p {
    font-size: 1rem;
    line-height: 1.8;
    color: #334155;
    margin-bottom: 2rem;
  }

  .specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .spec {
    display: inline-block;
    background-color: #f0f4f8;
    color: #1B2A4A;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    border: 1px solid #e2e8f0;
  }

  .reviews-section {
    max-width: 1000px;
    margin: 3rem auto;
    padding: 0 2rem;
  }

  .reviews-section h2 {
    font-size: 1.5rem;
    color: #1B2A4A;
    margin-bottom: 1.5rem;
  }

  .reviews-list {
    display: grid;
    gap: 1.5rem;
  }

  .review-card {
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 1.5rem;
    background-color: #f8fafc;
  }

  .review-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .customer-name {
    display: block;
    font-weight: bold;
    color: #1B2A4A;
    margin-bottom: 0.25rem;
  }

  .review-date {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .review-rating {
    font-weight: bold;
    color: #1B2A4A;
  }

  .review-comment {
    color: #334155;
    line-height: 1.6;
  }

  .cta-section {
    text-align: center;
    max-width: 1000px;
    margin: 4rem auto;
    padding: 3rem 2rem;
    background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%);
    border-radius: 12px;
  }

  .cta-section h2 {
    font-size: 1.8rem;
    color: #1B2A4A;
    margin-bottom: 1.5rem;
  }

  .cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: #C9A84C;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: bold;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background-color: #b8963d;
    transform: translateY(-2px);
  }
</style>